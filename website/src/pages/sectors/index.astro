---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/reskin/PageHero.astro";
import WCtaBand from "../../components/reskin/WCtaBand.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";

const sectors = (await getCollection("sectors")).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100)
);
---

<Layout
  title="Digital Marketing by Industry in Ireland | Rooftop Twenty Two"
  description="Marketing for Irish brands in hotels & hospitality, furniture & interiors, financial & professional services, healthcare, and food & drink."
>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Sectors", url: "/sectors/" }]} />

  <PageHero
    kicker="Sectors"
    title="Marketing built around your <em>sector</em>."
    intro="We work closely with a handful of sectors where we've built real depth. The buyer journeys are different, the seasons are different, and the things that actually move pipeline are different. We know yours."
    primary={{ label: "Talk to us about yours", href: "/contact/#contact" }}
    secondary={{ label: "See our work", href: "/work/" }}
  />

  <section class="sec">
    <div class="sec__inner">
      {sectors.length > 0 ? (
        <ul class="sec__grid">
          {sectors.map((s, i) => (
            <li class="reveal">
              <a class="sec-card" href={`/sectors/${s.data.slug}/`}>
                <span class="sec-card__n">{String(i + 1).padStart(2, "0")}</span>
                <h2 class="sec-card__title">{s.data.name}</h2>
                <p class="sec-card__sum">{s.data.summary}</p>
                <span class="sec-card__cta r22-arrow">Explore <span class="r22-arrow__i" aria-hidden="true">&rarr;</span></span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="sec__empty">Sector pages are on the way. In the meantime, every sector starts the same way: a conversation about your buyer, your numbers, and where to focus first.</p>
      )}
    </div>
  </section>

  <WCtaBand />
</Layout>

<style>
  .sec { background: var(--c-bg-alt); color: var(--c-ink); padding-block: var(--w-section-y); }
  .sec__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .sec__grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 760px) { .sec__grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; } }
  .sec-card {
    display: block; height: 100%; background: var(--c-bg); border: 1px solid var(--c-line);
    border-radius: var(--w-radius); padding: clamp(1.75rem, 3vw, 2.5rem); text-decoration: none; color: inherit;
    transition: transform var(--w-dur) var(--w-ease), box-shadow var(--w-dur) var(--w-ease);
  }
  .sec-card:hover { transform: translateY(-3px); box-shadow: var(--w-shadow-soft); }
  .sec-card__n { font-family: var(--w-font-display); font-weight: 700; font-size: 1.1rem; color: var(--c-accent); }
  .sec-card__title { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h3); line-height: 1.1; color: var(--c-ink); margin: 0.6rem 0 0; }
  .sec-card__sum { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); line-height: 1.55; margin: 0.6rem 0 0; }
  .sec-card__cta { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--w-font-body); font-weight: 600; color: var(--c-accent); margin-top: 1.25rem; }
  .sec__empty { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); max-width: 60ch; }
</style>
