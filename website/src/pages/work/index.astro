---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/reskin/PageHero.astro";
import WCtaBand from "../../components/reskin/WCtaBand.astro";
import Picture from "../../components/Picture.astro";

const entries = (await getCollection("portfolio", ({ data }) => !data.needs_review))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
---

<Layout
  title="Web Design & Digital Marketing Case Studies | Dublin"
  description="Selected case studies from Rooftop Twenty Two: branding, websites, and performance marketing for hotels, healthcare, interiors, and more across Ireland."
>
  <PageHero
    kicker="Selected work"
    title="Work we&rsquo;d <em>put our name to</em>."
    intro="Recent work spanning brand, web design and development, photography, and digital marketing, for ambitious Irish businesses and not-for-profits."
  />

  <section class="wk">
    <ul class="wk__grid">
      {entries.map((e) => {
        const slug = e.id.replace(/\.mdx?$/, "");
        const services = (e.data.services ?? []).slice(0, 3);
        const featured = e.data.featured ?? false;
        return (
          <li class:list={["wk__card reveal", featured ? "wk__card--featured" : ""]}>
            <a href={`/work/${slug}/`}>
              <figure class="wk__img" style={e.data.heroImage ? undefined : "background:var(--c-line);"}>
                {e.data.heroImage && (
                  <Picture src={e.data.heroImage} alt={e.data.name} loading="lazy" decoding="async" />
                )}
              </figure>
              <div class="wk__meta">
                <div class="wk__row">
                  <h2 class="wk__title">{e.data.name}</h2>
                  <span class="wk__cta">View project &rarr;</span>
                </div>
                {e.data.tagline && <p class="wk__tag">{e.data.tagline}</p>}
                {services.length > 0 && (
                  <ul class="wk__pills">
                    {services.map((s) => <li>{s}</li>)}
                  </ul>
                )}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>

  <WCtaBand />
</Layout>

<style>
  .wk { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); }
  .wk__grid {
    list-style: none; margin: 0 auto; padding-inline: var(--w-gutter); max-width: var(--w-container);
    display: grid; grid-template-columns: 1fr; gap: 2.5rem;
  }
  @media (min-width: 900px) { .wk__grid { grid-template-columns: repeat(2, 1fr); gap: 2.5rem 2rem; } }
  .wk__card--featured { grid-column: 1 / -1; }
  .wk__card a { display: block; text-decoration: none; color: inherit; }
  .wk__img {
    margin: 0; border-radius: var(--w-radius); overflow: hidden; aspect-ratio: 4 / 3;
    background: var(--c-bg-alt); box-shadow: var(--w-shadow-soft);
  }
  .wk__card--featured .wk__img { aspect-ratio: 21 / 9; }
  .wk__img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform var(--w-dur) var(--w-ease); }
  .wk__card a:hover .wk__img img { transform: scale(1.03); }
  .wk__meta { padding-top: 1.25rem; }
  .wk__row { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .wk__title { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h3); line-height: 1.05; margin: 0; }
  .wk__cta { font-family: var(--w-font-body); font-weight: 600; font-size: 0.9rem; color: var(--c-ink-soft); white-space: nowrap; }
  .wk__card a:hover .wk__cta { color: var(--c-ink); }
  .wk__tag { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); line-height: 1.5; margin: 0.6rem 0 0; max-width: 52ch; }
  .wk__pills { list-style: none; margin: 1rem 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .wk__pills li {
    padding: 0.35rem 0.8rem; border: 1px solid var(--c-line); border-radius: var(--radius-pill);
    font-family: var(--w-font-body); font-size: 0.75rem; letter-spacing: 0.03em; color: var(--c-ink-soft);
  }
</style>
