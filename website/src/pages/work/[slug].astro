---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PortfolioDetailHero from "../../components/PortfolioDetailHero.astro";
import CaseSection from "../../components/CaseSection.astro";

export async function getStaticPaths() {
  const entries = await getCollection("portfolio", ({ data }) => !data.needs_review);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { name, tagline, summary, heroImage, wordmark, sections, services, gallery } = entry.data;

// Build the More Work strip: 3 next case studies in order, wrapping around.
const allSorted = (await getCollection("portfolio", ({ data }) => !data.needs_review))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
const currentSlug = entry.id.replace(/\.mdx?$/, "");
const currentIndex = allSorted.findIndex(
  (e) => e.id.replace(/\.mdx?$/, "") === currentSlug
);
const moreWork = Array.from({ length: 3 }).map((_, i) => {
  const idx = (currentIndex + 1 + i) % allSorted.length;
  return allSorted[idx];
});

// Interleave gallery images between sections.
const interleavedAt = new Set<number>();
const showcasePositions = [0, 2];
const interleaved: { afterIndex: number; src: string }[] = [];
let nextGalleryIndex = 0;
for (const pos of showcasePositions) {
  if (pos < sections.length && nextGalleryIndex < gallery.length) {
    interleaved.push({ afterIndex: pos, src: gallery[nextGalleryIndex] });
    interleavedAt.add(nextGalleryIndex);
    nextGalleryIndex++;
  }
}
const remainingGallery = gallery.filter((_, i) => !interleavedAt.has(i));
---

<Layout
  title={`${name} | Rooftop Twenty Two`}
  description={summary ?? tagline ?? name}
  theme="light"
>
  <PortfolioDetailHero {name} {tagline} {heroImage} {wordmark} {services} />

  <div class="case-main" data-theme-switch>
    <div class="mx-auto max-w-[1280px] px-6 md:px-12 case-grid">
      <div class="case-body">
        {sections.map((sec, i) => (
          <>
            <CaseSection number={sec.number} heading={sec.heading} bullets={sec.bullets}>
              <p>{sec.body}</p>
            </CaseSection>
            {interleaved
              .filter((il) => il.afterIndex === i)
              .map((il) => (
                <figure class="case-showcase">
                  <img
                    src={il.src}
                    alt={`${name} project visual`}
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              ))}
          </>
        ))}

        <article class="case-article prose">
          <Content />
        </article>

        <div class="case-back">
          <a href="/work/" class="case-back__link">← Back to all projects</a>
        </div>
      </div>

      <aside class="case-rail">
        <div class="case-rail__card">
          <p class="case-rail__eyebrow">Got a project in mind?</p>
          <p class="case-rail__body">
            Tell us what you're scaling, launching, or rebuilding. We'll send a thoughtful reply and a time to talk it through.
          </p>
          <a href="/contact/" class="case-rail__cta">Start the conversation →</a>
        </div>
      </aside>
    </div>

    {remainingGallery.length > 0 && (
      <section class="case-gallery">
        <div class="mx-auto max-w-[1440px] px-6 md:px-12">
          <p class="case-gallery__eyebrow">Selected visuals</p>
        </div>
        <ul class="case-gallery__grid list-none p-0 m-0">
          {remainingGallery.map((src, i) => (
            <li
              class:list={[
                "case-gallery__item",
                i % 5 === 0 ? "case-gallery__item--wide" : "",
                i % 7 === 0 ? "case-gallery__item--tall" : "",
              ]}
            >
              <img src={src} alt={`${name} project visual ${i + 1}`} loading="lazy" decoding="async" />
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="more-work">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="more-work__head">
          <p class="more-work__eyebrow">More work</p>
          <a href="/work/" class="more-work__index">View all projects →</a>
        </div>
        <ul class="more-work__grid list-none p-0 m-0">
          {moreWork.map((e) => {
            const slug = e.id.replace(/\.mdx?$/, "");
            const svcs = (e.data.services ?? []).slice(0, 2);
            return (
              <li class="more-work__card">
                <a href={`/work/${slug}/`} class="more-work__link">
                  <div
                    class="more-work__banner"
                    style={e.data.heroImage
                      ? `background-image:url('${e.data.heroImage}');`
                      : `background-color: var(--color-navy-700);`}
                  >
                    {e.data.wordmark && (
                      <img
                        class="more-work__wordmark"
                        src={e.data.wordmark}
                        alt={`${e.data.name} wordmark`}
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                    <div class="more-work__overlay" aria-hidden="true"></div>
                  </div>
                  <div class="more-work__meta">
                    <h3 class="more-work__title">{e.data.name}</h3>
                    {svcs.length > 0 && (
                      <p class="more-work__svcs">{svcs.join(" · ")}</p>
                    )}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* Light body theme for the case study, overriding the site's dark default */
  :global(body.theme-light) {
    background-color: var(--color-stone-100, #F9F9F9);
  }
  .case-main {
    background-color: var(--color-stone-100, #F9F9F9);
    color: var(--color-text-on-light, #143A4F);
  }
  .case-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  @media (min-width: 1024px) {
    .case-grid {
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 4rem;
    }
  }

  /* Sticky right rail (Deuce-style) */
  .case-rail {
    align-self: start;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .case-rail {
      align-self: stretch;
    }
  }
  .case-rail__card {
    position: relative;
    background: var(--color-coral, #E15047);
    color: #ffffff;
    border-radius: var(--radius-card-lg, 18px);
    padding: 1.75rem 1.75rem 1.5rem;
    box-shadow: 0 14px 36px rgba(225, 80, 71, 0.18);
  }
  @media (min-width: 1024px) {
    .case-rail__card {
      position: sticky;
      top: 7.5rem;
    }
  }
  .case-rail__eyebrow {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.8vw, 1.875rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0 0 0.875rem;
    color: #ffffff;
  }
  .case-rail__body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 1.25rem;
  }
  .case-rail__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #ffffff;
    color: var(--color-coral, #E15047);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.7rem 1.1rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: gap 180ms ease, transform 180ms ease;
  }
  .case-rail__cta:hover {
    gap: 0.75rem;
    transform: translateY(-1px);
  }

  .case-showcase {
    margin: clamp(2rem, 4vw, 3rem) 0;
    border-radius: var(--radius-card-lg, 18px);
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.4);
  }
  .case-showcase img {
    width: 100%;
    height: auto;
    display: block;
  }
  .case-article {
    margin: clamp(2rem, 4vw, 3rem) 0;
    color: var(--color-text-on-light, #143A4F);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 60ch;
  }
  .case-article :global(h2),
  .case-article :global(h3),
  .case-article :global(h4) {
    font-family: var(--font-display);
    color: var(--color-text-on-light, #143A4F);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .case-article :global(p) {
    margin-bottom: 1rem;
  }
  .case-article :global(a) {
    color: var(--color-coral, #E15047);
    text-decoration: underline;
  }
  /* Selected visuals: full-bleed grid, no max-width container. */
  .case-gallery {
    margin: clamp(2rem, 5vw, 4rem) 0 clamp(2rem, 4vw, 3rem);
    padding: 0;
  }
  .case-gallery__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(20, 58, 79, 0.55);
    margin: 0 0 1rem;
  }
  .case-gallery__grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: minmax(240px, auto);
    gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .case-gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(320px, auto);
      gap: 0.75rem;
    }
  }
  @media (min-width: 1280px) {
    .case-gallery__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: minmax(380px, auto);
    }
  }
  .case-gallery__item {
    overflow: hidden;
    border-radius: var(--radius-card-md, 14px);
    background-color: rgba(255, 255, 255, 0.5);
  }
  .case-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms ease;
  }
  .case-gallery__item:hover img {
    transform: scale(1.03);
  }
  .case-gallery__item--wide {
    grid-column: span 2;
  }
  .case-gallery__item--tall {
    grid-row: span 2;
  }
  .case-back {
    margin-top: clamp(3rem, 5vw, 4rem);
  }
  .case-back__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.25rem;
    border: 1.5px solid rgba(20, 58, 79, 0.2);
    border-radius: 9999px;
    color: var(--color-text-on-light, #143A4F);
    font-family: var(--font-sans);
    font-weight: 500;
    text-decoration: none;
    transition: background 180ms ease, gap 180ms ease;
  }
  .case-back__link:hover {
    background: rgba(20, 58, 79, 0.05);
    gap: 0.75rem;
  }

  /* More work strip (Deuce-style) */
  .more-work {
    margin-top: clamp(2rem, 5vw, 4rem);
    padding-top: clamp(3rem, 5vw, 4rem);
    padding-bottom: clamp(3rem, 5vw, 4rem);
    border-top: 1px solid rgba(20, 58, 79, 0.1);
  }
  .more-work__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: clamp(2rem, 3vw, 2.5rem);
  }
  .more-work__eyebrow {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-text-on-light, #143A4F);
    margin: 0;
  }
  .more-work__index {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-coral, #E15047);
    font-weight: 600;
    text-decoration: none;
    transition: gap 180ms ease;
  }
  .more-work__index:hover {
    text-decoration: underline;
  }
  .more-work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .more-work__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
  .more-work__card {
    border-radius: var(--radius-card-md, 14px);
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.4);
    transition: transform 280ms ease;
  }
  .more-work__card:hover {
    transform: translateY(-4px);
  }
  .more-work__link {
    display: block;
    color: var(--color-text-on-light, #143A4F);
    text-decoration: none;
  }
  .more-work__banner {
    position: relative;
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .more-work__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.0) 50%, rgba(0,0,0,0.18) 100%);
    pointer-events: none;
  }
  .more-work__wordmark {
    position: relative;
    z-index: 1;
    max-width: 60%;
    max-height: 80px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.2));
  }
  .more-work__meta {
    padding: 1.125rem 1.25rem 1.375rem;
  }
  .more-work__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 0.375rem;
    color: var(--color-text-on-light, #143A4F);
  }
  .more-work__svcs {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(20, 58, 79, 0.55);
    margin: 0;
  }
</style>
