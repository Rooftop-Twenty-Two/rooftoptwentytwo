---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/reskin/PageHero.astro";
import WContactForm from "../../components/reskin/WContactForm.astro";
import Picture from "../../components/Picture.astro";

export async function getStaticPaths() {
  const entries = await getCollection("portfolio", ({ data }) => !data.needs_review);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { name, tagline, summary, heroImage, sections, services, gallery, websiteUrl } = entry.data;

const allSorted = (await getCollection("portfolio", ({ data }) => !data.needs_review))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
const currentSlug = entry.id.replace(/\.mdx?$/, "");
const currentIndex = allSorted.findIndex((e) => e.id.replace(/\.mdx?$/, "") === currentSlug);
const moreWork = Array.from({ length: 3 }).map((_, i) => allSorted[(currentIndex + 1 + i) % allSorted.length]);

// Case-study photography is interleaved between the narrative sections as large
// image breakers (no standalone gallery). One image follows each section; any
// remaining images become additional breakers before the prose. Breakers
// alternate full-bleed / inset to open up the gaps and pace the page.
const sectionImages = sections.map((_, i) => gallery[i] ?? null);
const extraImages = gallery.slice(sections.length);
---

<Layout title={`${name} | Rooftop Twenty Two`} description={summary ?? tagline ?? name}>
  <PageHero
    kicker={(services ?? []).slice(0, 3).join(" · ") || "Case study"}
    title={name}
    intro={tagline ?? summary}
    bg={heroImage}
    primary={websiteUrl
      ? { label: "Visit the website", href: websiteUrl, external: true }
      : { label: "Start a similar project", href: "/contact/" }}
    secondary={websiteUrl
      ? { label: "Start a similar project", href: "/contact/" }
      : { label: "All work", href: "/work/" }}
  />

  <section class="cs-body">
    {sections.map((sec, i) => (
      <>
        <div class="cs-wrap">
          <div class="cs-sec reveal">
            <div class="cs-sec__head">
              <span class="cs-sec__n">{sec.number}</span>
              <h2 class="cs-sec__h">{sec.heading}</h2>
            </div>
            <div class="cs-sec__content">
              <p class="cs-sec__body">{sec.body}</p>
              {sec.bullets && sec.bullets.length > 0 && (
                <ul class="cs-sec__bullets">
                  {sec.bullets.map((b) => (<li>{b}</li>))}
                </ul>
              )}
            </div>
          </div>
        </div>
        {sectionImages[i] && (
          <figure class:list={["cs-breaker reveal", i % 2 === 0 ? "cs-breaker--bleed" : "cs-breaker--inset"]}>
            <div class="cs-breaker__media r22-media">
              <Picture src={sectionImages[i]} alt={`${name}, ${sec.heading}`} loading="lazy" decoding="async" />
            </div>
            <figcaption class="cs-breaker__cap">{name} <span aria-hidden="true">·</span> {sec.heading}</figcaption>
          </figure>
        )}
      </>
    ))}

    {extraImages.map((src, j) => (
      <figure class:list={["cs-breaker reveal", (sections.length + j) % 2 === 0 ? "cs-breaker--bleed" : "cs-breaker--inset"]}>
        <div class="cs-breaker__media r22-media">
          <Picture src={src} alt={`${name} project visual`} loading="lazy" decoding="async" />
        </div>
        <figcaption class="cs-breaker__cap">{name} <span aria-hidden="true">·</span> Selected work</figcaption>
      </figure>
    ))}

    {(entry.body ?? "").trim().length > 0 && (
      <div class="cs-wrap"><article class="cs-prose"><Content /></article></div>
    )}
  </section>

  <WContactForm
    heading={`Want results like ${name}'s? <em>Let's talk</em>.`}
    routing={`project:${Astro.params.slug}`}
    prefillSubject={`Project enquiry, inspired by ${name}`}
  />

  <section class="cs-more">
    <div class="cs-more__inner">
      <div class="cs-more__head">
        <h2 class="cs-more__title">More work you&rsquo;ll like</h2>
        <a href="/work/" class="wbtn wbtn--primary">View all projects</a>
      </div>
      <ul class="cs-more__grid">
        {moreWork.map((e) => {
          const slug = e.id.replace(/\.mdx?$/, "");
          const svcs = (e.data.services ?? []).slice(0, 2);
          return (
            <li>
              <a href={`/work/${slug}/`}>
                <figure class="cs-more__img" style={e.data.heroImage ? undefined : "background:var(--c-line);"}>
                  {e.data.heroImage && <Picture src={e.data.heroImage} alt={e.data.name} loading="lazy" decoding="async" />}
                </figure>
                <h3 class="cs-more__name">{e.data.name}</h3>
                {svcs.length > 0 && <p class="cs-more__svcs">{svcs.join(" · ")}</p>}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

</Layout>

<style>
  .cs-body { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y) 0; display: flex; flex-direction: column; gap: clamp(2.5rem, 5vw, 4.5rem); }
  /* When the last item is a full-bleed (navy) breaker, let it run straight into
   * the navy contact band with no white gap. */
  .cs-body > .cs-breaker--bleed:last-child { margin-bottom: 0; }
  .cs-wrap { max-width: 1100px; width: 100%; margin: 0 auto; padding-inline: var(--w-gutter); }
  .cs-sec { display: grid; grid-template-columns: 1fr; gap: 1rem 3rem; }
  @media (min-width: 860px) { .cs-sec { grid-template-columns: 0.8fr 1.2fr; } }
  .cs-sec__head { display: flex; gap: 1rem; align-items: baseline; }
  .cs-sec__n { font-family: var(--w-font-display); font-weight: 700; font-size: 1.5rem; color: var(--c-accent); }
  .cs-sec__h { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h2); line-height: var(--lh-heading); letter-spacing: var(--tracking-display); margin: 0; }
  .cs-sec__body { font-family: var(--w-font-body); font-size: var(--fs-body); line-height: 1.75; color: var(--c-ink-soft); margin: 0; }
  .cs-sec__bullets { margin: 1.25rem 0 0; padding: 0; list-style: none; display: grid; gap: 0.6rem; }
  .cs-sec__bullets li { font-family: var(--w-font-body); color: var(--c-ink-soft); line-height: 1.5; padding-left: 1.5rem; position: relative; }
  .cs-sec__bullets li::before { content: ""; position: absolute; left: 0; top: 0.5em; width: 12px; height: 12px; background: var(--c-accent); border-radius: 0 100% 0 0; }
  .cs-prose { max-width: 65ch; font-family: var(--w-font-body); font-size: 1.05rem; line-height: 1.75; color: var(--c-ink-soft); }
  .cs-prose :global(h2), .cs-prose :global(h3) { font-family: var(--w-font-display); color: var(--c-ink); line-height: 1.15; margin: 2rem 0 0.75rem; }
  .cs-prose :global(a) { color: var(--c-ink); text-decoration: underline; }

  /* Interleaved image breakers (replace the old standalone gallery). Every image
   * is framed consistently (border + radius + shadow, fixed 16:9) so busy client
   * UI screenshots read as presented work, not raw bleed. "Feature" breakers sit
   * on a calm navy mat band for brand contrast and pacing; the rest on the page. */
  .cs-breaker { margin: 0; }
  .cs-breaker__media {
    width: min(1100px, calc(100% - 2 * var(--w-gutter)));
    margin-inline: auto;
    border-radius: var(--w-radius); border: 1px solid var(--c-line);
    box-shadow: var(--w-shadow-soft); background: var(--c-bg-alt);
  }
  .cs-breaker__media img { display: block; width: 100%; height: 100%; object-fit: cover; aspect-ratio: 16 / 9; }
  .cs-breaker__cap {
    width: min(1100px, calc(100% - 2 * var(--w-gutter)));
    margin: 0.9rem auto 0;
    font-family: var(--w-font-body); font-size: var(--fs-small); letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--c-ink-soft);
  }
  .cs-breaker__cap span { color: var(--c-accent); padding: 0 0.2rem; }

  /* Feature breaker, framed on a navy band. */
  .cs-breaker--bleed { background: var(--c-dark); padding-block: clamp(2.5rem, 5vw, 4.5rem); }
  .cs-breaker--bleed .cs-breaker__media { border-color: var(--c-line-dark); background: var(--c-dark-2); }
  .cs-breaker--bleed .cs-breaker__cap { color: var(--c-on-dark-soft); }

  .cs-more { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); }
  .cs-more__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .cs-more__head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .cs-more__title { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h2); letter-spacing: var(--tracking-display); margin: 0; }
  .cs-more__grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 760px) { .cs-more__grid { grid-template-columns: repeat(3, 1fr); } }
  .cs-more__grid a { text-decoration: none; color: inherit; display: block; }
  .cs-more__img { margin: 0; border: 1px solid var(--c-line); border-radius: var(--w-radius); overflow: hidden; aspect-ratio: 4 / 3; background: var(--c-bg-alt); box-shadow: var(--w-shadow-soft); }
  .cs-more__img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform var(--w-dur) var(--w-ease); }
  .cs-more__grid a:hover .cs-more__img img { transform: scale(1.04); }
  .cs-more__name { font-family: var(--w-font-display); font-weight: 600; font-size: 1.25rem; margin: 1rem 0 0; }
  .cs-more__svcs { font-family: var(--w-font-body); font-size: 0.8rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--c-ink-soft); margin: 0.3rem 0 0; }
</style>
