---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Signature from "../../components/Signature.astro";
import BtnFiller from "../../components/BtnFiller.astro";
import PageCTA from "../../components/PageCTA.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";

const programmes = (await getCollection("programmes")).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100)
);
---

<Layout
  title="Enterprise Ireland Programmes | Rooftop Twenty Two"
  description="Enterprise Ireland funded marketing programmes for Irish brands. Up to 50% of eligible costs covered."
>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Programmes", url: "/programmes/" }]} />

  <section class="mx-auto max-w-[1440px] px-6 md:px-12 pt-12 md:pt-20 pb-12 md:pb-16">
    <Signature text="Programmes" tone="mint" rotate={-3} />
    <h1
      class="mt-4 max-w-4xl"
      style="font-family:var(--font-display);font-size:clamp(2.75rem, 7vw, 5.5rem);color:var(--color-text-on-dark);letter-spacing:-0.02em;line-height:1.05;"
    >
      Enterprise Ireland funded engagements.
    </h1>
    <p
      class="mt-6 max-w-2xl"
      style="font-family:var(--font-sans);font-size:1.25rem;color:var(--color-text-on-dark-muted);line-height:1.55;"
    >
      We deliver marketing engagements funded by Enterprise Ireland under their innovation and capability instruments. Up to 50% of eligible costs covered, no extra paperwork on your side.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <BtnFiller href="/contact/#contact" variant="solid-white">Talk to us about funding</BtnFiller>
      <BtnFiller href="/work/" variant="on-dark">See selected work</BtnFiller>
    </div>
  </section>

  {programmes.length > 0 ? (
    <section class="mx-auto max-w-[1200px] px-6 md:px-12 pb-24 md:pb-32">
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 list-none p-0 m-0">
        {programmes.map((p) => (
          <li>
            <a
              href={`/programmes/${p.data.slug}/`}
              class="block p-8 transition-transform hover:-translate-y-1"
              style="background:rgba(255,255,255,0.04);border:1px solid rgba(0,255,178,0.18);border-radius:var(--radius-card-md);color:var(--color-text-on-dark);text-decoration:none;height:100%;"
            >
              {p.data.eiInstrument && (
                <p style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-mint);">{p.data.eiInstrument}</p>
              )}
              <h2 class="mt-2" style="font-family:var(--font-display);font-size:clamp(1.5rem, 2.5vw, 2rem);line-height:1.1;letter-spacing:-0.01em;">{p.data.name}</h2>
              <p class="mt-3" style="font-family:var(--font-sans);font-size:1rem;color:var(--color-text-on-dark-muted);line-height:1.55;">{p.data.summary}</p>
              <p class="mt-4" style="font-family:var(--font-sans);font-size:0.875rem;color:var(--color-mint);">Explore →</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : (
    <section class="mx-auto max-w-[800px] px-6 md:px-12 pb-24 md:pb-32">
      <p style="font-family:var(--font-sans);font-size:1.0625rem;color:var(--color-text-on-dark-muted);line-height:1.7;">
        Programme pages are being added. If you're scoping an Enterprise Ireland funded engagement, get in touch, we'll walk you through which instrument fits and what the next step looks like.
      </p>
    </section>
  )}

  <PageCTA variant="programme" />
</Layout>
