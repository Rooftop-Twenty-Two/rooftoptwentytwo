---
import Layout from "../layouts/Layout.astro";

// URL pre-fill: ?sector= / ?programme= / ?service= → hidden routing field + a
// friendly pre-filled subject/message.
const url = Astro.url;
const sectorParam = url.searchParams.get("sector") ?? "";
const programmeParam = url.searchParams.get("programme") ?? "";
const serviceParam = url.searchParams.get("service") ?? "";

const routingValue = [
  sectorParam && `sector:${sectorParam}`,
  programmeParam && `programme:${programmeParam}`,
  serviceParam && `service:${serviceParam}`,
].filter(Boolean).join("|");

function titleCase(s: string) {
  return s.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
}

let prefillSubject = "";
let prefillMessage = "";
if (programmeParam) {
  prefillSubject = `Programme: ${titleCase(programmeParam)}`;
  prefillMessage = `Hi, I'd like to talk about the ${titleCase(programmeParam)} programme${sectorParam ? ` for our ${titleCase(sectorParam)} business` : ""}.\n\n`;
} else if (sectorParam && serviceParam) {
  prefillSubject = `${titleCase(serviceParam)} for ${titleCase(sectorParam)}`;
  prefillMessage = `Hi, we're looking at ${titleCase(serviceParam)} for our ${titleCase(sectorParam)} business and would like to talk.\n\n`;
} else if (sectorParam) {
  prefillSubject = `Marketing for ${titleCase(sectorParam)}`;
  prefillMessage = `Hi, we work in ${titleCase(sectorParam)} and would like to talk about marketing.\n\n`;
} else if (serviceParam) {
  prefillSubject = `${titleCase(serviceParam)} enquiry`;
  prefillMessage = `Hi, we're interested in ${titleCase(serviceParam)}.\n\n`;
}
---

<Layout title="Contact | Rooftop Twenty Two" description="Get in touch with Rooftop Twenty Two, an independent branding and digital design studio in Dublin." hideStickyMobileCTA={true}>
  <section id="contact" class="ct">
    <div class="ct__inner">
      <!-- Left: copy + details -->
      <div class="ct__aside">
        <p class="kicker kicker--on-dark">Get in touch</p>
        <h1 class="ct__title">Let&rsquo;s talk about your <em>growth</em>.</h1>
        <p class="ct__lead">
          Tell us what you&rsquo;re scaling, launching, or rebuilding. We&rsquo;ll come
          back with a thoughtful reply and a time to talk it through.
        </p>

        <div class="ct__details">
          <a href="mailto:hey@rooftoptwentytwo.ie">hey@rooftoptwentytwo.ie</a>
          <a href="tel:+35316991422">+353 1 699 1422</a>
          <address>
            Rooftop Twenty Two, Claremont Avenue,<br />
            Glasnevin, Dublin 11, D11 YNR2
          </address>
        </div>

        <figure class="ct__photo">
          <img src="/images/office/office-studio-01.jpg" alt="The Rooftop Twenty Two studio" loading="lazy" decoding="async" />
        </figure>
      </div>

      <!-- Right: form -->
      <form class="ct__form" action="/api/contact" method="POST" novalidate data-contact-form>
        <input type="hidden" name="routing" value={routingValue} />
        <label class="ct__field">
          <span>Name</span>
          <input type="text" name="name" required placeholder="Your name" />
        </label>
        <label class="ct__field">
          <span>Email</span>
          <input type="email" name="email" required placeholder="you@company.com" />
        </label>
        <label class="ct__field">
          <span>Company</span>
          <input type="text" name="company" placeholder="Company (optional)" />
        </label>
        <label class="ct__field">
          <span>Subject</span>
          <input type="text" name="subject" placeholder="What's this about?" value={prefillSubject} />
        </label>
        <label class="ct__field ct__field--full">
          <span>Message</span>
          <textarea name="message" required rows="6" placeholder="Tell us a little about your project">{prefillMessage}</textarea>
        </label>
        <button type="submit" class="wbtn wbtn--accent ct__submit">Send message</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .ct { background: var(--c-dark); color: var(--c-on-dark); padding-block: clamp(7rem, 13vw, 11rem) var(--w-section-y); }
  .ct__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 920px) { .ct__inner { grid-template-columns: 1fr 1.05fr; gap: 5rem; align-items: start; } }
  .ct__title { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-display); line-height: var(--lh-display); letter-spacing: var(--tracking-display); margin: 1rem 0 0; }
  .ct__title em { font-style: normal; color: var(--c-accent-2); }
  .ct__lead { font-family: var(--w-font-body); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--c-on-dark-soft); margin: 1.5rem 0 0; max-width: 42ch; }
  .ct__details { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 2rem; font-family: var(--w-font-body); }
  .ct__details a { color: var(--c-on-dark); text-decoration: none; font-weight: 600; }
  .ct__details a:hover { color: var(--c-accent); }
  .ct__details address { color: var(--c-on-dark-soft); font-style: normal; line-height: 1.6; margin-top: 0.5rem; }
  .ct__photo { margin: 2.5rem 0 0; border-radius: var(--w-radius); overflow: hidden; aspect-ratio: 16 / 10; }
  .ct__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .ct__form { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .ct__field { display: flex; flex-direction: column; gap: 0.4rem; }
  .ct__field--full { grid-column: 1 / -1; }
  .ct__field span { font-family: var(--w-font-body); font-size: var(--fs-small); color: var(--c-on-dark-soft); }
  .ct__field input, .ct__field textarea {
    width: 100%; padding: 0.9rem 1.1rem; border-radius: 14px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.16);
    color: var(--c-on-dark); font-family: var(--w-font-body); font-size: 1rem; resize: vertical;
  }
  .ct__field input::placeholder, .ct__field textarea::placeholder { color: rgba(255,255,255,0.4); }
  .ct__field input:focus-visible, .ct__field textarea:focus-visible { outline: 2px solid var(--c-accent); outline-offset: 2px; border-color: transparent; }
  .ct__submit { grid-column: 1 / -1; justify-self: start; margin-top: 0.5rem; }
</style>
