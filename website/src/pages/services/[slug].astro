---
import { getCollection } from "astro:content";
import ServicePageTemplate from "../../components/templates/ServicePageTemplate.astro";
import ServiceGeometryTemplate from "../../components/templates/ServiceGeometryTemplate.astro";

export async function getStaticPaths() {
  const entries = await getCollection("services");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { data: entry.data },
  }));
}

const { data } = Astro.props;

// Brand-geometry showcase: proving the new direction on a single page first.
const geometrySlugs = ["seo"];
const useGeometry = geometrySlugs.includes(data.slug);
---

{useGeometry ? <ServiceGeometryTemplate {...data} /> : <ServicePageTemplate {...data} />}
