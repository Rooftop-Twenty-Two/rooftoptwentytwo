---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/reskin/PageHero.astro";
import LogoWall from "../../components/reskin/LogoWall.astro";
import WCtaBand from "../../components/reskin/WCtaBand.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";

const all = (await getCollection("services")).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100)
);

type Cluster = "performance-marketing" | "creative-and-content" | "web";
const clusterMeta: Record<Cluster, { name: string; body: string }> = {
  "performance-marketing": {
    name: "Performance Marketing",
    body: "Google Ads, paid social, SEO, and email, built around the conversions that actually move your business.",
  },
  "creative-and-content": {
    name: "Creative & Content",
    body: "Branding, brand identity, social, photo, and video, produced in-house at the cadence the channels actually need.",
  },
  web: {
    name: "Web",
    body: "Strategy, design, build, and care, modern sites chosen against your buyer journey, not our preference.",
  },
};
const clusters: Cluster[] = ["performance-marketing", "creative-and-content", "web"];
const grouped = clusters.map((cluster) => ({
  cluster,
  meta: clusterMeta[cluster],
  leaves: all.filter((s) => s.data.cluster === cluster && !s.data.isClusterParent),
}));
---

<Layout
  title="Services | Marketing, Web & Creative, Dublin"
  description="Performance marketing, creative & content, and web design under one roof. Full-funnel, in-house, and accountable to commercial outcomes for Irish brands."
>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Services", url: "/services/" }]} />

  <PageHero
    kicker="Our expertise"
    title="Full-funnel marketing, <em>under one roof</em>."
    intro="Three clusters, performance marketing, creative & content, and web. The same in-house team strategises, produces, and ships across all three, so the work stays joined-up across every surface of your brand."
    primary={{ label: "Start a conversation", href: "/contact/#contact" }}
    secondary={{ label: "See selected work", href: "/work/" }}
  />

  {grouped.map(({ cluster, meta, leaves }, i) => (
    <section class:list={["sv", i % 2 === 1 ? "sv--alt" : ""]}>
      <div class="sv__inner">
        <div class="sv__head reveal">
          <span class="sv__num">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h2 class="sv__title"><a href={`/services/${cluster}/`}>{meta.name}</a></h2>
            <p class="sv__body">{meta.body}</p>
          </div>
        </div>
        <ul class="sv__list">
          {leaves.map((s) => (
            <li class="sv__row reveal">
              <a class="sv__name" href={`/services/${s.data.slug}/`}>{s.data.name}</a>
              <p class="sv__sum">{s.data.summary}</p>
              <span class="sv__arrow">Explore &rarr;</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <LogoWall />
  <WCtaBand />
</Layout>

<style>
  .sv { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); }
  .sv--alt { background: var(--c-bg-alt); }
  .sv__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .sv__head { display: flex; gap: 1.5rem; align-items: baseline; }
  .sv__num { font-family: var(--w-font-display); font-weight: 600; color: var(--c-accent); font-size: 1.5rem; }
  .sv__title { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h2); line-height: var(--lh-heading); letter-spacing: var(--tracking-display); margin: 0; }
  .sv__title a { color: inherit; text-decoration: none; }
  .sv__title a:hover { color: var(--c-ink-soft); }
  .sv__body { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); line-height: 1.55; margin: 0.75rem 0 0; max-width: 50ch; }
  .sv__body a:not(.wbtn) { color: var(--c-accent); text-decoration: none; font-weight: 600; white-space: nowrap; }
  .sv__body a:hover { text-decoration: underline; }
  .sv__list { list-style: none; margin: 2.5rem 0 0; padding: 0; border-top: 1px solid var(--c-line); }
  .sv__row {
    display: grid; grid-template-columns: 1fr; gap: 0.25rem; padding: 1.5rem 0;
    border-bottom: 1px solid var(--c-line);
  }
  @media (min-width: 860px) { .sv__row { grid-template-columns: 1fr 1.6fr auto; gap: 1.5rem; align-items: center; } }
  .sv__name { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h3); line-height: 1.1; color: var(--c-ink); text-decoration: none; }
  .sv__name:hover { color: var(--c-ink-soft); }
  .sv__sum { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); line-height: 1.5; margin: 0; }
  .sv__arrow { font-family: var(--w-font-body); font-weight: 600; font-size: 0.9rem; color: var(--c-ink-soft); white-space: nowrap; }
  @media (min-width: 860px) { .sv__arrow { justify-self: end; } }
  .sv__row:hover .sv__arrow { color: var(--c-ink); }
</style>
