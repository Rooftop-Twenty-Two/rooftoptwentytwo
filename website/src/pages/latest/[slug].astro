---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageCTA from "../../components/PageCTA.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import ArticleSchema from "../../components/seo/ArticleSchema.astro";

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, slug, excerpt, metaDescription, author, publishedAt, updatedAt, heroImage } = entry.data;

const pageUrl = `/latest/${slug}/`;
const dateFmt = new Intl.DateTimeFormat("en-IE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={`${title} | Rooftop Twenty Two`} description={metaDescription}>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Latest", url: "/latest/" }, { name: title, url: pageUrl }]} />
  <ArticleSchema
    headline={title}
    description={metaDescription}
    url={pageUrl}
    image={heroImage}
    datePublished={publishedAt}
    dateModified={updatedAt ?? publishedAt}
    authorName={author}
  />

  <article class="mx-auto max-w-[820px] px-6 md:px-12 pt-12 md:pt-20 pb-20 md:pb-28">
    <p style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">
      {dateFmt.format(publishedAt)} · {author}
    </p>
    <h1
      class="mt-3"
      style="font-family:var(--font-display);font-size:clamp(2.5rem, 6vw, 4.5rem);color:var(--color-text-on-dark);line-height:1.05;letter-spacing:-0.02em;"
    >
      {title}
    </h1>
    <p
      class="mt-6 max-w-2xl"
      style="font-family:var(--font-sans);font-size:1.25rem;color:var(--color-text-on-dark-muted);line-height:1.55;"
    >
      {excerpt}
    </p>

    {heroImage && (
      <div class="my-10 overflow-hidden" style="border-radius:var(--radius-card-md);">
        <img src={heroImage} alt={title} class="w-full h-auto" />
      </div>
    )}

    <div class="prose prose-invert mt-10">
      <Content />
    </div>
  </article>

  <PageCTA variant="default" />
</Layout>
