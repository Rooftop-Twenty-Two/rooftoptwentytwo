---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageCTA from "../../components/PageCTA.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ArticleSchema from "../../components/seo/ArticleSchema.astro";

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, slug, excerpt, metaDescription, author, publishedAt, updatedAt, heroImage } = entry.data;

const pageUrl = `/latest/${slug}/`;
const dateFmt = new Intl.DateTimeFormat("en-IE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={`${title} | Rooftop Twenty Two`} description={metaDescription}>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Latest", url: "/latest/" }, { name: title, url: pageUrl }]} />
  <ArticleSchema
    headline={title}
    description={metaDescription}
    url={pageUrl}
    image={heroImage}
    datePublished={publishedAt}
    dateModified={updatedAt ?? publishedAt}
    authorName={author}
  />

  <article class="mx-auto max-w-[820px] px-6 md:px-12 pt-12 md:pt-20 pb-20 md:pb-28">
    <div class="mb-6">
      <Breadcrumbs items={[{ name: "Home", url: "/" }, { name: "Latest", url: "/latest/" }, { name: title, url: pageUrl }]} />
    </div>
    <p style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">
      {dateFmt.format(publishedAt)} · {author}
    </p>
    <h1
      class="mt-3"
      style="font-family:var(--font-display);font-size:clamp(2.5rem, 6vw, 4.5rem);color:var(--color-text-on-dark);line-height:1.05;letter-spacing:-0.02em;"
    >
      {title}
    </h1>
    <p
      class="mt-6 max-w-2xl"
      style="font-family:var(--font-sans);font-size:1.25rem;color:var(--color-text-on-dark-muted);line-height:1.55;"
    >
      {excerpt}
    </p>

    {heroImage && (
      <div class="my-10 overflow-hidden" style="border-radius:var(--radius-card-md);">
        <img src={heroImage} alt={title} class="w-full h-auto" />
      </div>
    )}

    <div class="article-body mt-10">
      <Content />
    </div>
  </article>

  <PageCTA variant="default" />
</Layout>

<style>
  /* Article body styling. The site does not use the Tailwind Typography
     plugin, so content rendered by <Content /> is styled explicitly here,
     mirroring the approach used on the case-study pages. */
  .article-body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text-on-dark-muted);
    max-width: 68ch;
  }
  .article-body :global(p) {
    margin: 0 0 1.25rem;
  }
  .article-body :global(h2) {
    font-family: var(--font-display);
    color: var(--color-text-on-dark);
    font-size: clamp(1.6rem, 3.2vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 2.75rem 0 0.85rem;
  }
  .article-body :global(h3) {
    font-family: var(--font-display);
    color: var(--color-text-on-dark);
    font-size: clamp(1.3rem, 2.2vw, 1.6rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 2rem 0 0.6rem;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.35rem;
  }
  .article-body :global(ul) {
    list-style: disc;
  }
  .article-body :global(ol) {
    list-style: decimal;
  }
  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }
  .article-body :global(li::marker) {
    color: var(--color-coral);
  }
  .article-body :global(strong) {
    color: var(--color-text-on-dark);
    font-weight: 600;
  }
  .article-body :global(a) {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .article-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-card-md);
    margin: 2rem 0;
  }
  .article-body :global(.article-video) { margin: 2.5rem 0; }
  .article-body :global(.article-video video) {
    display: block; width: 100%; max-height: 72vh; margin: 0 auto;
    border-radius: var(--radius-card-md); background: #000;
  }
  .article-body :global(.article-gallery) { display: grid; grid-template-columns: 1fr; gap: 1rem; margin: 2rem 0; }
  @media (min-width: 640px) { .article-body :global(.article-gallery) { grid-template-columns: 1fr 1fr; } }
  .article-body :global(.article-gallery p) { margin: 0; }
  .article-body :global(.article-gallery img) { margin: 0; height: 100%; object-fit: cover; }
  .article-body :global(blockquote) {
    margin: 2rem 0;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-coral);
    color: var(--color-text-on-dark);
    font-style: italic;
  }
  .article-body :global(h2:first-child),
  .article-body :global(h3:first-child),
  .article-body :global(p:first-child) {
    margin-top: 0;
  }
</style>
