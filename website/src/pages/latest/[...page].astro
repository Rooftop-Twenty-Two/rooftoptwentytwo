---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Signature from "../../components/Signature.astro";
import PageCTA from "../../components/PageCTA.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const articles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  );
  return paginate(articles, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<CollectionEntry<"articles">> };

const dateFmt = new Intl.DateTimeFormat("en-IE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

// Page 1 lives at /latest/, subsequent pages at /latest/<n>/.
const pageHref = (n: number) => (n === 1 ? "/latest/" : `/latest/${n}/`);
const pageNumbers = Array.from({ length: page.lastPage }, (_, i) => i + 1);
const canonicalPath = pageHref(page.currentPage);
---

<Layout
  title={page.currentPage > 1
    ? `Latest (page ${page.currentPage}) | Rooftop Twenty Two`
    : "Latest | Rooftop Twenty Two"}
  description="Notes from the studio: thinking on brand, performance marketing, and the work we make for Irish businesses."
>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Latest", url: "/latest/" }]} />

  <section class="mx-auto max-w-[1440px] px-6 md:px-12 pt-12 md:pt-20 pb-12 md:pb-16">
    <Breadcrumbs items={[{ name: "Home", url: "/" }, { name: "Latest", url: "/latest/" }]} />
    <div class="mt-6"><Signature text="Latest" tone="coral" rotate={-3} /></div>
    <h1
      class="mt-4 max-w-3xl"
      style="font-family:var(--font-display);font-size:clamp(2.75rem, 7vw, 5.5rem);color:var(--color-text-on-dark);letter-spacing:-0.02em;line-height:1.05;"
    >
      Notes from the studio.
    </h1>
    <p
      class="mt-6 max-w-2xl"
      style="font-family:var(--font-sans);font-size:1.25rem;color:var(--color-text-on-dark-muted);line-height:1.55;"
    >
      Thinking on brand, performance marketing, and the work we make for Irish businesses.
    </p>
  </section>

  {page.data.length > 0 ? (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 pb-16 md:pb-20">
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-8 list-none p-0 m-0">
        {page.data.map((a) => (
          <li>
            <a
              href={`/latest/${a.data.slug}/`}
              class="block group"
              style="color:var(--color-text-on-dark);text-decoration:none;"
            >
              {a.data.heroImage && (
                <div class="overflow-hidden mb-4" style="border-radius:var(--radius-card-md);aspect-ratio:16/10;background-color:var(--color-navy-700);">
                  <img src={a.data.heroImage} alt={a.data.title} loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
                </div>
              )}
              <p style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">
                {dateFmt.format(a.data.publishedAt)}
              </p>
              <h2 class="mt-2" style="font-family:var(--font-display);font-size:clamp(1.5rem, 2.5vw, 2rem);line-height:1.15;letter-spacing:-0.01em;">{a.data.title}</h2>
              <p class="mt-3" style="font-family:var(--font-sans);font-size:1rem;color:var(--color-text-on-dark-muted);line-height:1.55;">{a.data.excerpt}</p>
            </a>
          </li>
        ))}
      </ul>

      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Pagination">
          <a
            class:list={["pagination__step", { "pagination__step--disabled": !page.url.prev }]}
            href={page.url.prev ?? undefined}
            aria-disabled={page.url.prev ? undefined : "true"}
          >
            ← Prev
          </a>

          <ol class="pagination__pages">
            {pageNumbers.map((n) => (
              <li>
                <a
                  href={pageHref(n)}
                  class:list={["pagination__page", { "pagination__page--active": n === page.currentPage }]}
                  aria-current={n === page.currentPage ? "page" : undefined}
                >
                  {n}
                </a>
              </li>
            ))}
          </ol>

          <a
            class:list={["pagination__step", { "pagination__step--disabled": !page.url.next }]}
            href={page.url.next ?? undefined}
            aria-disabled={page.url.next ? undefined : "true"}
          >
            Next →
          </a>
        </nav>
      )}
    </section>
  ) : (
    <section class="mx-auto max-w-[800px] px-6 md:px-12 pb-24 md:pb-32">
      <p style="font-family:var(--font-sans);font-size:1.0625rem;color:var(--color-text-on-dark-muted);line-height:1.7;">
        New thinking is on the way. In the meantime, the work itself is the best read on how we approach client problems.
      </p>
    </section>
  )}

  <PageCTA variant="default" />
</Layout>

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    font-family: var(--font-sans);
  }
  .pagination__pages {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pagination__page,
  .pagination__step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.85rem;
    border-radius: 9999px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-on-dark);
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.14);
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
  }
  .pagination__page:hover,
  .pagination__step:hover {
    border-color: var(--color-coral);
    color: var(--color-coral);
  }
  .pagination__page--active {
    background-color: var(--color-coral);
    border-color: var(--color-coral);
    color: var(--color-navy-900);
  }
  .pagination__page--active:hover {
    color: var(--color-navy-900);
  }
  .pagination__step--disabled {
    opacity: 0.35;
    pointer-events: none;
  }
</style>
