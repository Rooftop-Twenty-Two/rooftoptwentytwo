---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found | Rooftop Twenty Two">
  <section
    class="px-6 md:px-12 py-16 md:py-24"
    style="background-color:#ffffff;color:var(--color-text-on-light);"
  >
    <div class="mx-auto max-w-[1440px] flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h1
          class="leading-tight"
          style="font-family:var(--font-display);font-size:clamp(2rem, 4vw, 3rem);color:var(--color-text-on-light);letter-spacing:-0.01em;"
        >
          The page can't be found.
        </h1>
        <p class="mt-3" style="font-family:var(--font-sans);font-size:var(--text-body-sm);color:var(--color-text-on-light-muted);">
          It looks like nothing was found at this location.
        </p>
      </div>
      <a href="/contact/" class="btn-pill btn-pill--coral">Let's Chat</a>
    </div>
  </section>
</Layout>
