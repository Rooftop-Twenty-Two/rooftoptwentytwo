---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | Rooftop Twenty Two" description="Sorry, we couldn't find that page. Explore our work, services, and insights, or get in touch with Rooftop Twenty Two in Dublin.">
  <section
    class="px-6 md:px-12 py-16 md:py-24"
    style="background-color:#ffffff;color:var(--c-ink);"
  >
    <div class="mx-auto max-w-[1440px] flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h1
          class="leading-tight"
          style="font-family:var(--font-display);font-size:clamp(2rem, 4vw, 3rem);color:var(--c-ink);letter-spacing:-0.01em;"
        >
          The page can't be found.
        </h1>
        <p class="mt-3" style="font-family:var(--font-sans);font-size:var(--text-body-sm);color:var(--c-ink-soft);">
          It looks like nothing was found at this location.
        </p>
      </div>
      <a href="/contact/" class="wbtn wbtn--accent">Let&rsquo;s chat</a>
    </div>
  </section>
</Layout>
