<!doctype html>
<html lang="en" class="pr-html">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Rooftop Twenty Two — Pitch</title>
    <link rel="preload" href="/fonts/butler-bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/mulish-variable.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="pr-body">
    <div class="pr-gate" id="pr-gate">
      <form class="pr-gate__card" id="pr-form" autocomplete="off">
        <p class="pr-gate__brand">Rooftop Twenty Two</p>
        <h1 class="pr-gate__title">Pitch deck</h1>
        <p class="pr-gate__sub">Enter the password to view.</p>
        <input class="pr-gate__input" id="pr-input" type="password" placeholder="Password" aria-label="Password" autofocus />
        <button class="pr-gate__btn" type="submit">View pitch</button>
        <p class="pr-gate__err" id="pr-err" hidden>That password isn't right. Try again.</p>
      </form>
    </div>

    <header class="pr-top" id="pr-top" hidden>
      <div class="pr-top__brand">Rooftop Twenty Two</div>
      <button class="pr-top__pdf" id="pr-pdf" type="button">Download PDF</button>
    </header>

    <main class="pr-main" id="pr-main"></main>

    <div class="pr-progress" id="pr-progress" hidden><span id="pr-progress-bar"></span></div>

    <!-- Case study modal -->
    <div class="cs-modal" id="cs-modal" hidden>
      <div class="cs-modal__backdrop" data-cs-close></div>
      <div class="cs-modal__panel" role="dialog" aria-modal="true" aria-label="Case study">
        <button class="cs-modal__close" data-cs-close aria-label="Close">&times;</button>
        <div class="cs-modal__body" id="cs-modal-body"></div>
      </div>
    </div>

    <script type="application/json" id="pr-data" set:html={payload}></script>

    <script>
      const dataEl = document.getElementById("pr-data");
      const payload = JSON.parse(dataEl?.textContent || "{}");
      const gate = document.getElementById("pr-gate");
      const form = document.getElementById("pr-form") as HTMLFormElement | null;
      const input = document.getElementById("pr-input") as HTMLInputElement | null;
      const err = document.getElementById("pr-err");
      const main = document.getElementById("pr-main");
      const top = document.getElementById("pr-top");
      const progress = document.getElementById("pr-progress");
      const bar = document.getElementById("pr-progress-bar");
      const modal = document.getElementById("cs-modal");
      const modalBody = document.getElementById("cs-modal-body");
      const KEY = "rt22-deck-pharmacy";
      const b64 = (s: string) => { const bin = atob(s); const u = new Uint8Array(bin.length); for (let i = 0; i < bin.length; i++) u[i] = bin.charCodeAt(i); return u; };

      async function decrypt(pw: string) {
        const base = await crypto.subtle.importKey("raw", new TextEncoder().encode(pw), "PBKDF2", false, ["deriveKey"]);
        const key = await crypto.subtle.deriveKey({ name: "PBKDF2", salt: b64(payload.s), iterations: 150000, hash: "SHA-256" }, base, { name: "AES-GCM", length: 256 }, false, ["decrypt"]);
        const buf = await crypto.subtle.decrypt({ name: "AES-GCM", iv: b64(payload.i) }, key, b64(payload.c));
        return new TextDecoder().decode(buf);
      }
      function onScroll() { if (!bar) return; const h = document.documentElement.scrollHeight - window.innerHeight; bar.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + "%"; }

      function initMarquees() {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const canHover = window.matchMedia("(hover: hover)").matches;
        document.querySelectorAll<HTMLElement>("[data-marquee]").forEach((vp) => {
          const track = vp.firstElementChild as HTMLElement | null; if (!track) return;
          const dur = parseFloat(vp.getAttribute("data-marquee") || "120") || 120;
          let half = track.scrollWidth / 2, paused = false, last = 0;
          const measure = () => { half = track.scrollWidth / 2; };
          measure(); vp.scrollLeft = half;
          window.addEventListener("resize", measure, { passive: true });
          if (document.fonts && document.fonts.ready) document.fonts.ready.then(measure);
          if (canHover) { vp.addEventListener("mouseenter", () => { paused = true; }); vp.addEventListener("mouseleave", () => { paused = false; }); }
          if (reduce) return;
          const tick = (ts: number) => { if (!last) last = ts; const dt = ts - last; last = ts; if (!paused && half > 0) { vp.scrollLeft -= (half / (dur * 1000)) * dt; if (vp.scrollLeft <= 0) vp.scrollLeft += half; } requestAnimationFrame(tick); };
          requestAnimationFrame(tick);
        });
      }

      function openCase(i: string | null) {
        const full = document.querySelector<HTMLElement>('.cs-full[data-cs="' + i + '"]');
        if (!full || !modal || !modalBody) return;
        modalBody.innerHTML = full.innerHTML;
        modal.removeAttribute("hidden");
        document.body.style.overflow = "hidden";
      }
      function closeCase() { modal?.setAttribute("hidden", ""); document.body.style.overflow = ""; }
      function initCases() {
        main?.querySelectorAll<HTMLElement>(".cs-card").forEach((c) => c.addEventListener("click", () => openCase(c.getAttribute("data-cs"))));
        modal?.querySelectorAll<HTMLElement>("[data-cs-close]").forEach((e) => e.addEventListener("click", closeCase));
      }
      window.addEventListener("keydown", (e) => { if (e.key === "Escape") closeCase(); });

      async function unlock(pw: string, fromSession = false) {
        try {
          const html = await decrypt(pw);
          if (main) main.innerHTML = html;
          gate?.remove();
          document.body.classList.add("is-unlocked");
          top?.removeAttribute("hidden");
          progress?.removeAttribute("hidden");
          sessionStorage.setItem(KEY, pw);
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll(); initMarquees(); initCases();
        } catch { if (!fromSession) { err?.removeAttribute("hidden"); input?.focus(); input?.select(); } }
      }
      form?.addEventListener("submit", (e) => { e.preventDefault(); err?.setAttribute("hidden", ""); unlock(input?.value || ""); });
