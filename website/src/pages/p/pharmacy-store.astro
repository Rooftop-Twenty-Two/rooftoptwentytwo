---
// ────────────────────────────────────────────────────────────────────────────
// Bespoke proposal deck — Pharmacy Store (website + booking platform).
// Prepared for Ciaran McNally and Tracey Dunne. Standalone 16:9 presentation,
// no site chrome. Slide CONTENT is AES-256-GCM encrypted at build time and only
// decrypts in the browser once the correct password is entered, so the page
// source ships ciphertext, not the pitch.
//
// Change the password below (PASSWORD) and rebuild to rotate it.
// noindex + excluded from the sitemap (see astro.config sitemap filter).
// ────────────────────────────────────────────────────────────────────────────
import "../../styles/globals.css";
import crypto from "node:crypto";

const PASSWORD = "rooftop-pharmacy"; // ← change me and rebuild to rotate access

// ---- Slide authoring helpers ----------------------------------------------
const eyebrow = (t: string) => `<p class="eyebrow">${t}</p>`;
const bullets = (items: string[]) =>
  `<ul class="blist">${items.map((i) => `<li><span class="bdot"></span><span>${i}</span></li>`).join("")}</ul>`;
const slide = (inner: string, cls = "") => `<section class="slide${cls ? " " + cls : ""}">${inner}</section>`;

const slides: string[] = [
  // 1 — Cover
  slide(
    `<div class="cover">
       ${eyebrow("Website proposal · June 2026")}
       <h1>A website built<br/>around booking.</h1>
       <p class="lead">A pharmacy group website and booking platform, prepared for Ciaran McNally and Tracey Dunne.</p>
       <p class="cover__by">Rooftop Twenty Two · Web design and digital marketing<br/>Glasnevin and the Beacon, Dublin</p>
     </div>`,
    "slide--cover"
  ),

  // 2 — Introduction
  slide(
    `${eyebrow("Introduction")}
     <h2>You've done the hard part with Tap.</h2>
     <p class="lead">The brand is fresh, the shops are being revamped, and the new photography is in place. The website is the last piece still looking five years old. That's where we come in.</p>
     <p class="lead lead--soft">Moving off e-commerce to a service and information site is exactly the kind of build where trust and clear booking matter more than selling a product off a shelf. It's the same thinking we apply for our consultant clients every week.</p>`
  ),

  // 3 — About us
  slide(
    `${eyebrow("About us")}
     <h2>A Dublin web and marketing team of 14.</h2>
     ${bullets([
       "Two offices, Glasnevin and the Beacon, with in-house web design, development, SEO, paid social, video and content.",
       "We produce 20 to 30 websites a year and move quickly without dropping quality.",
       "We work closely with brand studios like Tap, carrying their brand work through into a clean, consistent live site.",
     ])}`
  ),

  // 4 — Awards
  slide(
    `${eyebrow("Recognised work")}
     <h2>Award-winning web and search.</h2>
     ${bullets([
       "Gold winners at the Spider Awards for our web design work.",
       "Finalists at the European Search Awards 2026, with two of our team at the ceremony in Porto.",
       "A consistent record of award-winning sites across the medical, retail and charity sectors.",
     ])}
     <p class="lead lead--soft">Studios bring us in for the extra polish, backed by real development skill. We make it look right and make it work.</p>`
  ),

  // 5 — Initial thoughts
  slide(
    `${eyebrow("Our early read")}
     <h2>What the new site should do.</h2>
     ${bullets([
       "Move from shop to service. The site becomes a tool that works 24/7.",
       "Put services and booking front and centre, from vaccinations to health checks.",
       "Position the group as a community health hub, not a product shelf.",
       "Give each of the five pharmacies its own page, with hours that load instantly.",
       "Strip the dated, Covid-era content and run the Tap brand throughout.",
       "Build SEO in from day one, local to each service and location.",
       "Tell the automation and robotics story as a point of difference.",
     ])}`
  ),

  // 6 — Sitemap
  slide(
    `${eyebrow("A first-draft structure")}
     <h2>Potential sitemap.</h2>
     <div class="smap">
       <div class="smap__col">
         <h4>Home</h4>
         <h4>About</h4>
         <ul><li>Our story and the brand</li><li>Team and pharmacists</li><li>Innovation and automation</li></ul>
       </div>
       <div class="smap__col">
         <h4>Services</h4>
         <ul><li>Vaccinations</li><li>Health checks and screening</li><li>Weight management</li><li>Minor ailments</li><li>Smoking cessation</li><li>Prescriptions and repeats</li></ul>
       </div>
       <div class="smap__col">
         <h4>Our pharmacies</h4>
         <ul><li>A page per location</li><li>Hours, address, services</li><li>Photos and map</li></ul>
         <h4>Book an appointment</h4>
       </div>
       <div class="smap__col">
         <h4>Health advice and news</h4>
         <h4>Contact</h4>
         <h4>Careers</h4>
       </div>
     </div>
     <p class="note">For discussion. We'll confirm the final structure together.</p>`
  ),

  // 7 — Creative ideas
  slide(
    `${eyebrow("Creative ideas")}
     <h2>How the site comes to life.</h2>
     ${bullets([
       "Real photography front and centre, the Tap shots of your shops and teams. No stock.",
       "A book action that follows you through the site, always one tap away.",
       "A location finder, so visitors reach their nearest pharmacy fast.",
       "An innovation section that tells the robotics story in plain terms.",
       "Pharmacist profiles and trust signals, so people know the team before they walk in.",
       "A clean, modern look, designed mobile first, because most pharmacy searches happen on a phone.",
     ])}`
  ),

  // 8 — Robotics
  slide(
    `${eyebrow("A point of difference")}
     <h2>The robotics and automation angle.</h2>
     <p class="lead">Robotic dispensing pushes accuracy close to 100% and handles a large share of daily prescriptions in seconds, freeing your team to spend more time with patients.</p>
     <p class="lead lead--soft">Boots Ireland and others already frame it this way. Giving it a home on the site positions the group as forward-looking and justifies a premium feel across the brand. No other independent group locally will have this.</p>`
  ),

  // 9 — Booking comparison
  slide(
    `${eyebrow("Booking is the heart of it")}
     <h2>Off the shelf vs bespoke.</h2>
     <div class="cmp">
       <div class="cmp__h"></div><div class="cmp__h">Off the shelf</div><div class="cmp__h">Bespoke</div>
       <div class="cmp__l">What it is</div><div>A proven tool (Acuity, Bookly) styled to your brand.</div><div>Built around your services and five locations.</div>
       <div class="cmp__l">Speed and cost</div><div>Faster, lower cost. A monthly fee per location.</div><div>Higher upfront, no recurring third-party fee.</div>
       <div class="cmp__l">Look and feel</div><div>Styled to brand, sits slightly apart.</div><div>Matches the site exactly, one experience.</div>
       <div class="cmp__l">Flexibility</div><div>Great for standard booking.</div><div>Built around exactly how you work.</div>
       <div class="cmp__l">Maintenance</div><div>By the provider.</div><div>Owned by you, with our support.</div>
     </div>`
  ),

  // 10 — Recommendation
  slide(
    `${eyebrow("Our recommendation")}
     <h2>Start off the shelf. Grow into bespoke.</h2>
     <p class="lead">For launch, a strong off-the-shelf engine styled to your brand gets you live faster and covers vaccines and standard appointments well.</p>
     <p class="lead lead--soft">If your service range and automation plans grow, we move to a bespoke build later. We'll scope both at the workshop, so you decide with full sight of the costs.</p>`
  ),

  // 11 — Integrations
  slide(
    `${eyebrow("Beyond booking")}
     <h2>What the site connects to.</h2>
     <div class="igrid">
       <div class="icard"><span class="tag tag--core">Core</span><h4>Google Business Profile</h4><p>Locations, hours and reviews, visible in search and maps.</p></div>
       <div class="icard"><span class="tag tag--core">Core</span><h4>Online reviews</h4><p>Your Google reviews, pulled onto the site.</p></div>
       <div class="icard"><span class="tag tag--core">Core</span><h4>Maps and location finder</h4><p>Route people to their nearest pharmacy.</p></div>
       <div class="icard"><span class="tag tag--core">Core</span><h4>Analytics and tracking</h4><p>GA4 and booking conversions, so we improve over time.</p></div>
       <div class="icard"><span class="tag tag--core">Core</span><h4>Social media</h4><p>Feeds and links across your channels.</p></div>
       <div class="icard"><span class="tag tag--addon">Add-on</span><h4>Pharmacy management system</h4><p>Repeat prescription requests into your records.</p></div>
       <div class="icard"><span class="tag tag--addon">Add-on</span><h4>Email marketing</h4><p>Newsletter sign-up and campaigns.</p></div>
       <div class="icard"><span class="tag tag--addon">Add-on</span><h4>Online payments</h4><p>Only if you take payment at booking.</p></div>
     </div>`
  ),

  // 12 — Healthcare proof
  slide(
    `${eyebrow("Why us, for healthcare")}
     <h2>Trust is what we build.</h2>
     <blockquote class="quote">"It's a pleasure to work with such a creative, innovative and supportive team, from rebuilding our website to producing video that captures what we do."<cite>Fiona Monahan, Bloomfield Health Services</cite></blockquote>
     <p class="lead lead--soft">We work with consultants, clinics and care organisations across Ireland. A service and information site lives or dies on trust and clear booking, and that's exactly what we do every week.</p>`
  ),

  // 13 — Next steps
  slide(
    `${eyebrow("Next steps")}
     <h2>How we move this forward.</h2>
     ${bullets([
       "We send you live links and examples across medical, retail and innovation.",
       "We confirm a few details, then put indicative costs together, core build and options set out clearly.",
       "Once costs are agreed, we bring everyone together for the workshop to lock the detail and final sitemap.",
       "We get to work. A typical build runs 8 to 10 weeks from the workshop, finished on time.",
     ])}`
  ),

  // 14 — Close
  slide(
    `<div class="cover">
       ${eyebrow("Talk soon")}
       <h2>We'd be delighted to build this with you.</h2>
       <p class="lead">We think it's a strong fit.</p>
       <p class="contact"><a href="mailto:hey@rooftoptwentytwo.ie">hey@rooftoptwentytwo.ie</a> · +353 1 699 1422 · rooftoptwentytwo.ie</p>
       <p class="cover__by">Cathal O'Reilly<br/>Founder and Managing Director, Rooftop Twenty Two</p>
     </div>`,
    "slide--cover"
  ),
];

// ---- Encrypt the assembled slides (AES-256-GCM via PBKDF2-derived key) -------
const slidesHtml = slides.join("");
const salt = crypto.randomBytes(16);
const iv = crypto.randomBytes(12);
const key = crypto.pbkdf2Sync(PASSWORD, salt, 150000, 32, "sha256");
const cipher = crypto.createCipheriv("aes-256-gcm", key, iv);
const ciphertext = Buffer.concat([cipher.update(slidesHtml, "utf8"), cipher.final()]);
const tag = cipher.getAuthTag();
// Browser SubtleCrypto expects the auth tag appended to the ciphertext.
const payload = JSON.stringify({
  s: salt.toString("base64"),
  i: iv.toString("base64"),
  c: Buffer.concat([ciphertext, tag]).toString("base64"),
});
const slideCount = slides.length;
---

<!doctype html>
<html lang="en" class="deck-html">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Proposal — Pharmacy Store</title>
    <link rel="preload" href="/fonts/butler-bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/mulish-variable.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="deck-body">
    <!-- Password gate -->
    <div class="deck-gate" id="deck-gate">
      <form class="gate__card" id="gate-form" autocomplete="off">
        <p class="gate__brand">Rooftop Twenty Two</p>
        <h1 class="gate__title">Website proposal</h1>
        <p class="gate__sub">Enter the password to view the deck.</p>
        <input class="gate__input" id="gate-input" type="password" placeholder="Password" aria-label="Password" autofocus />
        <button class="gate__btn" type="submit">View proposal</button>
        <p class="gate__error" id="gate-error" hidden>That password isn't right. Try again.</p>
      </form>
    </div>

    <!-- Deck -->
    <div class="deck-viewport" id="deck-viewport">
      <div class="deck-stage" id="deck-stage" aria-live="polite"></div>
    </div>

    <!-- Controls -->
    <div class="deck-nav" id="deck-nav" hidden>
      <button class="nbtn" id="nav-prev" aria-label="Previous slide">&larr;</button>
      <span class="ncount"><span id="nav-cur">1</span> / <span id="nav-total">{slideCount}</span></span>
      <button class="nbtn" id="nav-next" aria-label="Next slide">&rarr;</button>
      <button class="nbtn nbtn--text" id="nav-print" aria-label="Download as PDF">PDF</button>
      <button class="nbtn nbtn--text" id="nav-full" aria-label="Toggle fullscreen">Full</button>
    </div>

    <div class="deck-progress" id="deck-progress" hidden><span id="deck-progress-bar"></span></div>

    <script type="application/json" id="deck-data" set:html={payload}></script>

    <script>
      const dataEl = document.getElementById("deck-data");
      const payload = JSON.parse(dataEl?.textContent || "{}");
      const gate = document.getElementById("deck-gate");
      const form = document.getElementById("gate-form") as HTMLFormElement | null;
      const input = document.getElementById("gate-input") as HTMLInputElement | null;
      const errEl = document.getElementById("gate-error");
      const stage = document.getElementById("deck-stage");
      const nav = document.getElementById("deck-nav");
      const progress = document.getElementById("deck-progress");
      const bar = document.getElementById("deck-progress-bar");
      const SESSION_KEY = "rt22-deck-pharmacy";

      const b64ToBytes = (s: string) => {
        const bin = atob(s);
        const u = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) u[i] = bin.charCodeAt(i);
        return u;
      };

      async function decrypt(pw: string): Promise<string> {
        const enc = new TextEncoder();
        const baseKey = await crypto.subtle.importKey("raw", enc.encode(pw), "PBKDF2", false, ["deriveKey"]);
        const key = await crypto.subtle.deriveKey(
          { name: "PBKDF2", salt: b64ToBytes(payload.s), iterations: 150000, hash: "SHA-256" },
          baseKey,
          { name: "AES-GCM", length: 256 },
          false,
          ["decrypt"]
        );
        const buf = await crypto.subtle.decrypt({ name: "AES-GCM", iv: b64ToBytes(payload.i) }, key, b64ToBytes(payload.c));
        return new TextDecoder().decode(buf);
      }

      let slides: HTMLElement[] = [];
      let idx = 0;

      function show(n: number) {
        idx = Math.max(0, Math.min(slides.length - 1, n));
        slides.forEach((s, i) => s.classList.toggle("is-current", i === idx));
        const cur = document.getElementById("nav-cur");
        if (cur) cur.textContent = String(idx + 1);
        if (bar) bar.style.width = ((idx + 1) / slides.length) * 100 + "%";
      }
      const next = () => show(idx + 1);
      const prev = () => show(idx - 1);

      function initDeck() {
        slides = Array.from(stage?.querySelectorAll<HTMLElement>(".slide") || []);
        if (!slides.length) return;
        nav?.removeAttribute("hidden");
        progress?.removeAttribute("hidden");
        show(0);
        document.getElementById("nav-next")?.addEventListener("click", next);
        document.getElementById("nav-prev")?.addEventListener("click", prev);
        document.getElementById("nav-print")?.addEventListener("click", () => window.print());
        document.getElementById("nav-full")?.addEventListener("click", toggleFull);
        window.addEventListener("keydown", (e) => {
          if (e.key === "ArrowRight" || e.key === "PageDown" || e.key === " ") { e.preventDefault(); next(); }
          else if (e.key === "ArrowLeft" || e.key === "PageUp") { e.preventDefault(); prev(); }
          else if (e.key.toLowerCase() === "f") toggleFull();
        });
        // Swipe on touch devices.
        let x0 = 0;
        stage?.addEventListener("touchstart", (e) => { x0 = e.touches[0].clientX; }, { passive: true });
        stage?.addEventListener("touchend", (e) => {
          const dx = e.changedTouches[0].clientX - x0;
          if (Math.abs(dx) > 45) (dx < 0 ? next : prev)();
        }, { passive: true });
      }

      function toggleFull() {
        const el = document.getElementById("deck-viewport");
        if (!document.fullscreenElement) el?.requestFullscreen?.();
        else document.exitFullscreen?.();
      }

      async function unlock(pw: string, fromSession = false) {
        try {
          const html = await decrypt(pw);
          if (stage) stage.innerHTML = html;
          gate?.remove();
          document.body.classList.add("is-unlocked");
          sessionStorage.setItem(SESSION_KEY, pw);
          initDeck();
        } catch {
          if (!fromSession) {
            errEl?.removeAttribute("hidden");
            input?.focus();
            input?.select();
          }
        }
      }

      form?.addEventListener("submit", (e) => {
        e.preventDefault();
        errEl?.setAttribute("hidden", "");
        unlock(input?.value || "");
      });

      const saved = sessionStorage.getItem(SESSION_KEY);
      if (saved) unlock(saved, true);
    </script>

    <style is:global>
      :root { --deck-bg: #061018; }
      .deck-html, .deck-body { height: 100%; }
      .deck-body {
        margin: 0; background: var(--deck-bg); color: var(--c-on-dark);
        font-family: var(--w-font-body); overflow: hidden;
      }

      /* ---- Gate ---- */
      .deck-gate {
        position: fixed; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center;
        padding: 1.5rem; background:
          radial-gradient(120% 90% at 80% 0%, rgba(225,80,71,0.16), transparent 55%),
          radial-gradient(120% 90% at 0% 100%, rgba(1,255,178,0.12), transparent 55%),
          var(--deck-bg);
      }
      .gate__card {
        width: min(440px, 100%); text-align: left; background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 2.25rem;
        backdrop-filter: blur(6px); display: flex; flex-direction: column; gap: 0.4rem;
      }
      .gate__brand { font-family: var(--w-font-body); font-weight: 700; font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--c-accent-2); margin: 0 0 0.75rem; }
      .gate__title { font-family: var(--w-font-display); font-weight: 600; font-size: 1.7rem; line-height: 1.1; margin: 0; color: #fff; }
      .gate__sub { font-size: 0.95rem; color: var(--c-on-dark-soft); margin: 0.4rem 0 1.25rem; }
      .gate__input {
        width: 100%; box-sizing: border-box; padding: 0.85rem 1.1rem; border-radius: 12px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.18);
        color: #fff; font-family: var(--w-font-body); font-size: 1rem;
      }
      .gate__input:focus-visible { outline: 2px solid var(--c-accent-2); outline-offset: 2px; }
      .gate__btn {
        margin-top: 0.75rem; padding: 0.85rem 1.1rem; border: 0; border-radius: 9999px; cursor: pointer;
        background: var(--c-accent); color: #fff; font-family: var(--w-font-body); font-weight: 700; font-size: 0.95rem;
        transition: transform 0.16s ease, filter 0.16s ease;
      }
      .gate__btn:hover { transform: translateY(-1px); filter: brightness(1.05); }
      .gate__error { color: #ffb3ad; font-size: 0.85rem; margin: 0.75rem 0 0; }

      /* ---- Stage / slides ---- */
      .deck-viewport {
        min-height: 100vh; display: flex; align-items: center; justify-content: center;
        padding: clamp(0.5rem, 2vh, 1.5rem); padding-bottom: 64px; box-sizing: border-box; background: var(--deck-bg);
      }
      .deck-stage {
        position: relative; width: min(100%, calc((100vh - 88px) * 16 / 9)); aspect-ratio: 16 / 9;
        background: var(--c-dark); border-radius: 8px; overflow: hidden;
        box-shadow: 0 30px 80px rgba(0,0,0,0.55);
      }
      .slide {
        position: absolute; inset: 0; container-type: size;
        display: flex; flex-direction: column; justify-content: center;
        padding: 7cqw 8cqw; box-sizing: border-box;
        opacity: 0; visibility: hidden; transform: translateY(1.2cqh);
        transition: opacity 0.45s ease, transform 0.45s ease;
        background:
          radial-gradient(80% 120% at 100% 0%, rgba(225,80,71,0.10), transparent 50%),
          radial-gradient(70% 120% at 0% 100%, rgba(1,255,178,0.07), transparent 50%);
      }
      .slide.is-current { opacity: 1; visibility: visible; transform: none; }

      .eyebrow { font-family: var(--w-font-body); font-weight: 700; font-size: 1.6cqw; letter-spacing: 0.26em; text-transform: uppercase; color: var(--c-accent-2); margin: 0 0 2.2cqh; }
      .slide h2 { font-family: var(--w-font-display); font-weight: 600; font-size: 5.3cqw; line-height: 1.05; letter-spacing: -0.02em; color: #fff; margin: 0; }
      .slide h3 { font-family: var(--w-font-display); font-weight: 600; font-size: 2.5cqw; line-height: 1.1; color: #fff; margin: 0.4cqh 0 0.6cqh; }
      .lead { font-family: var(--w-font-body); font-size: 2.25cqw; line-height: 1.5; color: var(--c-on-dark-soft); max-width: 64cqw; margin: 3.5cqh 0 0; }
      .lead--soft { color: rgba(194,221,219,0.72); font-size: 1.95cqw; margin-top: 2.4cqh; }

      .blist { list-style: none; margin: 4cqh 0 0; padding: 0; display: flex; flex-direction: column; gap: 2.1cqh; max-width: 82cqw; }
      .blist li { display: flex; gap: 2cqw; align-items: flex-start; font-size: 2.05cqw; line-height: 1.38; color: #eaf3f2; }
      .bdot { flex: 0 0 auto; width: 1cqw; height: 1cqw; margin-top: 1cqw; border-radius: 50%; background: var(--c-accent); }

      /* Cover */
      .slide--cover { background: radial-gradient(110% 130% at 85% 10%, rgba(225,80,71,0.18), transparent 55%), radial-gradient(90% 120% at 0% 100%, rgba(1,255,178,0.12), transparent 55%), var(--c-dark); }
      .cover h1 { font-family: var(--w-font-display); font-weight: 600; font-size: 8cqw; line-height: 1.0; letter-spacing: -0.025em; color: #fff; margin: 0; }
      .cover__by { font-size: 1.85cqw; line-height: 1.5; color: var(--c-on-dark-soft); margin: 5.5cqh 0 0; }
      .contact { font-size: 2cqw; color: #fff; margin: 3.5cqh 0 0; }
      .contact a { color: var(--c-accent-2); text-decoration: none; }

      /* Sitemap */
      .smap { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2.4cqw; margin-top: 4cqh; max-width: 88cqw; }
      .smap__col h4 { font-family: var(--w-font-display); font-weight: 600; font-size: 2cqw; color: #fff; margin: 0 0 0.6cqh; }
      .smap__col h4 ~ h4 { margin-top: 2.2cqh; }
      .smap__col ul { list-style: none; margin: 0; padding: 0; }
      .smap__col li { font-size: 1.5cqw; line-height: 1.55; color: var(--c-on-dark-soft); }

      /* Comparison table */
      .cmp { display: grid; grid-template-columns: 1.05fr 1.55fr 1.55fr; margin-top: 3.5cqh; max-width: 92cqw; border: 1px solid rgba(255,255,255,0.12); border-radius: 1.4cqw; overflow: hidden; }
      .cmp > div { padding: 1.5cqh 1.5cqw; font-size: 1.5cqw; line-height: 1.32; color: #eaf3f2; border-top: 1px solid rgba(255,255,255,0.08); }
      .cmp > div:nth-child(-n+3) { border-top: 0; }
      .cmp__h { font-family: var(--w-font-display); font-weight: 600; font-size: 1.85cqw; color: #fff; background: rgba(255,255,255,0.07); }
      .cmp__l { font-weight: 700; color: var(--c-accent-2); background: rgba(255,255,255,0.03); }

      /* Integrations grid */
      .igrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.8cqw 1.8cqw; margin-top: 3.5cqh; max-width: 92cqw; }
      .icard { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 1.4cqw; padding: 2cqh 1.6cqw; }
      .icard h4 { font-family: var(--w-font-display); font-weight: 600; font-size: 1.65cqw; color: #fff; margin: 1cqh 0 0.5cqh; line-height: 1.1; }
      .icard p { font-size: 1.3cqw; line-height: 1.35; color: var(--c-on-dark-soft); margin: 0; }
      .tag { display: inline-block; font-size: 1.05cqw; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.35cqh 1cqw; border-radius: 9999px; }
      .tag--core { background: rgba(1,255,178,0.16); color: var(--c-accent-2); }
      .tag--addon { background: rgba(225,80,71,0.2); color: #ff9b93; }

      /* Quote */
      .quote { margin: 3.5cqh 0 0; font-family: var(--w-font-display); font-style: italic; font-size: 2.9cqw; line-height: 1.32; color: #fff; max-width: 84cqw; border: 0; padding: 0; }
      .quote cite { display: block; font-family: var(--w-font-body); font-style: normal; font-size: 1.65cqw; color: var(--c-accent-2); margin-top: 2.2cqh; }

      .note { font-size: 1.55cqw; color: rgba(194,221,219,0.65); margin: 3.5cqh 0 0; }

      /* ---- Nav ---- */
      .deck-nav {
        position: fixed; left: 0; right: 0; bottom: 0; height: 56px; z-index: 40;
        display: flex; align-items: center; justify-content: center; gap: 0.9rem;
        background: rgba(6,16,24,0.82); backdrop-filter: blur(10px); border-top: 1px solid rgba(255,255,255,0.08);
      }
      .nbtn {
        min-width: 40px; height: 36px; padding: 0 0.7rem; border-radius: 9999px; cursor: pointer;
        background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14); color: #fff;
        font-family: var(--w-font-body); font-size: 1rem; line-height: 1; transition: background 0.16s ease;
      }
      .nbtn:hover { background: rgba(255,255,255,0.18); }
      .nbtn--text { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.04em; }
      .ncount { font-family: var(--w-font-body); font-size: 0.85rem; color: var(--c-on-dark-soft); min-width: 56px; text-align: center; }

      .deck-progress { position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 41; background: rgba(255,255,255,0.08); }
      .deck-progress span { display: block; height: 100%; width: 0; background: var(--c-accent); transition: width 0.4s ease; }

      @media (prefers-reduced-motion: reduce) {
        .slide { transition: opacity 0.2s linear; transform: none; }
      }

      /* ---- Print → PDF: one landscape page per slide ---- */
      @media print {
        @page { size: 1280px 720px; margin: 0; }
        .deck-body { overflow: visible; background: #fff; }
        .deck-gate, .deck-nav, .deck-progress { display: none !important; }
        .deck-viewport { display: block; min-height: 0; padding: 0; }
        .deck-stage { display: contents; box-shadow: none; }
        .slide {
          position: relative; inset: auto; width: 1280px; height: 720px;
          opacity: 1 !important; visibility: visible !important; transform: none !important;
          break-after: page; page-break-after: always;
        }
      }
    </style>
  </body>
</html>
