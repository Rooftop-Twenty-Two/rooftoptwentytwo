      /* ---- Wireframe mockup ---- */
      .sp-media--pad { display: flex; align-items: center; justify-content: center; padding: 5cqw; background: #0a1a26; }
      .wf { width: 100%; background: #fff; border-radius: 1.2cqw; padding: 2cqw; box-shadow: 0 12px 32px rgba(0,0,0,0.35); display: flex; flex-direction: column; gap: 1.8cqh; }
