// ────────────────────────────────────────────────────────────────────────────
// Rooftop Twenty Two — pitch deck FOR PHARMACY STORE (website + booking).
// Prepared for Ciaran McNally & Tracey Dunne. R22 is the primary brand;
// PharmacyStore appears as a co-brand lockup and inside the homepage mockup.
// Long-form scrolling page, same palette as the homepage, with office imagery.
//
// CONTENT is AES-256-GCM encrypted; decrypts in-browser on the password.
// Change PASSWORD and rebuild to rotate. noindex + excluded from sitemap.
// ────────────────────────────────────────────────────────────────────────────
import "../../styles/globals.css";
import { getCollection } from "astro:content";
import { existsSync } from "node:fs";
import path from "node:path";
import crypto from "node:crypto";

const PASSWORD = "rooftop-pharmacy"; // ← change me and rebuild to rotate access
const has = (p: string) => existsSync(path.join(process.cwd(), "public", p));

const team = (await getCollection("team"))
  .filter((m) => has(m.data.portrait))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100))
  .map((m) => ({ name: m.data.name, role: m.data.role, portrait: m.data.portrait }));
const leaders = ["Cathal", "Roisin", "Justin", "Padraic"].map((n) => team.find((t) => t.name === n)).filter(Boolean) as typeof team;

const portfolio = await getCollection("portfolio");
const namedCases = [
  { name: "Jonathan Lyon", tag: "Consultant Cardiologist", body: "A clinical website for a heart rhythm specialist. We built clear, reassuring pages around his conditions and services, with a strong path to enquiry and appointment. The site reads as current and credible, which is what patients look for when choosing who to trust with their care. Directly relevant to your move toward a service-led, booking-friendly site." },
  { name: "Anna Walsh", tag: "Consultant Urologist", body: "A consultant website focused on making services easy to understand and act on. We presented each service clearly, with simple enquiry and appointment options. The same approach works well for pharmacy services such as vaccinations, health checks and weight management, where people want clarity and a quick way to book." },
  { name: "Cervino Medical", tag: "Neurology practice", body: "A neurology practice where we handled both the website redesign and the digital marketing, including Google Ads. This shows the full picture: a strong site backed by SEO and paid activity to bring the right people to it. If you want to grow private service bookings over time, this is the model." },
  { name: "One in Four", tag: "Care-sector charity", body: "A care-sector website we designed and built from the ground up, working from interactive wireframes through to the live site. It is information-led with clear, prominent actions, exactly the structure a pharmacy site needs when the goal is helping people find a service and book rather than buy. This was the wireframe example we walked you through on the call." },
];
const portfolioCases: any[] = [];
for (const s of ["bloomfield-health-services", "antaris-consulting", "breast-cancer-ireland", "gourmet-food-parlour"]) {
  const e = portfolio.find((p) => p.data.slug === s);
  if (e && e.data.heroImage && has(e.data.heroImage)) portfolioCases.push(e.data);
}
const cases = [
  ...namedCases.map((c) => ({ type: "text" as const, name: c.name, tag: c.tag, body: c.body, image: "", results: null as any, slug: "" })),
  ...portfolioCases.map((d) => ({ type: "image" as const, name: d.name, tag: d.tagline || "", body: d.summary || "", image: d.heroImage, results: d.results, slug: d.slug })),
];

const logoFiles = [
  "/images/logos/Laya_Rev.png", "/images/logos/Irish-Defence-Forces_Rev.png", "/images/logos/ILT_Rev.svg",
  "/images/logos/GFP_Rev.svg", "/images/logos/GCJ_Rev.png", "/images/logos/1934_Rev.svg",
  "/images/logos/TC-Matthews_Rev.svg", "/images/logos/Captain-Americas_Rev.png", "/images/logos/Elephant-Castle_Rev.png",
  "/images/logos/Josesph-May_Rev.svg", "/images/logos/MIG_Rev.svg", "/images/logos/Shomera_Rev.svg",
].filter(has);
const awards = [
  { logo: "/images/spider-awards-rev.png", b: "Gold winners", s: "Spider Awards, web design" },
  { logo: "/images/European-Search-Awards-Logo_full_colour-cutout.png", b: "Finalists 2026", s: "European Search Awards, Porto" },
  { logo: "/images/DMA-Generic-Pink-Blue-270x270-1-cutout.png", b: "Award record", s: "Medical, retail and charity" },
].filter((a) => has(a.logo));
const testimonials = [
  { q: "It's a pleasure to work with such a creative, innovative and supportive team, from rebuilding our website to producing amazing video footage that captures the essence of what we do.", n: "Fiona Monahan", c: "Bloomfield Health Services" },
  { q: "They have excelled every step of the way, from branding, website development and programming to SEO.", n: "Jonathan Lyne", c: "Heart Rhythm Cardiology" },
  { q: "A huge thank you to all the team for their superb service. Their knowledge, advice and attention to detail is second to none.", n: "Ciara Foley", c: "Best4Travel" },
  { q: "Irish Landmark Trust have been working with Rooftop Twenty Two for a number of years now and we have loved the experience. A fantastic team of energetic, creative people.", n: "Grace Healy", c: "Irish Landmark Trust" },
  { q: "Cathal and his team could not have done more for us, from developing our vision to the implementation of our style and structure.", n: "Ciaran Mc Bride", c: "Irish Chauffeurs" },
  { q: "Their professionalism and quality of output is always to the high standards we expect, and they're a pleasure to work with.", n: "Brendan Boyle", c: "TAP Creative" },
];

const heart = (cls: string) => `<svg class="${cls}" viewBox="0 0 32 29.6" aria-hidden="true"><path d="M23.6 0c-3.4 0-6.3 2.7-7.6 5.6C14.7 2.7 11.8 0 8.4 0 3.8 0 0 3.8 0 8.4c0 9.1 9.3 13.6 16 21.2 6.7-7.6 16-12.1 16-21.2C32 3.8 28.2 0 23.6 0z"/></svg>`;
const psMark = `<svg class="ps-mark" viewBox="0 0 32 29.6" aria-hidden="true"><path d="M23.6 0c-3.4 0-6.3 2.7-7.6 5.6C14.7 2.7 11.8 0 8.4 0 3.8 0 0 3.8 0 8.4c0 9.1 9.3 13.6 16 21.2 6.7-7.6 16-12.1 16-21.2C32 3.8 28.2 0 23.6 0z" fill="currentColor"/><path d="M14.4 7.6h3.2v3.2h3.2v3.2h-3.2v3.2h-3.2v-3.2h-3.2v-3.2h3.2z" fill="#fff"/></svg>`;

const kicker = (t: string) => `<p class="pr-kicker">${t}</p>`;
const list = (items: string[]) => `<ul class="pr-list">${items.map((i) => `<li><span class="pr-tick"></span><span>${i}</span></li>`).join("")}</ul>`;
const initials = (n: string) => n.split(/\s+/).slice(0, 2).map((w) => w[0]).join("").toUpperCase();

const teamGrid = `<div class="pr-team">${team.map((m) => `<figure class="pr-mem"><img src="${m.portrait}" alt="${m.name}" loading="lazy"/><b>${m.name}</b><span>${m.role}</span></figure>`).join("")}</div>`;
const leaderCards = `<div class="pr-leaders">${leaders.map((m) => `<figure class="pr-leader"><img src="${m.portrait}" alt="${m.name}" loading="lazy"/><figcaption><b>${m.name}</b><span>${m.role}</span></figcaption></figure>`).join("")}</div>`;

const statBlock = (r: any) => (r && r.stats && r.stats.length ? `<div class="cs-stats">${r.stats.map((s: any) => `<div><b>${s.prefix || ""}${s.to}${s.suffix || ""}</b><span>${s.label}</span></div>`).join("")}</div>` : "");
const caseGrid = `<div class="cs-grid">${cases.map((c, i) => c.type === "image"
  ? `<button class="cs-card" data-cs="${i}" type="button"><span class="cs-card__img"><img src="${c.image}" alt="${c.name}" loading="lazy"/></span><span class="cs-card__meta"><b>${c.name}</b><span class="cs-card__tag">${c.tag}</span><em class="cs-card__cta">View case study &rarr;</em></span></button>`
  : `<button class="cs-card cs-card--text" data-cs="${i}" type="button"><span class="cs-card__label">Healthcare</span><span class="cs-card__meta"><b>${c.name}</b><span class="cs-card__tag">${c.tag}</span><em class="cs-card__cta">Read more &rarr;</em></span></button>`).join("")}</div>`;
const caseDetails = cases.map((c, i) => c.type === "image"
  ? `<div class="cs-full" data-cs="${i}" hidden><div class="cs-full__img"><img src="${c.image}" alt="${c.name}"/></div><h3>${c.name}</h3><p class="cs-full__tag">${c.tag}</p><p class="cs-full__body">${c.body}</p>${statBlock(c.results)}<a class="cs-full__link" href="/work/${c.slug}/" target="_blank" rel="noopener">Open full case study &rarr;</a></div>`
  : `<div class="cs-full" data-cs="${i}" hidden><div class="cs-full__head"><span>Healthcare</span></div><h3>${c.name}</h3><p class="cs-full__tag">${c.tag}</p><p class="cs-full__body">${c.body}</p><p class="cs-full__note">Live link available on request.</p></div>`).join("");

const logoMarquee = `<div class="pr-lviewport" data-marquee="60"><ul class="pr-ltrack" role="list">${[...logoFiles, ...logoFiles].map((l) => `<li class="pr-litem"><img src="${l}" alt="" loading="lazy"/></li>`).join("")}</ul></div>`;
const awardCards = `<div class="pr-awards">${awards.map((a) => `<div class="pr-award"><img src="${a.logo}" alt=""/><b>${a.b}</b><span>${a.s}</span></div>`).join("")}</div>`;

const tTrack = [...testimonials, ...testimonials];
const tCards = tTrack.map((t, i) => `<li class="pr-tcard" aria-hidden="${i >= testimonials.length ? "true" : "false"}"><span class="pr-tmark">&ldquo;</span><blockquote class="pr-tquote">${t.q}</blockquote><div class="pr-tby"><span class="pr-tavatar" aria-hidden="true">${initials(t.n)}</span><span class="pr-twho"><span class="pr-tname">${t.n}</span><span class="pr-tco">${t.c}</span></span></div></li>`).join("");

const homepageMock = `<div class="mock">
  <div class="mock__bar"><span class="mock__dot"></span><span class="mock__dot"></span><span class="mock__dot"></span><span class="mock__url">pharmacystore.ie</span></div>
  <div class="mock__screen">
    <div class="mock__nav"><span class="mock__logo">${psMark}<b>PharmacyStore</b></span><span class="mock__links">Services · Pharmacies · Book</span></div>
    <div class="mock__hero">${heart("mock__heart")}<div class="mock__herotext"><p class="mock__tag">Caring for your wellbeing</p><h4>Health checks that fit around your day.</h4><span class="mock__btn">Book an appointment</span></div></div>
    <div class="mock__tiles"><span>Vaccinations</span><span>Health checks</span><span>Weight management</span></div>
  </div></div>`;

const journey = [
  { wk: "Week 1", t: "Discovery &amp; strategy", p: "We sit down together at our Dublin offices and get into your business objectives. We agree goals, audience and the shape of your online presence.",
    inv: ["A working session on your goals, audience and priorities", "A look at how leading pharmacies worldwide present services and booking", "A review of your current content, stripping the dated and Covid-era pages", "Agreement on the shape of the site and a first-draft sitemap"], d: "a clear brief and project plan." },
  { wk: "Weeks 2&ndash;3", t: "Wireframe", p: "We walk you through a full, interactive wireframe. You click through the structure and functionality yourself, including the booking engine, so you understand exactly how the site works before any design. Nothing proceeds until you sign it off.",
    inv: ["A clickable wireframe of every key page", "The booking journey mapped out, so you can test it", "Structure for services, the five locations and health advice", "Your feedback built in, then sign-off before any design"], d: "a signed-off interactive wireframe.", wire: true },
  { wk: "Weeks 3&ndash;5", t: "Visual design", p: "We bring the new brand to life through design, video and imagery, starting with the homepage and working through the key templates.",
    inv: ["The Tap brand carried through every template", "Homepage and key page designs", "Direction for photography and video from your shops and team", "Pharmacist profiles and trust signals designed in"], d: "signed-off designs across key templates." },
  { wk: "Weeks 5&ndash;8", t: "Build &amp; staging", p: "We build the full site on a private staging link, so you can watch it come together and try it for yourself.",
    inv: ["The full site built on a private staging link", "A simple CMS so your team can update hours, services and offers", "The booking engine connected and working", "SEO foundations per service and location, plus core integrations"], d: "the complete site, ready to review." },
  { wk: "Weeks 8&ndash;10", t: "QA &amp; launch", p: "A smooth, well-drilled process we have perfected. We test, fix anything that needs it, then launch, moving quickly to land on time.",
    inv: ["Testing across phones, tablets and browsers", "Accessibility and performance checks, so hours and locations load instantly", "A final content pass and a short training session for your team", "A planned go-live, then we stay close after launch"], d: "a live site, training, and our support." },
];
const WIRE_HTML = '<div class="pr-jwire"><div class="pr-wf"><div class="pr-wf__bar"><span class="pr-wf__logo"></span><span class="pr-wf__nav"></span><span class="pr-wf__nav"></span><span class="pr-wf__btn"></span></div><div class="pr-wf__hero"><div class="pr-wf__lines"><span></span><span></span><span class="pr-wf__cta"></span></div><div class="pr-wf__img"></div></div><div class="pr-wf__cards"><span></span><span></span><span></span></div></div><p class="pr-jwire__cap"><b>What a wireframe is:</b> the blueprint of a page. Grey boxes, no colour yet, so we agree what goes where before any design. Quicker to move a box than redo a finished design.</p></div>';
const jStep = (s: any, i: number) => {
  const involve = s.inv.map((x: string) => "<li>" + x + "</li>").join("");
  const line = i === journey.length - 1 ? "" : '<span class="pr-jline"></span>';
  const wire = s.wire ? WIRE_HTML : "";
  return '<div class="pr-jstep"><div class="pr-jrail"><span class="pr-jnum">' + (i + 1) + '</span>' + line + '</div>' +
    '<div class="pr-jbody"><span class="pr-jweek">' + s.wk + '</span><h3>' + s.t + '</h3><p>' + s.p + '</p>' +
    '<p class="pr-jinvolveh">What\'s involved</p><ul class="pr-jinvolve">' + involve + '</ul>' +
    '<p class="pr-jdeliver"><b>Deliverable:</b> ' + s.d + '</p>' + wire + '</div></div>';
};
const journeyHtml = '<div class="pr-journey">' + journey.map(jStep).join("") + '</div>';

const content = `
<!-- 1 · Title -->
<section class="pr-hero">
  <div class="pr-hero__media"><img src="/images/office/office-studio-01.jpg" alt=""/><div class="pr-hero__scrim"></div></div>
  <div class="pr-wrap pr-hero__inner">
    <p class="pr-cobrand"><span class="pr-cobrand__a">Rooftop Twenty Two</span><span class="pr-cobrand__sep">for</span><span class="pr-cobrand__b">${psMark}PharmacyStore</span></p>
    ${kicker("Website proposal · June 2026")}
    <h1>Pharmacy group website<br/>and booking platform.</h1>
    <p class="pr-hero__sub">Prepared for Ciaran McNally and Tracey Dunne.</p>
    <p class="pr-hero__meta">Rooftop Twenty Two · Glasnevin &amp; the Beacon, Dublin · rooftoptwentytwo.ie</p>
  </div>
</section>

<!-- 2 · Introduction -->
<section class="pr-sec">
  <div class="pr-wrap pr-narrow">
    ${kicker("Introduction")}
    <h2>You have done the hard part with Tap.</h2>
    <p>The brand is fresh, the shops are being revamped and the new photography is in place. The website is the last piece still looking five years old, and that is where we come in.</p>
    <p>We work with a lot of medical and healthcare clients, from consultants and clinics to care organisations. That matters here, because moving off e-commerce to a service and information site is exactly the kind of build where trust and clear booking count more than selling a product off a shelf.</p>
  </div>
  <div class="pr-wrap"><figure class="pr-photo"><img src="/images/office/office-collab-01.jpg" alt="The Rooftop Twenty Two team at work" loading="lazy"/></figure></div>
</section>

