// ---- Encrypt the assembled slides (AES-256-GCM via PBKDF2-derived key) -------
const slidesHtml = slides.join("");
const salt = crypto.randomBytes(16);
const iv = crypto.randomBytes(12);
const key = crypto.pbkdf2Sync(PASSWORD, salt, 150000, 32, "sha256");
const cipher = crypto.createCipheriv("aes-256-gcm", key, iv);
const ciphertext = Buffer.concat([cipher.update(slidesHtml, "utf8"), cipher.final()]);
const tag = cipher.getAuthTag();
// Browser SubtleCrypto expects the auth tag appended to the ciphertext.
const payload = JSON.stringify({
  s: salt.toString("base64"),
  i: iv.toString("base64"),
  c: Buffer.concat([ciphertext, tag]).toString("base64"),
});
const slideCount = slides.length;
---

<!doctype html>
<html lang="en" class="deck-html">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Proposal — Pharmacy Store</title>
    <link rel="preload" href="/fonts/butler-bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/mulish-variable.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="deck-body">
    <!-- Password gate -->
    <div class="deck-gate" id="deck-gate">
      <form class="gate__card" id="gate-form" autocomplete="off">
        <p class="gate__brand">Rooftop Twenty Two</p>
        <h1 class="gate__title">Website proposal</h1>
        <p class="gate__sub">Enter the password to view the deck.</p>
        <input class="gate__input" id="gate-input" type="password" placeholder="Password" aria-label="Password" autofocus />
        <button class="gate__btn" type="submit">View proposal</button>
        <p class="gate__error" id="gate-error" hidden>That password isn't right. Try again.</p>
      </form>
    </div>

    <!-- Deck -->
    <div class="deck-viewport" id="deck-viewport">
      <div class="deck-stage" id="deck-stage" aria-live="polite"></div>
    </div>

    <!-- Controls -->
    <div class="deck-nav" id="deck-nav" hidden>
      <button class="nbtn" id="nav-prev" aria-label="Previous slide">&larr;</button>
      <span class="ncount"><span id="nav-cur">1</span> / <span id="nav-total">{slideCount}</span></span>
      <button class="nbtn" id="nav-next" aria-label="Next slide">&rarr;</button>
      <button class="nbtn nbtn--text" id="nav-print" aria-label="Download as PDF">PDF</button>
      <button class="nbtn nbtn--text" id="nav-full" aria-label="Toggle fullscreen">Full</button>
    </div>

    <div class="deck-progress" id="deck-progress" hidden><span id="deck-progress-bar"></span></div>

    <script type="application/json" id="deck-data" set:html={payload}></script>

    <script>
      const dataEl = document.getElementById("deck-data");
      const payload = JSON.parse(dataEl?.textContent || "{}");
      const gate = document.getElementById("deck-gate");
      const form = document.getElementById("gate-form") as HTMLFormElement | null;
      const input = document.getElementById("gate-input") as HTMLInputElement | null;
      const errEl = document.getElementById("gate-error");
      const stage = document.getElementById("deck-stage");
      const nav = document.getElementById("deck-nav");
      const progress = document.getElementById("deck-progress");
      const bar = document.getElementById("deck-progress-bar");
      const SESSION_KEY = "rt22-deck-pharmacy";

      const b64ToBytes = (s: string) => {
        const bin = atob(s);
        const u = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) u[i] = bin.charCodeAt(i);
        return u;
      };

      async function decrypt(pw: string): Promise<string> {
        const enc = new TextEncoder();
        const baseKey = await crypto.subtle.importKey("raw", enc.encode(pw), "PBKDF2", false, ["deriveKey"]);
        const key = await crypto.subtle.deriveKey(
          { name: "PBKDF2", salt: b64ToBytes(payload.s), iterations: 150000, hash: "SHA-256" },
          baseKey,
          { name: "AES-GCM", length: 256 },
          false,
          ["decrypt"]
        );
        const buf = await crypto.subtle.decrypt({ name: "AES-GCM", iv: b64ToBytes(payload.i) }, key, b64ToBytes(payload.c));
        return new TextDecoder().decode(buf);
      }

      let slides: HTMLElement[] = [];
      let idx = 0;

      function show(n: number) {
        idx = Math.max(0, Math.min(slides.length - 1, n));
        slides.forEach((s, i) => s.classList.toggle("is-current", i === idx));
        const cur = document.getElementById("nav-cur");
        if (cur) cur.textContent = String(idx + 1);
        if (bar) bar.style.width = ((idx + 1) / slides.length) * 100 + "%";
      }
      const next = () => show(idx + 1);
      const prev = () => show(idx - 1);

      function initDeck() {
        slides = Array.from(stage?.querySelectorAll<HTMLElement>(".slide") || []);
        if (!slides.length) return;
        nav?.removeAttribute("hidden");
        progress?.removeAttribute("hidden");
        show(0);
        document.getElementById("nav-next")?.addEventListener("click", next);
        document.getElementById("nav-prev")?.addEventListener("click", prev);
        document.getElementById("nav-print")?.addEventListener("click", () => window.print());
        document.getElementById("nav-full")?.addEventListener("click", toggleFull);
        window.addEventListener("keydown", (e) => {
          if (e.key === "ArrowRight" || e.key === "PageDown" || e.key === " ") { e.preventDefault(); next(); }
          else if (e.key === "ArrowLeft" || e.key === "PageUp") { e.preventDefault(); prev(); }
          else if (e.key.toLowerCase() === "f") toggleFull();
        });
        // Swipe on touch devices.
        let x0 = 0;
        stage?.addEventListener("touchstart", (e) => { x0 = e.touches[0].clientX; }, { passive: true });
        stage?.addEventListener("touchend", (e) => {
          const dx = e.changedTouches[0].clientX - x0;
          if (Math.abs(dx) > 45) (dx < 0 ? next : prev)();
        }, { passive: true });
      }

      function toggleFull() {
        const el = document.getElementById("deck-viewport");
        if (!document.fullscreenElement) el?.requestFullscreen?.();
        else document.exitFullscreen?.();
      }

      async function unlock(pw: string, fromSession = false) {
        try {
          const html = await decrypt(pw);
          if (stage) stage.innerHTML = html;
          gate?.remove();
          document.body.classList.add("is-unlocked");
          sessionStorage.setItem(SESSION_KEY, pw);
          initDeck();
        } catch {
          if (!fromSession) {
            errEl?.removeAttribute("hidden");
            input?.focus();
            input?.select();
          }
        }
      }

      form?.addEventListener("submit", (e) => {
        e.preventDefault();
        errEl?.setAttribute("hidden", "");
        unlock(input?.value || "");
      });

      const saved = sessionStorage.getItem(SESSION_KEY);
      if (saved) unlock(saved, true);
    </script>

