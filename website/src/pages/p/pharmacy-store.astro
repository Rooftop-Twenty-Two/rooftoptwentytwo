      .wf__logo, .wf__nav, .wf__btn, .wf__img, .wf__cta, .wf__lines span, .wf__cards span { background: #d9dde1; border-radius: 0.5cqw; display: block; }
      .wf__logo { width: 6cqw; height: 2cqw; }
      .wf__nav { width: 3.6cqw; height: 1.2cqw; }
      .wf__btn { width: 5cqw; height: 2cqw; margin-left: auto; background: #c2c8ce; }
