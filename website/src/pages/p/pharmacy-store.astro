      .ncount { font-family: var(--w-font-body); font-size: 0.85rem; color: var(--c-on-dark-soft); min-width: 56px; text-align: center; }

      .deck-progress { position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 41; background: rgba(255,255,255,0.08); }
      .deck-progress span { display: block; height: 100%; width: 0; background: var(--c-accent); transition: width 0.4s ease; }

      @media (prefers-reduced-motion: reduce) {
        .slide { transition: opacity 0.2s linear; transform: none; }
      }

      /* ---- Print → PDF: one landscape page per slide ---- */
      @media print {
        @page { size: 1280px 720px; margin: 0; }
        .deck-body { overflow: visible; background: #fff; }
        .deck-gate, .deck-nav, .deck-progress { display: none !important; }
        .deck-viewport { display: block; min-height: 0; padding: 0; }
        .deck-stage { display: contents; box-shadow: none; }
        .slide {
          position: relative; inset: auto; width: 1280px; height: 720px;
          opacity: 1 !important; visibility: visible !important; transform: none !important;
          break-after: page; page-break-after: always;
        }
      }
