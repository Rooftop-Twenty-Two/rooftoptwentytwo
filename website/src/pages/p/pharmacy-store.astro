// ────────────────────────────────────────────────────────────────────────────
// Rooftop Twenty Two — pitch deck (long-form, scrolling page).
// Nine sections: Title, About + team, Expertise, Process, Case studies (with
// click-to-open detail popups), Client portfolio, Team highlights, Pricing,
// Next steps. R22 brand throughout.
//
// CONTENT is AES-256-GCM encrypted at build and only decrypts in the browser on
// the correct password. Change PASSWORD and rebuild to rotate.
// noindex + excluded from the sitemap.
// ────────────────────────────────────────────────────────────────────────────
import "../../styles/globals.css";
import { getCollection } from "astro:content";
import { existsSync } from "node:fs";
import path from "node:path";
import crypto from "node:crypto";

const PASSWORD = "rooftop-pharmacy"; // ← change me and rebuild to rotate access
const has = (p: string) => existsSync(path.join(process.cwd(), "public", p));

// Full team (everyone with a portrait), ordered like the website.
const team = (await getCollection("team"))
  .filter((m) => has(m.data.portrait))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100))
  .map((m) => ({ name: m.data.name, role: m.data.role, portrait: m.data.portrait }));
// Leadership for the Team Highlights section.
const leadNames = ["Cathal", "Roisin", "Justin", "Padraic"];
const leaders = leadNames.map((n) => team.find((t) => t.name === n)).filter(Boolean) as typeof team;

// Case studies (up to 10) — featured first, then by order.
const caseStudies = (await getCollection("portfolio"))
  .filter((p) => p.data.heroImage && has(p.data.heroImage!) && p.data.summary)
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0) || (a.data.order ?? 100) - (b.data.order ?? 100))
  .slice(0, 10)
  .map((p) => p.data);

const logoFiles = [
  "/images/logos/Laya_Rev.png", "/images/logos/Irish-Defence-Forces_Rev.png", "/images/logos/ILT_Rev.svg",
  "/images/logos/GFP_Rev.svg", "/images/logos/GCJ_Rev.png", "/images/logos/1934_Rev.svg",
  "/images/logos/TC-Matthews_Rev.svg", "/images/logos/Captain-Americas_Rev.png", "/images/logos/Elephant-Castle_Rev.png",
  "/images/logos/Josesph-May_Rev.svg", "/images/logos/MIG_Rev.svg", "/images/logos/Shomera_Rev.svg",
