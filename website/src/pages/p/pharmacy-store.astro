    <script>
      const dataEl = document.getElementById("pr-data");
      const payload = JSON.parse(dataEl?.textContent || "{}");
      const gate = document.getElementById("pr-gate");
      const form = document.getElementById("pr-form");
      const input = document.getElementById("pr-input");
      const err = document.getElementById("pr-err");
      const main = document.getElementById("pr-main");
      const top = document.getElementById("pr-top");
      const progress = document.getElementById("pr-progress");
      const bar = document.getElementById("pr-progress-bar");
      const modal = document.getElementById("cs-modal");
      const modalBody = document.getElementById("cs-modal-body");
      const KEY = "rt22-deck-pharmacy";
      const b64 = (s) => { const bin = atob(s); const u = new Uint8Array(bin.length); for (let i = 0; i < bin.length; i++) u[i] = bin.charCodeAt(i); return u; };
      async function decrypt(pw) {
        const base = await crypto.subtle.importKey("raw", new TextEncoder().encode(pw), "PBKDF2", false, ["deriveKey"]);
        const key = await crypto.subtle.deriveKey({ name: "PBKDF2", salt: b64(payload.s), iterations: 150000, hash: "SHA-256" }, base, { name: "AES-GCM", length: 256 }, false, ["decrypt"]);
        return new TextDecoder().decode(await crypto.subtle.decrypt({ name: "AES-GCM", iv: b64(payload.i) }, key, b64(payload.c)));
      }
      function onScroll() { if (!bar) return; const h = document.documentElement.scrollHeight - window.innerHeight; bar.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + "%"; }
      function initMarquees() {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const canHover = window.matchMedia("(hover: hover)").matches;
        document.querySelectorAll("[data-marquee]").forEach((vp) => {
          const track = vp.firstElementChild; if (!track) return;
          const dur = parseFloat(vp.getAttribute("data-marquee") || "120") || 120;
          let half = track.scrollWidth / 2, paused = false, last = 0;
          const measure = () => { half = track.scrollWidth / 2; }; measure(); vp.scrollLeft = half;
          window.addEventListener("resize", measure, { passive: true });
          if (document.fonts && document.fonts.ready) document.fonts.ready.then(measure);
          if (canHover) { vp.addEventListener("mouseenter", () => { paused = true; }); vp.addEventListener("mouseleave", () => { paused = false; }); }
          if (reduce) return;
          const tick = (ts) => { if (!last) last = ts; const dt = ts - last; last = ts; if (!paused && half > 0) { vp.scrollLeft -= (half / (dur * 1000)) * dt; if (vp.scrollLeft <= 0) vp.scrollLeft += half; } requestAnimationFrame(tick); };
          requestAnimationFrame(tick);
        });
      }
      function openCase(i) { const f = document.querySelector('.cs-full[data-cs="' + i + '"]'); if (!f || !modal || !modalBody) return; modalBody.innerHTML = f.innerHTML; modal.removeAttribute("hidden"); document.body.style.overflow = "hidden"; }
      function closeCase() { if (modal) modal.setAttribute("hidden", ""); document.body.style.overflow = ""; }
      function initCases() {
        if (main) main.querySelectorAll(".cs-card").forEach((c) => c.addEventListener("click", () => openCase(c.getAttribute("data-cs"))));
        if (modal) modal.querySelectorAll("[data-cs-close]").forEach((e) => e.addEventListener("click", closeCase));
      }
      window.addEventListener("keydown", (e) => { if (e.key === "Escape") closeCase(); });
      async function unlock(pw, fromSession = false) {
        try {
          const html = await decrypt(pw);
          if (main) main.innerHTML = html;
          gate?.remove(); document.body.classList.add("is-unlocked");
          top?.removeAttribute("hidden"); progress?.removeAttribute("hidden");
          sessionStorage.setItem(KEY, pw);
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll(); initMarquees(); initCases();
        } catch { if (!fromSession) { err?.removeAttribute("hidden"); input?.focus(); input?.select(); } }
      }
      form?.addEventListener("submit", (e) => { e.preventDefault(); err?.setAttribute("hidden", ""); unlock(input?.value || ""); });
      document.getElementById("pr-pdf")?.addEventListener("click", () => window.print());
      const saved = sessionStorage.getItem(KEY); if (saved) unlock(saved, true);
    </script>

