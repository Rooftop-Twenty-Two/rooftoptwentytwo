<!doctype html>
<html lang="en" class="ps-html">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Proposal — PharmacyStore</title>
    <link rel="preload" href="/fonts/butler-bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/mulish-variable.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="ps-body">
    <!-- Password gate -->
    <div class="ps-gate" id="ps-gate">
      <form class="ps-gate__card" id="ps-form" autocomplete="off">
        <p class="ps-gate__mark" set:html={mark + "<span>PharmacyStore</span>"}></p>
        <h1 class="ps-gate__title">Website proposal</h1>
        <p class="ps-gate__sub">Enter the password to view the proposal.</p>
        <input class="ps-gate__input" id="ps-input" type="password" placeholder="Password" aria-label="Password" autofocus />
        <button class="ps-gate__btn" type="submit">View proposal</button>
        <p class="ps-gate__err" id="ps-err" hidden>That password isn't right. Try again.</p>
      </form>
    </div>

    <!-- Top bar (after unlock) -->
    <header class="ps-top" id="ps-top" hidden>
      <div class="ps-top__brand" set:html={mark + "<span>PharmacyStore</span>"}></div>
      <button class="ps-top__pdf" id="ps-pdf" type="button">Download PDF</button>
    </header>

    <main class="ps-main" id="ps-main"></main>

    <div class="ps-progress" id="ps-progress" hidden><span id="ps-progress-bar"></span></div>

    <script type="application/json" id="ps-data" set:html={payload}></script>

    <script>
      const dataEl = document.getElementById("ps-data");
      const payload = JSON.parse(dataEl?.textContent || "{}");
      const gate = document.getElementById("ps-gate");
      const form = document.getElementById("ps-form") as HTMLFormElement | null;
      const input = document.getElementById("ps-input") as HTMLInputElement | null;
      const err = document.getElementById("ps-err");
      const main = document.getElementById("ps-main");
      const top = document.getElementById("ps-top");
      const progress = document.getElementById("ps-progress");
      const bar = document.getElementById("ps-progress-bar");
      const KEY = "rt22-deck-pharmacy";

      const b64 = (s: string) => { const bin = atob(s); const u = new Uint8Array(bin.length); for (let i = 0; i < bin.length; i++) u[i] = bin.charCodeAt(i); return u; };

      async function decrypt(pw: string) {
        const base = await crypto.subtle.importKey("raw", new TextEncoder().encode(pw), "PBKDF2", false, ["deriveKey"]);
        const key = await crypto.subtle.deriveKey({ name: "PBKDF2", salt: b64(payload.s), iterations: 150000, hash: "SHA-256" }, base, { name: "AES-GCM", length: 256 }, false, ["decrypt"]);
        const buf = await crypto.subtle.decrypt({ name: "AES-GCM", iv: b64(payload.i) }, key, b64(payload.c));
        return new TextDecoder().decode(buf);
      }

      function onScroll() {
        if (!bar) return;
        const h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + "%";
      }

      async function unlock(pw: string, fromSession = false) {
        try {
          const html = await decrypt(pw);
          if (main) main.innerHTML = html;
          gate?.remove();
          document.body.classList.add("is-unlocked");
          top?.removeAttribute("hidden");
          progress?.removeAttribute("hidden");
          sessionStorage.setItem(KEY, pw);
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        } catch {
          if (!fromSession) { err?.removeAttribute("hidden"); input?.focus(); input?.select(); }
        }
      }

      form?.addEventListener("submit", (e) => { e.preventDefault(); err?.setAttribute("hidden", ""); unlock(input?.value || ""); });
      document.getElementById("ps-pdf")?.addEventListener("click", () => window.print());
      const saved = sessionStorage.getItem(KEY);
      if (saved) unlock(saved, true);
    </script>

    <style is:global>
      :root {
        --ps-green: #007F40; --ps-forest: #01592E; --ps-grass: #92C83E; --ps-red: #E1251B;
        --ps-grey: #556563; --ps-ink: #14342A; --ps-tint: #EAF3EC; --ps-line: #DCE7DF;
        --ps-serif: "Butler", Georgia, "Times New Roman", serif;
        --ps-sans: "Mulish", system-ui, -apple-system, "Segoe UI", sans-serif;
      }
      .ps-html, .ps-body { margin: 0; }
      .ps-body { background: #fff; color: var(--ps-ink); font-family: var(--ps-sans); overflow-x: hidden; }
      .ps-body:not(.is-unlocked) { overflow: hidden; height: 100vh; }
      .ps-wrap { max-width: 1140px; margin: 0 auto; padding-inline: clamp(1.25rem, 5vw, 3.5rem); }
      .ps-narrow { max-width: 820px; }

      /* ---- Gate ---- */
      .ps-gate { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center; padding: 1.5rem;
        background: radial-gradient(120% 90% at 80% 0%, rgba(146,200,62,0.18), transparent 55%), var(--ps-forest); }
      .ps-gate__card { width: min(440px, 100%); background: #fff; border-radius: 20px; padding: 2.4rem; box-shadow: 0 24px 60px rgba(0,0,0,0.3); display: flex; flex-direction: column; gap: 0.35rem; }
      .ps-gate__mark { display: flex; align-items: center; gap: 0.55rem; color: var(--ps-green); font-family: var(--ps-sans); font-weight: 800; font-size: 1.05rem; margin: 0 0 0.9rem; }
      .ps-gate__mark .ps-mark { width: 30px; height: auto; }
      .ps-gate__title { font-family: var(--ps-serif); font-weight: 600; font-size: 1.85rem; line-height: 1.05; margin: 0; color: var(--ps-forest); }
      .ps-gate__sub { font-size: 0.95rem; color: var(--ps-grey); margin: 0.4rem 0 1.2rem; }
      .ps-gate__input { width: 100%; box-sizing: border-box; padding: 0.85rem 1.1rem; border-radius: 12px; border: 1px solid var(--ps-line); background: #fff; color: var(--ps-ink); font-family: var(--ps-sans); font-size: 1rem; }
      .ps-gate__input:focus-visible { outline: 2px solid var(--ps-green); outline-offset: 2px; }
      .ps-gate__btn { margin-top: 0.8rem; padding: 0.85rem 1.1rem; border: 0; border-radius: 9999px; cursor: pointer; background: var(--ps-green); color: #fff; font-family: var(--ps-sans); font-weight: 800; font-size: 0.95rem; transition: filter 0.15s ease, transform 0.15s ease; }
      .ps-gate__btn:hover { filter: brightness(1.06); transform: translateY(-1px); }
      .ps-gate__err { color: var(--ps-red); font-size: 0.85rem; margin: 0.7rem 0 0; }

      /* ---- Top bar + progress ---- */
      .ps-top { position: sticky; top: 0; z-index: 40; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        padding: 0.7rem clamp(1.25rem, 5vw, 3.5rem); background: rgba(255,255,255,0.92); backdrop-filter: blur(8px); border-bottom: 1px solid var(--ps-line); }
      .ps-top__brand { display: flex; align-items: center; gap: 0.5rem; color: var(--ps-green); font-weight: 800; font-size: 1rem; }
      .ps-top__brand .ps-mark { width: 26px; height: auto; }
      .ps-top__pdf { border: 1px solid var(--ps-line); background: #fff; color: var(--ps-forest); font-family: var(--ps-sans); font-weight: 700; font-size: 0.82rem; padding: 0.5rem 1rem; border-radius: 9999px; cursor: pointer; }
      .ps-top__pdf:hover { background: var(--ps-tint); }
      .ps-progress { position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 50; background: transparent; }
      .ps-progress span { display: block; height: 100%; width: 0; background: var(--ps-grass); }

      /* ---- Type & sections ---- */
      .ps-mark { color: var(--ps-green); }
      .ps-kicker { font-family: var(--ps-sans); font-weight: 800; font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ps-green); margin: 0 0 1rem; }
      .ps-sec { padding-block: clamp(3.25rem, 7vw, 6rem); }
      .ps-sec--tint { background: var(--ps-tint); }
      .ps-sec--forest { background: var(--ps-forest); color: #fff; position: relative; overflow: hidden; }
      .ps-sec h2 { font-family: var(--ps-serif); font-weight: 600; font-size: clamp(1.9rem, 4.2vw, 3rem); line-height: 1.08; letter-spacing: -0.01em; color: var(--ps-forest); margin: 0 0 1.25rem; }
      .ps-sec--forest h2 { color: #fff; }
      .ps-sec--forest .ps-kicker { color: var(--ps-grass); }
      .ps-sec p { font-size: 1.08rem; line-height: 1.65; color: var(--ps-ink); margin: 0 0 1rem; max-width: 70ch; }
      .ps-sec--forest p { color: rgba(255,255,255,0.86); }
      .ps-lead { font-size: 1.2rem; color: var(--ps-grey); }
      .ps-soft { font-size: 0.98rem; color: var(--ps-grey); margin-top: 1.5rem; }
      .ps-sec--forest .ps-soft { color: rgba(255,255,255,0.7); }

      /* ---- Hero ---- */
      .ps-hero { position: relative; background: linear-gradient(160deg, var(--ps-green), var(--ps-forest)); color: #fff; overflow: hidden; padding-block: clamp(4.5rem, 12vw, 9rem); }
      .ps-hero__heart { position: absolute; right: -6%; top: 50%; transform: translateY(-50%); width: min(60vw, 620px); height: auto; fill: rgba(255,255,255,0.07); }
      .ps-hero__inner { position: relative; z-index: 1; }
      .ps-cobrand { display: flex; align-items: center; gap: 0.55rem; font-weight: 800; font-size: 0.9rem; letter-spacing: 0.02em; margin: 0 0 1.75rem; color: #fff; }
      .ps-cobrand .ps-mark { width: 30px; height: auto; color: #fff; }
      .ps-hero .ps-kicker { color: var(--ps-grass); }
      .ps-hero h1 { font-family: var(--ps-serif); font-weight: 600; font-size: clamp(2.4rem, 6.5vw, 4.6rem); line-height: 1.02; letter-spacing: -0.02em; color: #fff; margin: 0; }
      .ps-hero__sub { font-size: clamp(1.1rem, 2.2vw, 1.4rem); color: #fff; margin: 1.5rem 0 0; }
      .ps-hero__meta { font-size: 0.95rem; color: rgba(255,255,255,0.75); margin: 0.6rem 0 0; }
      .ps-tagline { display: inline-block; margin-top: 2rem; font-family: var(--ps-serif); font-style: italic; font-size: 1.3rem; color: var(--ps-grass); }

      /* ---- Stats ---- */
      .ps-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2.5rem; }
      .ps-stat { background: var(--ps-forest); color: #fff; border-radius: 16px; padding: 1.75rem 1.5rem; text-align: center; }
      .ps-stat b { display: block; font-family: var(--ps-serif); font-weight: 600; font-size: clamp(2rem, 5vw, 3rem); color: var(--ps-grass); line-height: 1; }
      .ps-stat span { display: block; font-size: 0.92rem; color: rgba(255,255,255,0.82); margin-top: 0.5rem; }
      @media (max-width: 620px) { .ps-stats { grid-template-columns: 1fr; } }

      /* ---- Lists ---- */
      .ps-list { list-style: none; margin: 1.5rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 1.1rem; }
      .ps-list li { display: flex; gap: 0.9rem; align-items: flex-start; font-size: 1.06rem; line-height: 1.55; color: var(--ps-ink); }
      .ps-tick { flex: 0 0 auto; width: 18px; height: 18px; margin-top: 0.2rem; fill: var(--ps-green); }
      .ps-sec--forest .ps-list li { color: rgba(255,255,255,0.9); }
      .ps-sec--forest .ps-tick { fill: var(--ps-grass); }

      /* ---- Awards ---- */
      .ps-awards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 1.75rem; }
      .ps-award { text-align: center; background: #fff; border: 1px solid var(--ps-line); border-radius: 16px; padding: 2rem 1.25rem; }
      .ps-award img { height: 60px; width: auto; max-width: 70%; object-fit: contain; margin: 0 auto 1.1rem; display: block; }
      .ps-award b { display: block; font-family: var(--ps-serif); font-weight: 600; font-size: 1.2rem; color: var(--ps-forest); }
      .ps-award span { display: block; font-size: 0.9rem; color: var(--ps-grey); margin-top: 0.3rem; }
      @media (max-width: 720px) { .ps-awards { grid-template-columns: 1fr; } }

      /* ---- Team ---- */
      .ps-team { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 1.75rem; }
      .ps-mem { margin: 0; }
      .ps-mem img { width: 100%; aspect-ratio: 4/5; object-fit: cover; object-position: center 14%; border-radius: 14px; background: var(--ps-tint); display: block; }
      .ps-mem b { display: block; font-family: var(--ps-serif); font-weight: 600; font-size: 1.1rem; color: var(--ps-forest); margin-top: 0.7rem; }
      .ps-mem span { display: block; font-size: 0.88rem; color: var(--ps-grey); }
      @media (max-width: 820px) { .ps-team { grid-template-columns: repeat(2, 1fr); } }

      /* ---- Case studies ---- */
      .ps-cases { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.75rem; }
      .ps-case { background: #fff; border: 1px solid var(--ps-line); border-radius: 16px; padding: 1.9rem; }
      .ps-case .ps-mark { width: 34px; height: auto; margin-bottom: 1rem; }
      .ps-case h3 { font-family: var(--ps-serif); font-weight: 600; font-size: 1.35rem; color: var(--ps-forest); margin: 0; }
      .ps-case__role { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ps-green); margin: 0.3rem 0 0.9rem; }
      .ps-case p { font-size: 1rem; line-height: 1.6; color: var(--ps-ink); margin: 0; }
      @media (max-width: 720px) { .ps-cases { grid-template-columns: 1fr; } }

      /* ---- Sitemap tree ---- */
      .ps-tree { margin: 2rem 0 0; }
      .ps-tree__home { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--ps-green); color: #fff; font-family: var(--ps-serif); font-weight: 600; font-size: 1.25rem; padding: 0.6rem 1.4rem; border-radius: 12px; }
      .ps-tree__home .ps-mark { width: 24px; height: auto; color: #fff; }
      .ps-tree__row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1.5rem; }
      .ps-node { background: var(--ps-tint); border: 1px solid var(--ps-line); border-radius: 12px; padding: 1.1rem 1.2rem; }
      .ps-node b { display: block; font-family: var(--ps-serif); font-weight: 600; font-size: 1.1rem; color: var(--ps-forest); margin-bottom: 0.5rem; }
      .ps-node--leaf b { margin-bottom: 0; }
      .ps-node ul { list-style: none; margin: 0; padding: 0; }
      .ps-node li { font-size: 0.92rem; line-height: 1.6; color: var(--ps-grey); }
      @media (max-width: 820px) { .ps-tree__row { grid-template-columns: repeat(2, 1fr); } }

      /* ---- Robotics ---- */
      .ps-robotics__heart { position: absolute; right: -4%; bottom: -20%; width: min(40vw, 380px); height: auto; fill: rgba(255,255,255,0.06); }

      /* ---- Tables ---- */
      .ps-tablewrap { margin-top: 1.75rem; overflow-x: auto; border: 1px solid var(--ps-line); border-radius: 16px; }
      .ps-table { width: 100%; border-collapse: collapse; min-width: 640px; background: #fff; }
      .ps-table th, .ps-table td { text-align: left; padding: 1rem 1.15rem; vertical-align: top; font-size: 0.98rem; line-height: 1.45; border-top: 1px solid var(--ps-line); }
      .ps-table thead th { background: var(--ps-forest); color: #fff; font-family: var(--ps-sans); font-weight: 800; font-size: 0.9rem; border: 0; }
      .ps-table tbody th { color: var(--ps-green); font-weight: 800; width: 22%; }
      .ps-table td { color: var(--ps-ink); }
      .ps-table--int tbody th { width: 26%; color: var(--ps-forest); font-family: var(--ps-serif); font-weight: 600; font-size: 1.02rem; }
      .ps-tag { display: inline-block; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.25rem 0.7rem; border-radius: 9999px; white-space: nowrap; }
      .ps-tag--core { background: rgba(0,127,64,0.12); color: var(--ps-green); }
      .ps-tag--addon { background: rgba(225,37,27,0.12); color: var(--ps-red); }

      .ps-rec { display: flex; gap: 1.1rem; margin-top: 1.75rem; background: var(--ps-tint); border-radius: 16px; padding: 1.6rem 1.75rem; }
      .ps-rec .ps-mark { flex: 0 0 auto; width: 34px; height: auto; margin-top: 0.2rem; }
      .ps-rec b { display: block; font-family: var(--ps-serif); font-weight: 600; font-size: 1.2rem; color: var(--ps-forest); margin-bottom: 0.4rem; }
      .ps-rec p { margin: 0; }

      /* ---- Timeline ---- */
      .ps-timeline { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.25rem; margin: 2rem 0 0; position: relative; }
      .ps-timeline::before { content: ""; position: absolute; top: 22px; left: 10%; right: 10%; height: 2px; background: rgba(255,255,255,0.2); }
      .ps-step { text-align: center; position: relative; }
      .ps-step__n { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%; background: var(--ps-grass); color: var(--ps-forest); font-family: var(--ps-serif); font-weight: 700; font-size: 1.1rem; position: relative; z-index: 1; }
      .ps-step b { display: block; font-family: var(--ps-serif); font-weight: 600; font-size: 1.05rem; color: #fff; margin-top: 0.9rem; line-height: 1.15; }
      .ps-step__wk { display: block; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ps-grass); margin: 0.4rem 0; }
      .ps-step p { font-size: 0.9rem; line-height: 1.4; color: rgba(255,255,255,0.8); margin: 0; }
      @media (max-width: 820px) { .ps-timeline { grid-template-columns: 1fr 1fr; gap: 1.75rem; } .ps-timeline::before { display: none; } }

      /* ---- Wireframe explainer ---- */
      .ps-wf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; margin-top: 3rem; }
      .ps-wf-text h3 { font-family: var(--ps-serif); font-weight: 600; font-size: 1.6rem; color: #fff; margin: 0 0 0.8rem; }
      .ps-wf { background: #fff; border-radius: 14px; padding: 1.25rem; display: flex; flex-direction: column; gap: 0.85rem; box-shadow: 0 16px 40px rgba(0,0,0,0.25); }
      .ps-wf__bar { display: flex; align-items: center; gap: 0.6rem; }
      .ps-wf__logo, .ps-wf__nav, .ps-wf__btn, .ps-wf__img, .ps-wf__cta, .ps-wf__lines span, .ps-wf__cards span { background: #d9dde1; border-radius: 5px; display: block; }
      .ps-wf__logo { width: 84px; height: 20px; }
      .ps-wf__nav { width: 48px; height: 12px; }
      .ps-wf__btn { width: 60px; height: 22px; margin-left: auto; background: #c2c8ce; }
      .ps-wf__hero { display: flex; gap: 1rem; }
      .ps-wf__lines { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 0.6rem; }
      .ps-wf__lines span { height: 14px; }
      .ps-wf__lines span:nth-child(1) { width: 90%; }
      .ps-wf__lines span:nth-child(2) { width: 65%; }
      .ps-wf__cta { width: 100px; height: 26px; margin-top: 0.5rem; background: var(--ps-green); }
      .ps-wf__img { width: 42%; min-height: 110px; }
      .ps-wf__cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.7rem; }
      .ps-wf__cards span { height: 56px; }
      @media (max-width: 820px) { .ps-wf-row { grid-template-columns: 1fr; gap: 1.5rem; } }

      /* ---- Close ---- */
      .ps-close__heart { position: absolute; left: -4%; bottom: -25%; width: min(48vw, 460px); height: auto; fill: rgba(255,255,255,0.06); }
      .ps-contact { margin-top: 1.5rem; }
      .ps-contact a { color: var(--ps-grass); text-decoration: none; }
      .ps-sign { font-family: var(--ps-serif); font-size: 1.2rem; color: #fff; margin-top: 1.75rem; }
      .ps-sign span { font-family: var(--ps-sans); font-size: 0.95rem; color: rgba(255,255,255,0.75); }

      .ps-foot { background: #06281a; color: rgba(255,255,255,0.6); font-size: 0.82rem; padding: 1.5rem 0; text-align: center; }

      @media print {
        @page { margin: 14mm; }
        .ps-gate, .ps-top, .ps-progress { display: none !important; }
        .ps-body { overflow: visible; }
        .ps-sec, .ps-hero { break-inside: avoid; }
        .ps-sec--forest, .ps-hero, .ps-stat { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      }
    </style>
  </body>
</html>
