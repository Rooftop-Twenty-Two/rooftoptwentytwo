        <tr><th>Online payments</th><td>Only if you take payment at the point of booking.</td><td><span class="pr-tag pr-tag--addon">Add-on</span></td></tr>
      </tbody>
    </table></div>
  </div>
</section>

<!-- 10 · Robotics -->
<section class="pr-sec pr-sec--dark">
  <div class="pr-wrap pr-narrow">
    ${kicker("A point of difference")}
    <h2>The robotics and automation angle.</h2>
