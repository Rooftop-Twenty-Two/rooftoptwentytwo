---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import Marquee from "../components/Marquee.astro";
import LogoBar from "../components/LogoBar.astro";
import IntroParagraph from "../components/IntroParagraph.astro";
import HomeWorkPreview from "../components/HomeWorkPreview.astro";
import ServicesPanel from "../components/ServicesPanel.astro";
import Testimonial from "../components/Testimonial.astro";
import TeamStrip from "../components/TeamStrip.astro";
---

<Layout title="Rooftop Twenty Two, Independent branding and digital design studio">
  <HeroHome />
  <LogoBar />
  <Marquee />
  <IntroParagraph />
  <HomeWorkPreview />
  <ServicesPanel />
  <Testimonial
    signatureName="Thanks Conor!"
    premiumLabel="Availing of our Premium Plan"
    quote='"Rooftop Twenty Two act as my Digital Marketing function in Nostra. They integrated seamlessly, bringing a wealth of experience and guidance. We achieved far more than expected in a relatively short period and I would highly recommend Rooftop to a company seeking large marketing agency experience with a personal touch."'
    attribution="Conor O'Brien, Nostra"
    brandLogo="/images/logos/Nostra.svg"
    portrait="/images/site/conor-obrien.jpg"
    portraitAlt="Conor O'Brien, Nostra"
  />
  <TeamStrip />
</Layout>
