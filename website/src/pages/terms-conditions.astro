---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Terms & Conditions | Rooftop Twenty Two">
  <section class="mx-auto max-w-3xl px-6 md:px-12 pt-12 md:pt-20 pb-24">
    <h1
      class="mb-10"
      style="font-family:var(--font-display);font-size:clamp(2.5rem, 5vw, 4rem);color:var(--color-text-on-dark);letter-spacing:-0.01em;"
    >
      Terms &amp; Conditions
    </h1>
    <div class="space-y-6" style="font-family:var(--font-sans);font-size:var(--text-body);color:var(--color-text-on-dark-muted);line-height:1.7;">
      <p>
        These terms govern the use of rooftoptwentytwo.ie. By using this site you agree to be bound by these terms. Rooftop Twenty Two reserves the right to change these terms at any time.
      </p>
      <h2 style="font-family:var(--font-display);font-size:var(--text-heading-md);color:var(--color-text-on-dark);margin-top:1.5rem;">Content ownership</h2>
      <p>
        All material on this site, including text, images, logos, and case studies, is owned by Rooftop Twenty Two or its clients and may not be reproduced without prior written consent.
      </p>
      <h2 style="font-family:var(--font-display);font-size:var(--text-heading-md);color:var(--color-text-on-dark);margin-top:1.5rem;">Privacy</h2>
      <p>
        Personal information submitted through the contact form is used only to respond to your enquiry. We do not sell or share personal data with third parties.
      </p>
      <h2 style="font-family:var(--font-display);font-size:var(--text-heading-md);color:var(--color-text-on-dark);margin-top:1.5rem;">Contact</h2>
      <p>
        Questions about these terms can be sent to hey@rooftoptwentytwo.ie.
      </p>
    </div>
  </section>
</Layout>
