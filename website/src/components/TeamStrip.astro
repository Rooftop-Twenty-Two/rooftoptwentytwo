---
import { getCollection } from "astro:content";

const team = (await getCollection("team")).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100)
);
---

<section class="mx-auto max-w-[1440px] px-6 md:px-12 py-12 md:py-20">
  <div class="flex flex-wrap items-end gap-6 mb-10">
    <h2
      style="font-family:var(--font-display);font-size:clamp(1.75rem, 3vw, 2.5rem);color:var(--color-text-on-dark);letter-spacing:-0.01em;line-height:1.1;"
    >
      The team behind your next big win.
    </h2>
    <a href="/about/" class="btn-filler btn-filler--on-dark" data-filler>
      <span aria-hidden="true"></span>Meet the team
    </a>
  </div>

  <div class="team-strip relative overflow-hidden">
    <div class="team-strip__edge team-strip__edge--left" aria-hidden="true" data-team-edge="left"></div>
    <div class="team-strip__edge team-strip__edge--right" aria-hidden="true" data-team-edge="right"></div>

    <ul class="team-strip__track" data-team-track>
      {team.map((m) => (
        <li class="team-strip__item">
          <figure class="m-0">
            <div
              class="overflow-hidden"
              style="border-radius:var(--radius-card-sm);aspect-ratio:5/6;background-color:var(--color-navy-700);"
            >
              <img src={m.data.portrait} alt={m.data.name} loading="lazy" decoding="async" class="w-full h-full object-cover grayscale" />
            </div>
            <figcaption class="mt-2">
              <p style="font-family:var(--font-sans);font-weight:600;font-size:0.9rem;color:var(--color-text-on-dark);">{m.data.name}</p>
              <p style="font-family:var(--font-sans);font-size:0.75rem;color:var(--color-text-on-dark-muted);">{m.data.role}</p>
            </figcaption>
          </figure>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .team-strip__track {
    display: flex;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
    width: max-content;
    transition: transform 1.6s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .team-strip__item {
    flex: 0 0 220px;
  }
  @media (min-width: 768px) {
    .team-strip__item {
      flex: 0 0 240px;
    }
  }
  .team-strip__edge {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 18%;
    z-index: 2;
    pointer-events: auto;
  }
  .team-strip__edge--left { left: 0; cursor: w-resize; }
  .team-strip__edge--right { right: 0; cursor: e-resize; }

  /* On mobile, just show as a horizontally scrollable strip, no hover-pan */
  @media (max-width: 767px) {
    .team-strip { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .team-strip__track { transition: none; }
    .team-strip__edge { display: none; }
  }
</style>

<script>
  const track = document.querySelector<HTMLElement>("[data-team-track]");
  const left = document.querySelector<HTMLElement>('[data-team-edge="left"]');
  const right = document.querySelector<HTMLElement>('[data-team-edge="right"]');
  if (track && left && right) {
    const PAN_RIGHT = -1100;  // mouse on right edge → pan strip leftwards (show more right items)
    const PAN_LEFT = 480;     // mouse on left edge → pan strip rightwards (show start items)
    const reset = () => (track.style.transform = "translateX(0)");
    left.addEventListener("mouseenter", () => (track.style.transform = `translateX(${PAN_LEFT}px)`));
    right.addEventListener("mouseenter", () => (track.style.transform = `translateX(${PAN_RIGHT}px)`));
    left.addEventListener("mouseleave", reset);
    right.addEventListener("mouseleave", reset);
  }
</script>
