---
// Two-column numbered section matching the source's case study pattern:
// mint display numeral on the LEFT under a hand-script label, body content
// on the RIGHT. Light-themed (sits on stone background). Bullets render as
// chip-style cards with thin borders.

interface Props {
  number: string;
  heading: string;
  bullets?: string[];
}
const { number, heading, bullets = [] } = Astro.props;
---

<section class="case-section">
  <div class="case-section__left">
    <p class="case-section__number">{number}</p>
    <p class="case-section__script">{heading}</p>
  </div>

  <div class="case-section__right">
    <h2 class="case-section__heading">{heading}</h2>
    <div class="case-section__body">
      <slot />
    </div>
    {bullets.length > 0 && (
      <ul class="case-section__bullets list-none p-0 m-0">
        {bullets.map((b) => (
          <li class="case-section__bullet">{b}</li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .case-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  @media (min-width: 768px) {
    .case-section {
      grid-template-columns: minmax(220px, 1fr) 3fr;
      gap: 3rem;
    }
  }
  .case-section__left {
    position: relative;
  }
  .case-section__number {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 8vw, 7rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--color-mint, #00FFB2);
    margin: 0;
  }
  .case-section__script {
    font-family: var(--font-script);
    font-size: clamp(2.75rem, 5vw, 4.5rem);
    line-height: 1;
    color: var(--color-text-on-light, #143A4F);
    margin: -0.2em 0 0 0.25rem;
    transform: rotate(-3deg);
    transform-origin: left center;
    display: inline-block;
  }
  .case-section__heading {
    /* The heading is rendered as the script label on the left; we keep it
       as a screen-reader-friendly h2 but visually hide it so the layout
       matches the source (which doesn't repeat the heading). */
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }
  .case-section__body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    color: var(--color-text-on-light, #143A4F);
    line-height: 1.7;
    max-width: 60ch;
  }
  .case-section__body :global(p + p) {
    margin-top: 1rem;
  }
  .case-section__bullets {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.625rem;
  }
  .case-section__bullet {
    padding: 0.95rem 1.15rem;
    border: 1px solid rgba(20, 58, 79, 0.14);
    border-radius: var(--radius-card-md, 14px);
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-text-on-light, #143A4F);
    background: rgba(255, 255, 255, 0.55);
  }
</style>
