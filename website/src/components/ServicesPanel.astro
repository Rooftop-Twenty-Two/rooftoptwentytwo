---
// Hover-tabs services panel. Three tabs (Brand Design / Website Design /
// Digital Marketing) each reveal a capability list on hover or focus.
// Mirrors the source's nested-tabs UX (hover triggers active, click also
// triggers, keyboard focus also triggers).

type Item = { label: string; href?: string };
type Group = { id: string; title: string; href: string; items: Item[] };

const groups: Group[] = [
  {
    id: "brand",
    title: "Brand Design",
    href: "/services/creative-and-content/",
    items: [
      { label: "Brand Identity", href: "/services/design/" },
      { label: "Brand Strategy" },
      { label: "Brand Tone of Voice" },
      { label: "Brand Guidelines" },
      { label: "Brand Implementation" },
      { label: "Brand Repositioning" },
      { label: "Print Design", href: "/services/design/" },
      { label: "Digital Branding", href: "/services/design/" },
      { label: "Marketing Assets" },
      { label: "Environmental Branding" },
      { label: "Brand Experience" },
      { label: "Motion Graphics and Animation", href: "/services/photo-and-video/" },
    ],
  },
  {
    id: "web",
    title: "Website Design",
    href: "/services/web/",
    items: [
      { label: "Website Design", href: "/services/website-design-and-build/" },
      { label: "Wireframes", href: "/services/website-design-and-build/" },
      { label: "Design Systems", href: "/services/website-design-and-build/" },
      { label: "UX Design", href: "/services/website-design-and-build/" },
      { label: "Website Development", href: "/services/website-design-and-build/" },
      { label: "eCommerce Development", href: "/services/website-design-and-build/" },
      { label: "Shopify Development", href: "/services/website-design-and-build/" },
      { label: "Website Care", href: "/services/website-care/" },
    ],
  },
  {
    id: "digital",
    title: "Digital Marketing",
    href: "/services/performance-marketing/",
    items: [
      { label: "Search Engine Optimisation", href: "/services/seo/" },
      { label: "Content Marketing", href: "/services/seo/" },
      { label: "Social Media Management", href: "/services/social-media-management/" },
      { label: "Paid Social Media Advertising", href: "/services/paid-social/" },
      { label: "Google Ads", href: "/services/google-ads/" },
      { label: "Email Marketing", href: "/services/email-marketing/" },
      { label: "Video Production", href: "/services/photo-and-video/" },
      { label: "Graphic Design", href: "/services/design/" },
      { label: "Marketing Strategy" },
      { label: "Analytics & Reporting" },
      { label: "Conversion Rate Optimisation" },
      { label: "Copywriting" },
      { label: "Full-stack Campaign Management" },
      { label: "E-commerce Marketing" },
    ],
  },
];
---

<section class="services-section alternate-theme-switch" data-theme-switch>
  <!-- Source-exact thin arc: 40px tall, solid navy. The thin top strip
       (~1.7px) sits at the section boundary; the tongue dips down 40px
       at the center into the white services area. The gradient fade
       on HomeWorkPreview above handles the imagery-to-navy diffusion;
       this arc only handles the curved boundary. -->
  <svg
    class="services-section__divider-top"
    viewBox="0 0 1000 100"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path d="M1000,4.3V0H0v4.3C0.9,23.1,126.7,99.2,500,100S1000,22.7,1000,4.3z" />
  </svg>

  <div class="services-section__inner mx-auto max-w-[1280px] px-6 md:px-12 pt-12 pb-20 md:pt-16 md:pb-28">
    <div
      class="p-2 md:p-4"
      style="color:var(--color-text-on-light);"
    >
    <h2
      class="mb-3 max-w-4xl"
      style="font-family:var(--font-display);font-size:clamp(1.75rem, 3.5vw, 2.75rem);line-height:1.1;letter-spacing:-0.01em;"
    >
      Brand Design, Web Design, Digital Marketing,
    </h2>
    <p
      class="mb-12"
      style="font-family:var(--font-script);color:var(--color-coral);font-size:5rem;line-height:1;display:inline-block;transform:rotate(-3deg);"
    >
      and much more
    </p>

    <div class="services-tabs" data-services-tabs>
      <div class="services-tabs__heads" role="tablist" aria-label="Services">
        {groups.map((g, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${g.id}`}
            aria-controls={`panel-${g.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            class="services-tabs__head"
            data-tab-target={g.id}
          >
            {g.title}
          </button>
        ))}
      </div>

      <div class="services-tabs__panels mt-8">
        {groups.map((g, i) => (
          <div
            role="tabpanel"
            id={`panel-${g.id}`}
            aria-labelledby={`tab-${g.id}`}
            class:list={["services-tabs__panel", { "services-tabs__panel--active": i === 0 }]}
            data-tab-panel={g.id}
            tabindex="0"
          >
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-2 list-none p-0 m-0" style="font-family:var(--font-sans);font-size:1rem;color:var(--color-text-on-light-muted);">
              {g.items.map((item) => (
                <li>
                  {item.href ? (
                    <a href={item.href} class="services-tabs__item-link">{item.label}</a>
                  ) : (
                    <span>{item.label}</span>
                  )}
                </li>
              ))}
            </ul>
            <div class="mt-8 flex flex-wrap items-center gap-4">
              <a href={g.href} class="services-tabs__cta">
                Inside {g.title.toLowerCase()} <span aria-hidden="true">→</span>
              </a>
              <a href="/services/" class="services-tabs__cta services-tabs__cta--ghost">
                View all services <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    position: relative;
    background-color: var(--color-stone-100);
    color: var(--color-text-on-light);
    margin-top: 0;
    padding-top: 50px;
  }
  .services-section__divider-top {
    position: absolute;
    top: -1px;
    left: 0;
    width: 100%;
    height: 40px;
    fill: var(--color-page-bg);
    z-index: 3;
    display: block;
    pointer-events: none;
  }
  .services-section__inner {
    position: relative;
    z-index: 2;
  }
  .services-tabs__heads {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 1px solid rgba(20, 58, 79, 0.15);
  }
  .services-tabs__head {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0.875rem 1.25rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text-on-light-muted);
    cursor: pointer;
    position: relative;
    transition: color 200ms ease;
    border-radius: 9999px 9999px 0 0;
  }
  .services-tabs__head:hover,
  .services-tabs__head:focus-visible {
    color: var(--color-text-on-light);
    outline: none;
  }
  .services-tabs__head[aria-selected="true"] {
    color: var(--color-text-on-light);
  }
  .services-tabs__head[aria-selected="true"]::after {
    content: "";
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: -1px;
    height: 2px;
    background: var(--color-coral);
  }
  .services-tabs__panel {
    display: none;
    animation: tab-fade 350ms ease both;
  }
  .services-tabs__panel--active {
    display: block;
  }
  .services-tabs__item-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .services-tabs__item-link:hover {
    color: var(--color-text-on-light);
    border-bottom-color: var(--color-coral);
  }
  .services-tabs__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text-on-light);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 2px solid var(--color-coral);
    transition: gap 180ms ease;
  }
  .services-tabs__cta:hover {
    gap: 0.875rem;
  }
  .services-tabs__cta--ghost {
    border-bottom-color: transparent;
    color: var(--color-text-on-light-muted);
  }
  .services-tabs__cta--ghost:hover {
    color: var(--color-text-on-light);
    border-bottom-color: rgba(20, 58, 79, 0.2);
  }
  @keyframes tab-fade {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // Tabs become active on hover, click, focus, and Arrow Left/Right navigation.
  const groups = document.querySelectorAll<HTMLElement>("[data-services-tabs]");
  for (const g of groups) {
    const heads = g.querySelectorAll<HTMLButtonElement>("[data-tab-target]");
    const panels = g.querySelectorAll<HTMLElement>("[data-tab-panel]");
    const activate = (id: string) => {
      heads.forEach((h) => h.setAttribute("aria-selected", h.dataset.tabTarget === id ? "true" : "false"));
      panels.forEach((p) =>
        p.classList.toggle("services-tabs__panel--active", p.dataset.tabPanel === id)
      );
    };
    heads.forEach((h, i) => {
      h.addEventListener("mouseenter", () => activate(h.dataset.tabTarget!));
      h.addEventListener("focus", () => activate(h.dataset.tabTarget!));
      h.addEventListener("click", () => activate(h.dataset.tabTarget!));
      h.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
          e.preventDefault();
          const next = e.key === "ArrowRight" ? (i + 1) % heads.length : (i - 1 + heads.length) % heads.length;
          heads[next].focus();
        }
      });
    });
  }
</script>
