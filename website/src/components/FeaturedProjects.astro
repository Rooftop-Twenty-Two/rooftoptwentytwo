---
import { getCollection } from "astro:content";
import Signature from "./Signature.astro";

const all = await getCollection("portfolio", ({ data }) => !data.needs_review);
const featured = all
  .sort((a, b) => {
    // Featured first, then by order.
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return (a.data.order ?? 100) - (b.data.order ?? 100);
  })
  .slice(0, 4);
---

<section class="mx-auto max-w-[1440px] px-6 md:px-12 py-16 md:py-24">
  <div class="flex flex-wrap items-end justify-between gap-6 mb-10 md:mb-14">
    <div>
      <Signature text="Our Work" tone="coral" rotate={-3} />
      <h2
        class="mt-3"
        style="font-family:var(--font-display);font-size:clamp(2rem, 4vw, 3rem);color:var(--color-text-on-dark);line-height:1.05;letter-spacing:-0.015em;"
      >
        Selected projects.
      </h2>
    </div>
    <a href="/work/" class="btn-pill btn-pill--ghost-mint">View all work</a>
  </div>

  <ul class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 list-none p-0 m-0">
    {featured.map((e) => {
      const slug = e.id.replace(/\.mdx?$/, "");
      const services = (e.data.services ?? []).slice(0, 2).join(" · ");
      return (
        <li>
          <a
            href={`/work/${slug}/`}
            class="block group relative overflow-hidden"
            style="border-radius:var(--radius-card-md);aspect-ratio:4/3;background-color:var(--color-navy-700);"
          >
            {e.data.heroImage && (
              <img
                src={e.data.heroImage}
                alt={e.data.name}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
              />
            )}
          </a>
          <div class="mt-4">
            {services && (
              <p style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">
                {services}
              </p>
            )}
            <h3
              class="mt-1"
              style="font-family:var(--font-display);font-size:clamp(1.5rem, 2.5vw, 2rem);color:var(--color-text-on-dark);line-height:1.1;letter-spacing:-0.01em;"
            >
              <a href={`/work/${slug}/`} class="hover:underline">{e.data.name}</a>
            </h3>
            {e.data.tagline && (
              <p class="mt-2 max-w-xl" style="font-family:var(--font-sans);font-size:0.95rem;color:var(--color-text-on-dark-muted);">
                {e.data.tagline}
              </p>
            )}
          </div>
        </li>
      );
    })}
  </ul>
</section>
