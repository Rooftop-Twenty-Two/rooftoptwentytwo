---
import BrandTicker from "./reskin/BrandTicker.astro";
const year = new Date().getFullYear();
---

<BrandTicker variant="dark" />

<footer style="background-color:var(--c-dark);color:var(--c-on-dark);" class="pt-20 md:pt-28 pb-8">
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <div class="footer-news">
      <div>
        <p class="kicker kicker--on-dark">Stay in the loop</p>
        <h2 class="footer-news__title">Ideas from the rooftop, now and then.</h2>
      </div>
      <form class="footer-news__form" action="/api/subscribe" method="POST">
        <label class="sr-only" for="footer-email">Email address</label>
        <input id="footer-email" type="email" name="email" required placeholder="you@company.com" class="footer-news__input" />
        <button type="submit" class="wbtn wbtn--accent">Subscribe</button>
      </form>
    </div>

    <hr class="my-12 md:my-16 border-t" style="border-color:rgba(255,255,255,0.10);" />

    <div class="mt-16 md:mt-24 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10">
      <div>
        <p class="font-semibold mb-3" style="font-family:var(--font-sans);">Studio</p>
        <nav aria-label="Footer" class="flex flex-col gap-2" style="font-family:var(--font-sans);font-weight:500;font-size:var(--text-body);">
          <a href="/work/" class="r22-link r22-link--on-dark">Our Work</a>
          <a href="/services/" class="r22-link r22-link--on-dark">Services</a>
          <a href="/sectors/" class="r22-link r22-link--on-dark">Sectors</a>
          <a href="/programmes/" class="r22-link r22-link--on-dark">EI Programmes</a>
          <a href="/latest/" class="r22-link r22-link--on-dark">Latest</a>
          <a href="/about/" class="r22-link r22-link--on-dark">About</a>
          <a href="/contact/" class="r22-link r22-link--on-dark">Contact</a>
        </nav>
      </div>

      <div>
        <p class="font-semibold mb-3" style="font-family:var(--font-sans);">Services</p>
        <nav aria-label="Services" class="flex flex-col gap-2" style="font-family:var(--font-sans);font-weight:500;font-size:var(--text-body);">
          <a href="/services/performance-marketing/" class="r22-link r22-link--on-dark">Performance Marketing</a>
          <a href="/services/google-ads/" class="r22-link r22-link--on-dark">Google Ads</a>
          <a href="/services/paid-social/" class="r22-link r22-link--on-dark">Paid Social</a>
          <a href="/services/seo/" class="r22-link r22-link--on-dark">SEO</a>
          <a href="/services/email-marketing/" class="r22-link r22-link--on-dark">Email Marketing</a>
          <a href="/services/creative-and-content/" class="r22-link r22-link--on-dark">Creative &amp; Content</a>
          <a href="/services/social-media-management/" class="r22-link r22-link--on-dark">Social Media Management</a>
          <a href="/services/design/" class="r22-link r22-link--on-dark">Design</a>
          <a href="/services/photo-and-video/" class="r22-link r22-link--on-dark">Photo &amp; Video</a>
          <a href="/services/web/" class="r22-link r22-link--on-dark">Web</a>
          <a href="/services/website-design-and-build/" class="r22-link r22-link--on-dark">Website Design &amp; Build</a>
          <a href="/services/website-care/" class="r22-link r22-link--on-dark">Website Care</a>
        </nav>
      </div>

      <div>
        <p class="font-semibold mb-3" style="font-family:var(--font-sans);">Head Office</p>
        <address class="not-italic leading-relaxed" style="font-family:var(--font-sans);">
          Rooftop Twenty Two,<br />
          Claremont Avenue,<br />
          Glasnevin,<br />
          Dublin 11,<br />
          D11 YNR2
        </address>
        <p class="mt-4" style="font-family:var(--font-sans);">
          <a href="mailto:hey@rooftoptwentytwo.ie" class="r22-link r22-link--on-dark">hey@rooftoptwentytwo.ie</a>
        </p>
        <p style="font-family:var(--font-sans);">
          <a href="tel:+35316991422" class="r22-link r22-link--on-dark">+353 1 699 1422</a>
        </p>
      </div>

      <div>
        <p class="font-semibold mb-3" style="font-family:var(--font-sans);">Connect with us</p>
        <div class="flex gap-4">
          <a href="https://ie.linkedin.com/company/rooftop-twenty-two" target="_blank" rel="noopener" aria-label="LinkedIn" class="hover:text-[var(--c-accent-2)] transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.62 0 4.29 2.38 4.29 5.48v6.26zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.55V9h3.57v11.45z" />
            </svg>
          </a>
          <a href="https://www.instagram.com/rooftoptwentytwo/" target="_blank" rel="noopener" aria-label="Instagram" class="hover:text-[var(--c-accent-2)] transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <hr class="mt-16 border-t" style="border-color:rgba(255,255,255,0.08);" />
    <p class="mt-6 text-xs" style="color:rgba(255,255,255,0.5);">
      © Rooftop Twenty Two. {year}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .footer-news {
    display: grid; grid-template-columns: 1fr; gap: 1.5rem; align-items: end;
  }
  @media (min-width: 820px) { .footer-news { grid-template-columns: 1fr auto; gap: 3rem; } }
  .footer-news__title {
    font-family: var(--w-font-display); font-weight: 600;
    font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.05; letter-spacing: var(--tracking-display);
    margin-top: 0.5rem; color: var(--c-on-dark);
  }
  .footer-news__form { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .footer-news__input {
    flex: 1 1 240px; min-width: 0; padding: 0.9rem 1.2rem; border-radius: var(--radius-pill);
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.16);
    color: var(--c-on-dark); font-family: var(--w-font-body); font-size: 0.95rem;
  }
  .footer-news__input::placeholder { color: rgba(255,255,255,0.45); }
  .footer-news__input:focus-visible { outline: 2px solid var(--c-accent); outline-offset: 2px; }
</style>
