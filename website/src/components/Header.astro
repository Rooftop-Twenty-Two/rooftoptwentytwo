---
import { getCollection } from "astro:content";
import PressToTalkRing from "./PressToTalkRing.astro";

// --- Data for the mega-panels ----------------------------------------------
const services = (await getCollection("services")).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100)
);
// Group services into the same three clusters used on the homepage:
// Creative & Content, Web, Performance Marketing.
const clusterOrder = ["creative-and-content", "web", "performance-marketing"];
const clusterNames: Record<string, string> = {
  "creative-and-content": "Creative & Content",
  "web": "Web",
  "performance-marketing": "Performance Marketing",
};
const svcGroups = clusterOrder.map((cl) => {
  const parent = services.find((s) => s.data.cluster === cl && s.data.isClusterParent);
  const children = services
    .filter((s) => s.data.cluster === cl && !s.data.isClusterParent)
    .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100))
    .map((s) => ({ name: s.data.name, href: `/services/${s.data.slug}/` }));
  return {
    name: clusterNames[cl],
    href: parent ? `/services/${parent.data.slug}/` : "/services/",
    children,
  };
});

const portfolio = (await getCollection("portfolio", ({ data }) => !data.needs_review))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
const work = (portfolio.filter((p) => p.data.featured && p.data.heroImage).length >= 3
  ? portfolio.filter((p) => p.data.featured && p.data.heroImage)
  : portfolio.filter((p) => p.data.heroImage))
  .map((p) => ({ name: p.data.name, tagline: p.data.tagline, img: p.data.heroImage!, href: `/work/${p.id.replace(/\.mdx?$/, "")}/` }))
  .slice(0, 4);

const articlesAll = (await getCollection("articles")).sort(
  (a, b) => +new Date(b.data.publishedAt as any) - +new Date(a.data.publishedAt as any)
);
const articles = articlesAll.map((a) => ({
  title: a.data.title, excerpt: a.data.excerpt, img: a.data.heroImage,
  href: `/latest/${a.data.slug}/`,
})).slice(0, 4);

const path = Astro.url.pathname;
const isActive = (base: string) => path === base || path.startsWith(base);
---

<header class="hd" data-header data-state="default">
  <div class="hd__bar mx-auto max-w-[1320px] px-6 md:px-12">
    <a href="/" class="hd__logo header__item" data-header-item aria-label="Rooftop Twenty Two, home">
      <img class="header-logo header-logo--white" src="/images/site/rooftop-logo-white.svg" alt="Rooftop Twenty Two" width="180" height="34" />
      <img class="header-logo header-logo--navy" src="/images/site/rooftop-logo-navy.svg" alt="Rooftop Twenty Two" width="180" height="34" aria-hidden="true" />
    </a>

    <nav class="hd__nav header__item" data-header-item aria-label="Primary">
      <ul class="hd__list">
        <!-- WORK -->
        <li class:list={["hd__item has-mega", isActive("/work") && "is-active"]} data-mega>
          <button type="button" class="hd__link" id="t-work" aria-haspopup="true" aria-expanded="false" aria-controls="mp-work">Work</button>
          <div class="mega" id="mp-work" role="region" aria-labelledby="t-work">
            <div class="mega__grid mega__grid--work">
              <div class="mega__a">
                <p class="mega__eyebrow">Selected work</p>
                <ul class="mega__links">
                  {work.slice(0, 3).map((w) => <li><a class="r22-link" href={w.href}>{w.name}</a></li>)}
                </ul>
                <a class="mega__viewall r22-link" href="/work/">View all work &rarr;</a>
              </div>
              {work[0] && (
                <a class="mega__featured" href={work[0].href}>
                  <span class="mega__fimg"><img src={work[0].img} alt={work[0].name} loading="lazy" /></span>
                  <span class="mega__flabel">Featured case study</span>
                  <span class="mega__ftitle">{work[0].name}</span>
                </a>
              )}
              <div class="mega__media">
                {work.slice(1, 3).map((w) => (
                  <a class="mega__tile" href={w.href}><img src={w.img} alt={w.name} loading="lazy" /></a>
                ))}
              </div>
            </div>
          </div>
        </li>

        <!-- SERVICES -->
        <li class:list={["hd__item has-mega", isActive("/services") && "is-active"]} data-mega>
          <button type="button" class="hd__link" id="t-services" aria-haspopup="true" aria-expanded="false" aria-controls="mp-services">Services</button>
          <div class="mega" id="mp-services" role="region" aria-labelledby="t-services">
            <div class="mega__grid mega__grid--services">
              <div class="mega__cats">
                {svcGroups.map((g) => (
                  <div class="mega__cat">
                    <a class="mega__cat-h" href={g.href}>{g.name}</a>
                    <ul class="mega__cat-links">
                      {g.children.map((c) => <li><a class="r22-link" href={c.href}>{c.name}</a></li>)}
                    </ul>
                  </div>
                ))}
              </div>
              <a class="mega__featured mega__featured--cta" href="/contact/">
                <span class="mega__ftitle">Not sure where to start?</span>
                <span class="mega__fsub">Tell us what you&rsquo;re scaling and we&rsquo;ll point you the right way.</span>
                <span class="mega__cta-row"><img class="mega__avatar" src="/images/hero/Cathal.png" alt="" loading="lazy" /> Get in touch &rarr;</span>
              </a>
              <a class="mega__svc-img" href="/work/">
                <img src="/images/office/office-work-01.jpg" alt="Rooftop Twenty Two work in progress" loading="lazy" />
              </a>
            </div>
          </div>
        </li>

        <!-- ABOUT -->
        <li class:list={["hd__item has-mega", path === "/about/" && "is-active"]} data-mega>
          <button type="button" class="hd__link" id="t-about" aria-haspopup="true" aria-expanded="false" aria-controls="mp-about">About</button>
          <div class="mega" id="mp-about" role="region" aria-labelledby="t-about">
            <div class="mega__grid">
              <div class="mega__a">
                <p class="mega__eyebrow">About R22</p>
                <ul class="mega__links">
                  <li><a class="r22-link" href="/about/#story">Our story</a></li>
                  <li><a class="r22-link" href="/about/#team">Our team</a></li>
                  <li><a class="r22-link" href="/about/#how-we-work">How we work</a></li>
                </ul>
                <a class="mega__viewall r22-link" href="/about/">About R22 &rarr;</a>
              </div>
              <div class="mega__featured mega__featured--quote">
                <span class="mega__quote">&ldquo;We work like we&rsquo;re part of your team, invested in your growth, not just billing hours.&rdquo;</span>
                <span class="mega__cite"><img class="mega__avatar" src="/images/hero/Cathal.png" alt="" loading="lazy" /> Cathal O&rsquo;Reilly, Founder</span>
              </div>
              <div class="mega__media">
                <a class="mega__tile" href="/about/#team"><img src="/images/office/office-collab-02.jpg" alt="Team collaborating" loading="lazy" /></a>
                <a class="mega__tile" href="/about/"><img src="/images/office/office-studio-01.jpg" alt="The Rooftop studio" loading="lazy" /></a>
              </div>
            </div>
          </div>
        </li>

        <!-- INSIGHTS -->
        <li class:list={["hd__item has-mega", isActive("/latest") && "is-active"]} data-mega>
          <button type="button" class="hd__link" id="t-insights" aria-haspopup="true" aria-expanded="false" aria-controls="mp-insights">Insights</button>
          <div class="mega" id="mp-insights" role="region" aria-labelledby="t-insights">
            <div class="mega__grid">
              <div class="mega__a">
                <p class="mega__eyebrow">Latest</p>
                <ul class="mega__links">
                  {articles.slice(0, 3).map((a) => <li><a class="r22-link" href={a.href}>{a.title}</a></li>)}
                </ul>
                <a class="mega__viewall r22-link" href="/latest/">View all insights &rarr;</a>
              </div>
              {articles[0] && (
                <a class="mega__featured" href={articles[0].href}>
                  {articles[0].img && <span class="mega__fimg"><img src={articles[0].img} alt={articles[0].title} loading="lazy" /></span>}
                  <span class="mega__flabel">Latest article</span>
                  <span class="mega__ftitle">{articles[0].title}</span>
                </a>
              )}
              <div class="mega__media">
                {articles.slice(1, 3).map((a) => (
                  a.img ? <a class="mega__tile" href={a.href}><img src={a.img} alt={a.title} loading="lazy" /></a> : null
                ))}
              </div>
            </div>
          </div>
        </li>

        <!-- CAREERS -->
        <li class:list={["hd__item", isActive("/careers") && "is-active"]}>
          <a class="hd__link" href="/careers/">Careers</a>
        </li>
      </ul>
    </nav>

    <div class="hd__right header__item" data-header-item>
      <a href="/contact/" class="wbtn wbtn--accent hd__cta">Get in Touch</a>
      <button type="button" class="hd__menu" data-menu-open-trigger aria-label="Menu" aria-expanded="false">
        <PressToTalkRing size={52} />
      </button>
    </div>
  </div>
</header>

<style>
  .header__item { opacity: 0; transform: translateY(-8px); transition: opacity 600ms ease, transform 600ms ease; }
  .header__item--ready { opacity: 1; transform: translateY(0); }

  .hd { position: sticky; top: 0; width: 100%; z-index: 100; color: #fff;
    transition: background-color var(--w-dur-fast) var(--w-ease), color var(--w-dur-fast) var(--w-ease), box-shadow var(--w-dur-fast) var(--w-ease); }
  .hd__bar { display: flex; align-items: center; justify-content: space-between; height: 80px; }

  /* Solid white once scrolled, or while a panel is open */
  .hd[data-state="scrolled"], .hd[data-state="menu-open"] {
    background: var(--c-bg); color: var(--c-ink);
    box-shadow: 0 1px 0 var(--c-line), var(--w-shadow-soft);
  }
  .hd__logo { display: inline-flex; align-items: center; }
  .header-logo { height: 32px; width: auto; display: block; }
  .header-logo--navy { display: none; }
  .hd[data-state="scrolled"] .header-logo--white,
  .hd[data-state="menu-open"] .header-logo--white { display: none; }
  .hd[data-state="scrolled"] .header-logo--navy,
  .hd[data-state="menu-open"] .header-logo--navy { display: block; }

  /* Nav */
  .hd__nav { display: none; }
  @media (min-width: 1024px) { .hd__nav { display: block; } }
  .hd__list { display: flex; align-items: center; gap: 0.25rem; list-style: none; margin: 0; padding: 0; }
  .hd__item { position: relative; }
  .hd__link {
    font-family: var(--w-font-body); font-weight: 600; font-size: 0.98rem; color: inherit;
    background: none; border: 0; cursor: pointer; text-decoration: none;
    padding: 0.55rem 0.95rem; border-radius: var(--radius-pill);
    transition: color var(--w-dur-fast) var(--w-ease);
  }
  .hd__link:hover, .hd__item[data-open="true"] .hd__link { color: var(--c-accent); }
  .hd[data-state="default"] .hd__link:hover,
  .hd[data-state="default"] .hd__item[data-open="true"] .hd__link { color: var(--c-accent-2); }
  .hd__item.is-active > .hd__link { box-shadow: inset 0 -2px 0 var(--c-accent); }
  .hd__link:focus-visible { outline: 2px solid var(--c-accent); outline-offset: 2px; }

  .hd__right { display: flex; align-items: center; gap: 0.75rem; }
  @media (max-width: 1023px) { .hd__cta { display: none; } }
  .hd__menu { color: inherit; }
  @media (min-width: 1024px) { .hd__menu { display: none; } }

  /* Mega panel */
  /* Centered on screen (fixed, below the 80px header bar) rather than anchored
   * under each nav item. Panel stays a child of the <li> so hover-intent holds. */
  .mega {
    position: fixed; top: 80px; left: 50%; padding-top: 0.6rem;
    visibility: hidden; opacity: 0; transform: translate(-50%, -8px);
    transition: opacity var(--w-dur) var(--w-ease), transform var(--w-dur) var(--w-ease), visibility var(--w-dur);
    z-index: 120;
  }
  .hd__item[data-open="true"] .mega { visibility: visible; opacity: 1; transform: translate(-50%, 0); }
  .mega__grid {
    display: grid; gap: 1.4rem; padding: clamp(1.25rem, 2.5vw, 2rem);
    background: var(--c-bg); color: var(--c-ink);
    border: 1px solid var(--c-line); border-radius: var(--w-radius); box-shadow: var(--w-shadow-soft);
    grid-template-columns: 220px 240px 200px; width: max-content; max-width: 88vw;
  }
  .mega__grid--work { grid-template-columns: 200px 240px 200px; }
  /* Services panel: three homepage clusters as columns, plus the CTA. */
  .mega__grid--services { grid-template-columns: auto 230px 210px; align-items: stretch; }
  .mega__svc-img { display: block; border-radius: var(--w-radius); overflow: hidden; min-height: 100%; }
  .mega__svc-img img { width: 100%; height: 100%; min-height: 220px; object-fit: cover; display: block; transition: transform var(--w-dur) var(--w-ease); }
  .mega__svc-img:hover img { transform: scale(1.04); }
  .mega__cats { display: grid; grid-template-columns: repeat(3, minmax(150px, 1fr)); gap: 2rem; }
  .mega__cat-h {
    display: block; font-family: var(--w-font-display); font-weight: 700; font-size: 1.05rem;
    color: var(--c-ink); text-decoration: none; padding-bottom: 0.6rem; margin-bottom: 0.4rem;
    border-bottom: 1px solid var(--c-line); transition: color var(--w-dur-fast) var(--w-ease);
  }
  .mega__cat-h:hover { color: var(--c-accent); }
  .mega__cat-links { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.1rem; }
  .mega__cat-links a {
    display: block; font-family: var(--w-font-body); font-size: 0.95rem;
    color: var(--c-ink-soft); text-decoration: none; padding: 0.32rem 0;
    transition: color var(--w-dur-fast) var(--w-ease);
  }
  .mega__cat-links a:hover { color: var(--c-accent); }
  .mega__eyebrow { font-family: var(--w-font-body); font-weight: 700; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--c-ink-soft); margin: 0 0 1rem; }
  .mega__links { list-style: none; margin: 0 0 1rem; padding: 0; display: grid; gap: 0.15rem; }
  .mega__links a {
    display: block; font-family: var(--w-font-display); font-weight: 600; font-size: 1.05rem;
    color: var(--c-ink); text-decoration: none; padding: 0.5rem 0; border-radius: 8px;
    transition: color var(--w-dur-fast) var(--w-ease), transform var(--w-dur-fast) var(--w-ease);
  }
  .mega__links a:hover { color: var(--c-accent); }
  .mega__viewall { font-family: var(--w-font-body); font-weight: 600; font-size: 0.9rem; color: var(--c-accent); text-decoration: none; }

  .mega__featured {
    display: flex; flex-direction: column; gap: 0.5rem; text-decoration: none;
    background: var(--c-bg-alt); border-radius: 14px; padding: 1.1rem; color: var(--c-ink);
  }
  .mega__featured--cta { background: var(--c-ink); color: #fff; justify-content: center; }
  .mega__featured--quote { background: var(--c-bg-alt); justify-content: center; }
  .mega__fimg { display: block; border-radius: 10px; overflow: hidden; aspect-ratio: 16/10; margin-bottom: 0.4rem; }
  .mega__fimg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mega__flabel { font-family: var(--w-font-body); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-ink-soft); }
  .mega__ftitle { font-family: var(--w-font-display); font-weight: 600; font-size: 1.15rem; line-height: 1.15; }
  .mega__featured--cta .mega__ftitle { color: #fff; }
  .mega__fsub { font-family: var(--w-font-body); font-size: 0.85rem; color: var(--c-on-dark-soft); line-height: 1.45; }
  .mega__cta-row { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--w-font-body); font-weight: 600; color: var(--c-accent-2); margin-top: 0.3rem; }
  .mega__avatar { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; }
  .mega__quote { font-family: var(--w-font-display); font-weight: 500; font-size: 1.05rem; line-height: 1.3; color: var(--c-ink); }
  .mega__cite { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--w-font-body); font-size: 0.8rem; color: var(--c-ink-soft); margin-top: 0.75rem; }

  .mega__media { display: grid; gap: 0.5rem; align-content: start; }
  .mega__tile { display: block; border-radius: 10px; overflow: hidden; aspect-ratio: 4/3; background: var(--c-bg-alt); }
  .mega__tile img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform var(--w-dur) var(--w-ease); }
  .mega__tile:hover img { transform: scale(1.05); }

  @media (prefers-reduced-motion: reduce) {
    .mega { transition: opacity var(--w-dur-fast) linear; transform: translate(-50%, 0) !important; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const items = document.querySelectorAll<HTMLElement>("[data-header-item]");
    items.forEach((el, i) => setTimeout(() => el.classList.add("header__item--ready"), 120 + i * 110));
  });

  const header = document.querySelector<HTMLElement>("[data-header]");
  const megas = Array.from(document.querySelectorAll<HTMLElement>("[data-mega]"));
  let anyOpen = false;

  function syncHeaderState() {
    if (!header) return;
    if (anyOpen) { header.dataset.state = "menu-open"; return; }
    header.dataset.state = window.scrollY > 80 ? "scrolled" : "default";
  }
  window.addEventListener("scroll", syncHeaderState, { passive: true });
  syncHeaderState();

  function closeAll(except?: HTMLElement) {
    for (const li of megas) {
      if (li === except) continue;
      li.dataset.open = "false";
      li.querySelector(".hd__link")?.setAttribute("aria-expanded", "false");
    }
  }
  function setOpen(li: HTMLElement, open: boolean) {
    li.dataset.open = String(open);
    li.querySelector(".hd__link")?.setAttribute("aria-expanded", String(open));
    if (open) closeAll(li);
    anyOpen = megas.some((m) => m.dataset.open === "true");
    syncHeaderState();
  }

  // Hover-intent: open after 80ms, close after 200ms; trigger + panel share the <li>.
  let openTimer = 0, closeTimer = 0;
  megas.forEach((li) => {
    const btn = li.querySelector<HTMLButtonElement>(".hd__link");
    li.addEventListener("mouseenter", () => {
      window.clearTimeout(closeTimer);
      openTimer = window.setTimeout(() => setOpen(li, true), 80);
    });
    li.addEventListener("mouseleave", () => {
      window.clearTimeout(openTimer);
      closeTimer = window.setTimeout(() => setOpen(li, false), 220);
    });
    li.addEventListener("focusin", () => setOpen(li, true));
    li.addEventListener("focusout", (e) => {
      if (!li.contains(e.relatedTarget as Node)) setOpen(li, false);
    });
    btn?.addEventListener("click", (e) => {
      e.preventDefault();
      setOpen(li, li.dataset.open !== "true");
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && anyOpen) {
      const open = megas.find((m) => m.dataset.open === "true");
      closeAll(); anyOpen = false; syncHeaderState();
      open?.querySelector<HTMLButtonElement>(".hd__link")?.focus();
    }
  });
  document.addEventListener("click", (e) => {
    if (!(e.target as HTMLElement).closest("[data-mega]")) { closeAll(); anyOpen = false; syncHeaderState(); }
  });
  window.addEventListener("scroll", () => {
    if (anyOpen && window.scrollY > 80) { closeAll(); anyOpen = false; syncHeaderState(); }
  }, { passive: true });
</script>
