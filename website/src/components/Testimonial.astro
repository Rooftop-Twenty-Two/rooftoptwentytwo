---
import Signature from "./Signature.astro";

interface Props {
  signatureName?: string;
  premiumLabel?: string;
  quote: string;
  attribution: string;
  brandLogo?: string;
  portrait: string;
  portraitAlt?: string;
}

const {
  signatureName = "Thanks Conor!",
  premiumLabel = "Availing of our Premium Plan",
  quote,
  attribution,
  brandLogo,
  portrait,
  portraitAlt = "",
} = Astro.props;
---

<section class="mx-auto max-w-[1440px] px-6 md:px-12 py-20 md:py-28 grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 items-center">
  <div class="md:col-span-7 max-w-2xl">
    <Signature text={signatureName} tone="coral" rotate={-5} />
    <p
      class="mt-4"
      style="font-family:var(--font-sans);font-size:0.9rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-text-on-dark-muted);"
    >
      {premiumLabel}
    </p>
    <blockquote
      class="mt-6"
      style="font-family:var(--font-display);font-size:clamp(1.25rem, 2vw, 1.875rem);line-height:1.4;color:var(--color-text-on-dark);letter-spacing:-0.005em;"
    >
      {quote}
    </blockquote>
    <p class="mt-6" style="font-family:var(--font-sans);font-size:1rem;color:var(--color-text-on-dark-muted);">{attribution}</p>
    {brandLogo && (
      <img src={brandLogo} alt="" class="mt-6 h-8 w-auto opacity-90" loading="lazy" decoding="async" />
    )}
  </div>
  <div class="md:col-span-5">
    <figure class="m-0 overflow-hidden" style="border-radius:var(--radius-card-lg);">
      <img src={portrait} alt={portraitAlt} class="w-full h-auto block" loading="lazy" decoding="async" />
    </figure>
  </div>
</section>
