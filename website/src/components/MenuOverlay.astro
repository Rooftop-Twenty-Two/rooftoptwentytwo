---
// Full-screen menu overlay (mobile + tap-to-open). Clean single-column layout:
// kicker, big stacked nav links, primary CTA. clip-path reveal + staggered fade-up.
// Triggered by [data-menu-open-trigger]; dismissed by [data-menu-close] / backdrop / Esc.
import { getCollection } from "astro:content";
const svcCount = (await getCollection("services")).filter((s) => !s.data.isClusterParent).length;

const links = [
  { label: "Work", href: "/work/" },
  { label: "Services", href: "/services/", badge: svcCount },
  { label: "About", href: "/about/" },
  { label: "Insights", href: "/latest/" },
  { label: "Careers", href: "/careers/" },
  { label: "Contact", href: "/contact/" },
];
---

<div class="menu" data-menu hidden>
  <button type="button" class="menu__backdrop" aria-label="Close menu" data-menu-close></button>

  <div class="menu__panel" role="dialog" aria-modal="true" aria-label="Main menu">
    <div class="menu__bar">
      <a href="/" class="menu__logo" aria-label="Rooftop Twenty Two, home">
        <img src="/images/site/rooftop-logo-white.svg" alt="Rooftop Twenty Two" width="170" height="32" />
      </a>
      <button type="button" class="menu__close" aria-label="Close menu" data-menu-close>
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 56 56" fill="none" aria-hidden="true">
          <rect x="1.3" y="1.33" width="53.4" height="53.4" rx="26.7" stroke="currentColor" stroke-width="1.6" />
          <path d="M28 29.31L39.93 41.24L41.21 39.97L29.28 28.04L41.21 16.11L39.93 14.83L28 26.76L16.07 14.83L14.8 16.11L26.73 28.04L14.8 39.97L16.07 41.24L28 29.31Z" fill="currentColor" />
        </svg>
      </button>
    </div>

    <nav class="menu__nav" aria-label="Primary">
      <p class="menu__eyebrow" data-menu-stagger><span class="menu__dot" aria-hidden="true"></span> Have a look around&hellip;</p>
      <ul class="menu__list">
        {links.map((l) => (
          <li data-menu-stagger>
            <a href={l.href} class="menu__link">
              {l.label}
              {l.badge ? <sup class="menu__badge">{l.badge}</sup> : null}
            </a>
          </li>
        ))}
      </ul>

      <div class="menu__cta" data-menu-stagger>
        <a href="/contact/" class="wbtn wbtn--accent menu__cta-btn">Get in touch <span class="menu__cta-arrow" aria-hidden="true">&#8599;</span></a>
      </div>

      <ul class="menu__social" data-menu-stagger>
        <li><a href="https://ie.linkedin.com/company/rooftop-twenty-two" target="_blank" rel="noopener" class="menu__social-link">LinkedIn</a></li>
        <li aria-hidden="true" class="menu__social-divider">·</li>
        <li><a href="https://www.instagram.com/rooftoptwentytwo/" target="_blank" rel="noopener" class="menu__social-link">Instagram</a></li>
      </ul>
    </nav>
  </div>
</div>

<style>
  .menu { position: fixed; inset: 0; z-index: 100; pointer-events: none; }
  .menu[data-menu-open] { pointer-events: auto; }
  .menu__backdrop {
    position: absolute; inset: 0; background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    opacity: 0; transition: opacity 500ms ease; border: 0; cursor: pointer;
  }
  .menu[data-menu-open] .menu__backdrop { opacity: 1; }

  .menu__panel {
    position: absolute; inset: 0;
    background: var(--c-dark); color: #fff;
    clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
    transition: clip-path 750ms cubic-bezier(0.65, 0, 0.35, 1);
    display: flex; flex-direction: column; overflow-y: auto;
    padding: 1.25rem clamp(1.5rem, 6vw, 4rem) 2.5rem;
  }
  .menu[data-menu-open] .menu__panel { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }

  .menu__bar { display: flex; align-items: center; justify-content: space-between; }
  .menu__logo img { height: 30px; width: auto; display: block; }
  .menu__close { appearance: none; border: 0; background: transparent; color: #fff; cursor: pointer; transition: transform 220ms ease; margin-right: -0.25rem; }
  .menu__close:hover { transform: rotate(90deg); }

  .menu__nav { margin-top: auto; padding-top: 2.5rem; }
  .menu__eyebrow {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--w-font-body); font-size: 0.95rem; color: var(--c-on-dark-soft); margin: 0 0 1.5rem;
  }
  .menu__dot { width: 0.45rem; height: 0.45rem; border-radius: 50%; background: var(--c-accent-2); }

  .menu__list { list-style: none; margin: 0; padding: 0; }
  .menu__link {
    display: inline-block; position: relative;
    font-family: var(--w-font-display); font-weight: 600;
    font-size: clamp(2.75rem, 11vw, 4.5rem); line-height: 1.04; letter-spacing: -0.02em;
    color: #fff; text-decoration: none; transition: color 200ms ease, transform 200ms ease;
  }
  .menu__link:hover { color: var(--c-accent-2); transform: translateX(4px); }
  .menu__badge {
    top: -0.2em; margin-left: 0.4rem;
    font-family: var(--w-font-body); font-weight: 700; font-size: 0.8rem; line-height: 1;
    color: var(--c-dark); background: var(--c-accent-2);
    border-radius: var(--radius-pill); padding: 0.2rem 0.5rem; vertical-align: super;
  }

  .menu__cta { margin-top: 2.25rem; }
  .menu__cta-arrow { margin-left: 0.4rem; font-weight: 700; }

  .menu__social { list-style: none; margin: 2.25rem 0 0; padding: 0; display: flex; align-items: center; gap: 0.9rem; }
  .menu__social-link { font-family: var(--w-font-body); font-size: 0.95rem; color: var(--c-on-dark-soft); text-decoration: none; transition: color 200ms ease; }
  .menu__social-link:hover { color: var(--c-accent-2); }
  .menu__social-divider { color: rgba(255, 255, 255, 0.25); }

  [data-menu-stagger] { opacity: 0; transform: translateY(36px); transition: opacity 500ms ease, transform 500ms ease; }
  .menu[data-menu-open] [data-menu-stagger] { opacity: 1; transform: translateY(0); }
  .menu[data-menu-open] .menu__list [data-menu-stagger]:nth-child(1) { transition-delay: 0.16s; }
  .menu[data-menu-open] .menu__list [data-menu-stagger]:nth-child(2) { transition-delay: 0.22s; }
  .menu[data-menu-open] .menu__list [data-menu-stagger]:nth-child(3) { transition-delay: 0.28s; }
  .menu[data-menu-open] .menu__list [data-menu-stagger]:nth-child(4) { transition-delay: 0.34s; }
  .menu[data-menu-open] .menu__list [data-menu-stagger]:nth-child(5) { transition-delay: 0.40s; }
  .menu[data-menu-open] .menu__list [data-menu-stagger]:nth-child(6) { transition-delay: 0.46s; }
  .menu[data-menu-open] .menu__eyebrow { transition-delay: 0.10s; }
  .menu[data-menu-open] .menu__cta { transition-delay: 0.52s; }
  .menu[data-menu-open] .menu__social { transition-delay: 0.58s; }

  @media (prefers-reduced-motion: reduce) {
    .menu__panel { transition: none; }
    [data-menu-stagger] { transition: none; }
  }
</style>

<script>
  const menu = document.querySelector<HTMLElement>("[data-menu]");
  if (menu) {
    const open = () => {
      menu.removeAttribute("hidden");
      requestAnimationFrame(() => menu.setAttribute("data-menu-open", ""));
      document.documentElement.style.overflow = "hidden";
    };
    const close = () => {
      menu.removeAttribute("data-menu-open");
      document.documentElement.style.overflow = "";
      setTimeout(() => {
        if (!menu.hasAttribute("data-menu-open")) menu.setAttribute("hidden", "");
      }, 800);
    };
    document.querySelectorAll<HTMLElement>("[data-menu-open-trigger]").forEach((el) => {
      el.addEventListener("click", (e) => { e.preventDefault(); open(); });
    });
    document.querySelectorAll<HTMLElement>("[data-menu-close]").forEach((el) => {
      el.addEventListener("click", close);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.hasAttribute("data-menu-open")) close();
    });
  }
</script>
