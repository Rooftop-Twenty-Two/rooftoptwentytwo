---
import FAQSchema from "./seo/FAQSchema.astro";

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  heading?: string;
  eyebrow?: string;
}

const { faqs, heading = "Common questions", eyebrow } = Astro.props;
---

{faqs.length > 0 && (
  <section class="faq-block mx-auto max-w-[1100px] px-6 md:px-12 py-16 md:py-24">
    {eyebrow && (
      <p class="faq-block__eyebrow">{eyebrow}</p>
    )}
    <h2 class="faq-block__heading">{heading}</h2>

    <div class="faq-block__list">
      {faqs.map((f, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-item__summary">
            <span class="faq-item__question">{f.question}</span>
            <span class="faq-item__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </summary>
          <div class="faq-item__answer">
            <p>{f.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <FAQSchema faqs={faqs} />
  </section>
)}

<style>
  .faq-block__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-on-dark-soft);
    margin-bottom: 0.5rem;
  }
  .faq-block__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-on-dark);
    margin-bottom: 2.5rem;
  }
  .faq-block__list {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .faq-item__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    cursor: pointer;
    list-style: none;
  }
  .faq-item__summary::-webkit-details-marker { display: none; }
  .faq-item__question {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 1.8vw, 1.5rem);
    color: var(--c-on-dark);
    line-height: 1.3;
  }
  .faq-item__icon {
    flex-shrink: 0;
    color: var(--c-accent-2);
    transition: transform 220ms var(--ease-out-rooftop);
  }
  .faq-item[open] .faq-item__icon { transform: rotate(180deg); }
  .faq-item__answer {
    padding: 0 0 1.75rem 0;
    font-family: var(--font-sans);
    color: var(--c-on-dark-soft);
    line-height: 1.65;
    font-size: 1.0625rem;
    max-width: 65ch;
  }
</style>
