---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BtnFiller from "../BtnFiller.astro";
import FAQBlock from "../FAQBlock.astro";
import PageCTA from "../PageCTA.astro";
import BreadcrumbSchema from "../seo/BreadcrumbSchema.astro";
import ServiceSchema from "../seo/ServiceSchema.astro";

type ProcessStep = { step: string; label: string; body: string };
type FAQ = { question: string; answer: string };

interface Props {
  name: string;
  slug: string;
  cluster: string;
  isClusterParent: boolean;
  summary: string;
  metaDescription: string;
  heroEyebrow?: string;
  heroHeading: string;
  heroBody: string;
  whatItIs: string;
  whatsIncluded: string[];
  process: ProcessStep[];
  sectorsThatBuy: string[];
  relatedServices: string[];
  relatedProgrammes: string[];
  caseStudySlugs: string[];
  faq: FAQ[];
}

const {
  name,
  slug,
  cluster,
  isClusterParent,
  summary,
  metaDescription,
  heroEyebrow,
  heroHeading,
  heroBody,
  whatItIs,
  whatsIncluded,
  process,
  sectorsThatBuy,
  relatedServices,
  relatedProgrammes,
  caseStudySlugs,
  faq,
} = Astro.props;

const pageUrl = `/services/${slug}/`;
const title = `${name} | Rooftop Twenty Two`;

// Resolve linked case studies to real portfolio imagery.
const portfolio = await getCollection("portfolio");
const pfBySlug = new Map(portfolio.map((p) => [p.data.slug, p.data]));
const caseStudies = (caseStudySlugs ?? [])
  .map((sl) => pfBySlug.get(sl))
  .filter((p): p is NonNullable<typeof p> => Boolean(p && p.heroImage))
  .slice(0, 3);

// Hero background: lead case study, falling back to an office shot.
const heroBg = caseStudies[0]?.heroImage ?? "/images/office/office-collab-01.jpg";

// Cluster-aligned colour treatment, matching the Services index bands so each
// detail page feels part of its cluster.
type Treatment = {
  accent: string;
  band: string;
  bandText: string;
  bandMuted: string;
  bandAccent: string;
};
const treatments: Record<string, Treatment> = {
  "performance-marketing": {
    accent: "var(--color-coral)",
    band: "var(--color-coral)",
    bandText: "#FFFFFF",
    bandMuted: "rgba(255,255,255,0.88)",
    bandAccent: "var(--color-navy-900)",
  },
  "creative-and-content": {
    accent: "var(--color-coral)",
    band: "var(--color-warm-100)",
    bandText: "var(--color-navy-900)",
    bandMuted: "var(--color-text-on-light-muted)",
    bandAccent: "var(--color-coral)",
  },
  web: {
    accent: "var(--color-mint)",
    band: "var(--color-teal-700)",
    bandText: "#FFFFFF",
    bandMuted: "var(--color-teal-200)",
    bandAccent: "var(--color-mint)",
  },
};
const t = treatments[cluster] ?? treatments["web"];

const breadcrumbs = isClusterParent
  ? [
      { name: "Home", url: "/" },
      { name: "Services", url: "/services/" },
      { name, url: pageUrl },
    ]
  : [
      { name: "Home", url: "/" },
      { name: "Services", url: "/services/" },
      { name: cluster.replace(/-/g, " "), url: `/services/${cluster}/` },
      { name, url: pageUrl },
    ];
---

<Layout title={title} description={metaDescription}>
  <BreadcrumbSchema items={breadcrumbs} />
  <ServiceSchema name={name} description={metaDescription} url={pageUrl} />

  <!-- Hero: full-bleed image with overlay + uppercase label -->
  <section class="svc-hero" style={`--hero-img:url('${heroBg}');`}>
    <div class="svc-hero__inner mx-auto max-w-[1280px] px-6 md:px-12">
      <p class="svc-hero__eyebrow">{heroEyebrow ?? name}</p>
      <h1 class="svc-hero__title">{heroHeading}</h1>
      <p class="svc-hero__body">{heroBody}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <BtnFiller href={`/contact/?service=${slug}#contact`} variant="solid-white">
          Talk to us about {name.toLowerCase()}
        </BtnFiller>
        <BtnFiller href="/work/" variant="on-dark">See selected work</BtnFiller>
      </div>
    </div>
  </section>

  <!-- Big statement band -->
  <section class="svc-statement" style={`background:${t.band};color:${t.bandText};`}>
    <div class="mx-auto max-w-[1200px] px-6 md:px-12 py-20 md:py-28">
      <p class="svc-statement__label" style={`color:${t.bandAccent};`}>Why it matters</p>
      <p class="svc-statement__text">{summary}</p>
    </div>
  </section>

  <!-- What it is -->
  <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-16 md:py-24 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
    <div class="md:col-span-4">
      <p class="svc-eyebrow" style={`color:${t.accent};`}>What it is</p>
      <h2 class="svc-h2 mt-2">How we approach {name.toLowerCase()}</h2>
    </div>
    <div class="md:col-span-8 max-w-2xl">
      <p style="font-family:var(--font-sans);font-size:1.125rem;color:var(--color-text-on-dark-muted);line-height:1.7;">
        {whatItIs}
      </p>
    </div>
  </section>

  {whatsIncluded.length > 0 && (
    <!-- Scope as a capability grid -->
    <section class="mx-auto max-w-[1280px] px-6 md:px-12 py-12 md:py-20">
      <p class="svc-eyebrow" style={`color:${t.accent};`}>What's included</p>
      <h2 class="svc-h2 svc-h2--caps mt-2 mb-10 md:mb-14 max-w-3xl">Everything {name.toLowerCase()} should cover</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0 m-0">
        {whatsIncluded.map((it, i) => (
          <li class="svc-cap p-6">
            <span class="svc-cap__num" style={`color:${t.accent};`}>{String(i + 1).padStart(2, "0")}</span>
            <p class="svc-cap__label">{it}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {process.length > 0 && (
    <section style={`background:${t.band};color:${t.bandText};`}>
      <div class="mx-auto max-w-[1100px] px-6 md:px-12 py-16 md:py-24">
        <p class="svc-eyebrow" style={`color:${t.bandAccent};`}>How we work</p>
        <h2 class="svc-h2 mt-2 mb-12" style={`color:${t.bandText};`}>Process</h2>
        <ol class="grid grid-cols-1 md:grid-cols-2 gap-10 list-none p-0 m-0">
          {process.map((p) => (
            <li class="flex gap-5">
              <p style={`font-family:var(--font-display);font-size:clamp(2.5rem,5vw,3.5rem);color:${t.bandAccent};line-height:1;flex-shrink:0;`}>{p.step}</p>
              <div>
                <h3 style={`font-family:var(--font-display);font-size:1.5rem;color:${t.bandText};line-height:1.2;`}>{p.label}</h3>
                <p class="mt-2 max-w-md" style={`font-family:var(--font-sans);font-size:1rem;color:${t.bandMuted};line-height:1.6;`}>{p.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  {caseStudies.length > 0 && (
    <!-- Results imagery -->
    <section class="mx-auto max-w-[1280px] px-6 md:px-12 py-16 md:py-24">
      <p class="svc-eyebrow" style={`color:${t.accent};`}>Proof</p>
      <h2 class="svc-h2 svc-h2--caps mt-2 mb-10 md:mb-14">Results we're proud of</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
        {caseStudies.map((cs) => (
          <a
            href={`/work/${cs.slug}/`}
            class="svc-shot block overflow-hidden"
            style="border-radius:var(--radius-card-lg);text-decoration:none;"
          >
            <figure class="svc-shot__fig" style="aspect-ratio:4/3;">
              <img src={cs.heroImage} alt={cs.name} loading="lazy" decoding="async" />
              <figcaption class="svc-shot__cap">
                <span style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;opacity:0.85;">Case study</span>
                <span style="font-family:var(--font-display);font-size:1.15rem;line-height:1.15;">{cs.name}</span>
              </figcaption>
            </figure>
          </a>
        ))}
      </div>
    </section>
  )}

  {sectorsThatBuy.length > 0 && (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16">
      <p class="svc-eyebrow" style={`color:${t.accent};`}>Where this lands</p>
      <h2 class="svc-h2 mt-2 mb-8">Sectors that buy {name.toLowerCase()}</h2>
      <ul class="flex flex-wrap gap-3 list-none p-0 m-0">
        {sectorsThatBuy.map((sec) => (
          <li>
            <a
              href={`/sectors/${sec}/`}
              class="inline-flex items-center px-5 py-3 transition-colors"
              style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:9999px;color:var(--color-text-on-dark);font-family:var(--font-sans);font-size:0.95rem;text-decoration:none;"
            >
              {sec.replace(/-/g, " ").replace(/\b\w/g, (m) => m.toUpperCase())}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {relatedServices.length > 0 && (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16">
      <p class="svc-eyebrow" style={`color:${t.accent};`}>Often paired with</p>
      <h2 class="svc-h2 mt-2 mb-8">Related services</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0 m-0">
        {relatedServices.map((rs) => (
          <li>
            <a
              href={`/services/${rs}/`}
              class="svc-card block p-5"
              style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-card-md);color:var(--color-text-on-dark);text-decoration:none;"
            >
              <p style="font-family:var(--font-display);font-size:1.25rem;line-height:1.2;">{rs.replace(/-/g, " ").replace(/\b\w/g, (m) => m.toUpperCase())}</p>
              <p class="svc-card__cta mt-2" style={`font-family:var(--font-sans);font-size:0.875rem;color:${t.accent};`}>Explore →</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {faq.length > 0 && (
    <FAQBlock faqs={faq} heading={`${name} questions`} eyebrow="FAQ" />
  )}

  <!-- Giant wordmark -->
  <div class="svc-wordmark" aria-hidden="true">Rooftop Twenty Two</div>

  <PageCTA variant="service" service={slug} />
</Layout>

<style>
  /* Shared section type */
  .svc-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .svc-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    color: var(--color-text-on-dark);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .svc-h2--caps {
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }

  /* Hero */
  .svc-hero {
    position: relative;
    min-height: 62vh;
    display: flex;
    align-items: flex-end;
    padding: clamp(3rem, 8vh, 6rem) 0;
    background-image: linear-gradient(
        to top,
        rgba(13, 32, 48, 0.94) 0%,
        rgba(13, 32, 48, 0.6) 45%,
        rgba(13, 32, 48, 0.55) 100%
      ),
      var(--hero-img);
    background-size: cover;
    background-position: center;
  }
  .svc-hero__inner {
    width: 100%;
  }
  .svc-hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mint);
    margin-bottom: 1.25rem;
  }
  .svc-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    color: var(--color-text-on-dark);
    letter-spacing: -0.025em;
    line-height: 0.98;
    max-width: 18ch;
  }
  .svc-hero__body {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    color: var(--color-text-on-dark-muted);
    line-height: 1.55;
    max-width: 42rem;
    margin-top: 1.5rem;
  }

  /* Statement band */
  .svc-statement__label {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .svc-statement__text {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.2vw, 3.5rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    max-width: 22ch;
  }

  /* Capability grid */
  .svc-cap {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-card-md);
    transition: transform 0.25s ease, background 0.25s ease;
  }
  .svc-cap:hover {
    transform: translateY(-6px);
    background: rgba(255, 255, 255, 0.06);
  }
  .svc-cap__num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1;
    display: block;
  }
  .svc-cap__label {
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.2;
    color: var(--color-text-on-dark);
    margin-top: 0.75rem;
  }

  /* Imagery */
  .svc-shot__fig {
    position: relative;
    margin: 0;
    width: 100%;
  }
  .svc-shot__fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .svc-shot:hover .svc-shot__fig img {
    transform: scale(1.04);
  }
  .svc-shot__cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1rem 1.1rem;
    color: #fff;
    background: linear-gradient(to top, rgba(13, 32, 48, 0.85), rgba(13, 32, 48, 0));
  }

  /* Related cards */
  .svc-card {
    transition: transform 0.25s ease;
  }
  .svc-card:hover {
    transform: translateY(-6px);
  }
  .svc-card__cta {
    transition: transform 0.25s ease;
  }
  .svc-card:hover .svc-card__cta {
    transform: translateX(4px);
  }

  /* Giant wordmark */
  .svc-wordmark {
    font-family: var(--font-display);
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    font-size: clamp(3rem, 13vw, 12rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.14);
    padding: 2rem 0 0.5rem;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-shot:hover .svc-shot__fig img { transform: none; }
    .svc-card:hover, .svc-cap:hover { transform: none; }
  }
</style>
