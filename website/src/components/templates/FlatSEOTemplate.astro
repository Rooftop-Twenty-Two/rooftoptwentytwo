---
import Layout from "../../layouts/Layout.astro";
import Signature from "../Signature.astro";
import BtnFiller from "../BtnFiller.astro";
import FAQBlock from "../FAQBlock.astro";
import PageCTA from "../PageCTA.astro";
import BreadcrumbSchema from "../seo/BreadcrumbSchema.astro";

type FAQ = { question: string; answer: string };

interface Props {
  slug: string;
  h1: string;
  metaTitle: string;
  metaDescription: string;
  headTerm: string;
  location?: string;
  relatedSectorSlug?: string;
  relatedServiceSlug?: string;
  subHeroBody: string;
  whatWeDo: string;
  trustLogos: string[];
  caseStudySlugs: string[];
  faq: FAQ[];
}

const {
  slug,
  h1,
  metaTitle,
  metaDescription,
  headTerm,
  location,
  relatedSectorSlug,
  relatedServiceSlug,
  subHeroBody,
  whatWeDo,
  trustLogos,
  caseStudySlugs,
  faq,
} = Astro.props;

const pageUrl = `/${slug}/`;

const contactQS: string[] = [];
if (relatedServiceSlug) contactQS.push(`service=${relatedServiceSlug}`);
if (relatedSectorSlug) contactQS.push(`sector=${relatedSectorSlug}`);
const contactHref = `/contact/${contactQS.length ? `?${contactQS.join("&")}` : ""}#contact`;
---

<Layout title={metaTitle} description={metaDescription} hidePreFooterCTA={false}>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: h1, url: pageUrl }]} />

  <section class="mx-auto max-w-[1200px] px-6 md:px-12 pt-12 md:pt-20 pb-16 md:pb-24">
    <Signature text={location ?? headTerm} tone="coral" rotate={-3} size="clamp(2rem, 3.5vw, 3rem)" />
    <h1
      class="mt-4 max-w-4xl"
      style="font-family:var(--font-display);font-size:clamp(2.75rem, 7vw, 5.5rem);color:var(--color-text-on-dark);letter-spacing:-0.02em;line-height:1.05;"
    >
      {h1}
    </h1>
    <p
      class="mt-6 max-w-2xl"
      style="font-family:var(--font-sans);font-size:1.25rem;color:var(--color-text-on-dark-muted);line-height:1.55;"
    >
      {subHeroBody}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <BtnFiller href={contactHref} variant="solid-white">Start a conversation</BtnFiller>
      <BtnFiller href="/work/" variant="on-dark">See selected work</BtnFiller>
    </div>
  </section>

  <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
    <div class="md:col-span-4">
      <p style="font-family:var(--font-sans);font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">What we do</p>
      <h2
        class="mt-2"
        style="font-family:var(--font-display);font-size:clamp(1.75rem, 3vw, 2.5rem);color:var(--color-text-on-dark);line-height:1.15;letter-spacing:-0.01em;"
      >
        How we work with you
      </h2>
    </div>
    <p class="md:col-span-8 max-w-2xl" style="font-family:var(--font-sans);font-size:1.125rem;color:var(--color-text-on-dark-muted);line-height:1.7;">{whatWeDo}</p>
  </section>

  {trustLogos.length > 0 && (
    <section class="mx-auto max-w-[1200px] px-6 md:px-12 py-8">
      <p class="mb-6" style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">
        Trusted by
      </p>
      <ul class="flex flex-wrap items-center gap-x-10 gap-y-6 list-none p-0 m-0" style="opacity:0.7;">
        {trustLogos.map((src) => (
          <li>
            <img src={src} alt="" loading="lazy" decoding="async" style="height:32px;width:auto;filter:brightness(0) invert(1);" />
          </li>
        ))}
      </ul>
    </section>
  )}

  {(relatedServiceSlug || relatedSectorSlug) && (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16">
      <p style="font-family:var(--font-sans);font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">Go deeper</p>
      <ul class="mt-6 flex flex-wrap gap-3 list-none p-0 m-0">
        {relatedServiceSlug && (
          <li>
            <a
              href={`/services/${relatedServiceSlug}/`}
              class="inline-flex items-center px-5 py-3"
              style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:9999px;color:var(--color-text-on-dark);font-family:var(--font-sans);font-size:0.95rem;text-decoration:none;"
            >
              Service: {relatedServiceSlug.replace(/-/g, " ")}
            </a>
          </li>
        )}
        {relatedSectorSlug && (
          <li>
            <a
              href={`/sectors/${relatedSectorSlug}/`}
              class="inline-flex items-center px-5 py-3"
              style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:9999px;color:var(--color-text-on-dark);font-family:var(--font-sans);font-size:0.95rem;text-decoration:none;"
            >
              Sector: {relatedSectorSlug.replace(/-/g, " ")}
            </a>
          </li>
        )}
      </ul>
    </section>
  )}

  {faq.length > 0 && <FAQBlock faqs={faq} eyebrow="FAQ" />}

  <PageCTA
    variant={relatedSectorSlug ? "sector" : relatedServiceSlug ? "service" : "default"}
    sector={relatedSectorSlug}
    service={relatedServiceSlug}
  />
</Layout>
