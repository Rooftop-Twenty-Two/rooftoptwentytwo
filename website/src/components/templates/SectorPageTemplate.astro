---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Signature from "../Signature.astro";
import BtnFiller from "../BtnFiller.astro";
import FAQBlock from "../FAQBlock.astro";
import PageCTA from "../PageCTA.astro";
import BreadcrumbSchema from "../seo/BreadcrumbSchema.astro";

type FAQ = { question: string; answer: string };

interface Props {
  name: string;
  slug: string;
  summary: string;
  metaDescription: string;
  heroEyebrow?: string;
  heroHeading: string;
  heroBody: string;
  challenges: string[];
  pointOfView?: string;
  serviceSlugs: string[];
  programmeSlugs: string[];
  caseStudySlugs: string[];
  aggregateMetrics: { value: string; label: string }[];
  faq: FAQ[];
}

const {
  name,
  slug,
  summary,
  metaDescription,
  heroEyebrow,
  heroHeading,
  heroBody,
  challenges,
  pointOfView,
  serviceSlugs,
  programmeSlugs,
  caseStudySlugs,
  aggregateMetrics,
  faq,
} = Astro.props;

const pageUrl = `/sectors/${slug}/`;
const title = `${name} | Rooftop Twenty Two`;
const titleCase = (s: string) =>
  s.replace(/-/g, " ").replace(/\b\w/g, (m) => m.toUpperCase());

// Load + filter the case studies referenced by this sector. Preserves the
// order declared in caseStudySlugs so the page author controls priority.
const portfolio = await getCollection("portfolio", ({ data }) => !data.needs_review);
const caseStudies = caseStudySlugs
  .map((s) => portfolio.find((e) => e.id.replace(/\.mdx?$/, "") === s))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));
---

<Layout title={title} description={metaDescription}>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: "/" },
      { name: "Sectors", url: "/sectors/" },
      { name, url: pageUrl },
    ]}
  />

  <section class="mx-auto max-w-[1200px] px-6 md:px-12 pt-12 md:pt-20 pb-16 md:pb-24">
    {heroEyebrow && <Signature text={heroEyebrow} tone="coral" rotate={-3} size="clamp(2rem, 3.5vw, 3rem)" />}
    <h1
      class="mt-4 max-w-4xl"
      style="font-family:var(--font-display);font-size:clamp(2.75rem, 7vw, 5.5rem);color:var(--color-text-on-dark);letter-spacing:-0.02em;line-height:1.05;"
    >
      {heroHeading}
    </h1>
    <p
      class="mt-6 max-w-2xl"
      style="font-family:var(--font-sans);font-size:1.25rem;color:var(--color-text-on-dark-muted);line-height:1.55;"
    >
      {heroBody}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <BtnFiller href={`/contact/?sector=${slug}#contact`} variant="solid-white">
        Talk to us about {name.toLowerCase()}
      </BtnFiller>
      <BtnFiller href="/work/" variant="on-dark">See selected work</BtnFiller>
    </div>
  </section>

  {aggregateMetrics.length > 0 && (
    <section class="mx-auto max-w-[1200px] px-6 md:px-12 py-8">
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-6 list-none p-0 m-0">
        {aggregateMetrics.map((m) => (
          <li>
            <p style="font-family:var(--font-display);font-size:clamp(2rem, 3.5vw, 3rem);color:var(--color-mint);line-height:1;">{m.value}</p>
            <p class="mt-2" style="font-family:var(--font-sans);font-size:0.875rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">{m.label}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {challenges.length > 0 && (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4">
        <p style="font-family:var(--font-sans);font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">Common challenges</p>
        <h2
          class="mt-2"
          style="font-family:var(--font-display);font-size:clamp(1.75rem, 3vw, 2.5rem);color:var(--color-text-on-dark);line-height:1.15;letter-spacing:-0.01em;"
        >
          What we see in {name.toLowerCase()}
        </h2>
      </div>
      <ul class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 list-none p-0 m-0" style="font-family:var(--font-sans);font-size:1.0625rem;color:var(--color-text-on-dark);">
        {challenges.map((c) => (
          <li class="flex gap-3">
            <span style="color:var(--color-coral);flex-shrink:0;">→</span>
            <span>{c}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {pointOfView && (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4">
        <p style="font-family:var(--font-sans);font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">Our point of view</p>
        <h2
          class="mt-2"
          style="font-family:var(--font-display);font-size:clamp(1.75rem, 3vw, 2.5rem);color:var(--color-text-on-dark);line-height:1.15;letter-spacing:-0.01em;"
        >
          How we approach {name.toLowerCase()}
        </h2>
      </div>
      <p class="md:col-span-8 max-w-2xl" style="font-family:var(--font-sans);font-size:1.125rem;color:var(--color-text-on-dark-muted);line-height:1.7;">{pointOfView}</p>
    </section>
  )}

  {serviceSlugs.length > 0 && (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16">
      <p style="font-family:var(--font-sans);font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">Services that fit</p>
      <h2
        class="mt-2 mb-8"
        style="font-family:var(--font-display);font-size:clamp(1.75rem, 3vw, 2.5rem);color:var(--color-text-on-dark);line-height:1.15;letter-spacing:-0.01em;"
      >
        How we typically engage with {name.toLowerCase()}
      </h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0 m-0">
        {serviceSlugs.map((s) => (
          <li>
            <a
              href={`/services/${s}/`}
              class="block p-5 transition-transform hover:-translate-y-1"
              style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-card-md);color:var(--color-text-on-dark);text-decoration:none;"
            >
              <p style="font-family:var(--font-display);font-size:1.25rem;line-height:1.2;">{titleCase(s)}</p>
              <p class="mt-2" style="font-family:var(--font-sans);font-size:0.875rem;color:var(--color-text-on-dark-muted);">Explore →</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {caseStudies.length > 0 && (
    <section class="mx-auto max-w-[1280px] px-6 md:px-12 py-12 md:py-16">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">Selected work</p>
          <h2
            class="mt-2"
            style="font-family:var(--font-display);font-size:clamp(1.75rem, 3vw, 2.5rem);color:var(--color-text-on-dark);line-height:1.15;letter-spacing:-0.01em;"
          >
            What we've shipped in {name.toLowerCase()}
          </h2>
        </div>
        <a
          href="/work/"
          style="font-family:var(--font-sans);font-size:0.95rem;color:var(--color-mint);font-weight:600;text-decoration:none;"
        >
          View all projects →
        </a>
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 list-none p-0 m-0">
        {caseStudies.slice(0, 6).map((e) => {
          const cslug = e.id.replace(/\.mdx?$/, "");
          const svcs = (e.data.services ?? []).slice(0, 2);
          return (
            <li>
              <a
                href={`/work/${cslug}/`}
                class="block group"
                style="text-decoration:none;color:var(--color-text-on-dark);"
              >
                <div
                  class="relative overflow-hidden"
                  style={`border-radius:var(--radius-card-md);aspect-ratio:4/3;background-color:var(--color-navy-700);${
                    e.data.heroImage ? `background-image:url('${e.data.heroImage}');background-size:cover;background-position:center;` : ""
                  }`}
                >
                  {e.data.wordmark && (
                    <div class="absolute inset-0 flex items-center justify-center">
                      <img
                        src={e.data.wordmark}
                        alt={`${e.data.name} wordmark`}
                        loading="lazy"
                        decoding="async"
                        style="max-width:55%;max-height:60px;width:auto;height:auto;object-fit:contain;filter:drop-shadow(0 4px 12px rgba(0,0,0,0.25));"
                      />
                    </div>
                  )}
                  <div
                    class="absolute inset-0"
                    style="background:linear-gradient(180deg, rgba(0,0,0,0.0) 0%, rgba(0,0,0,0.0) 50%, rgba(0,0,0,0.2) 100%);pointer-events:none;"
                  ></div>
                </div>
                <div class="mt-4">
                  <p style="font-family:var(--font-display);font-size:1.25rem;line-height:1.15;letter-spacing:-0.01em;">{e.data.name}</p>
                  {e.data.tagline && (
                    <p class="mt-1" style="font-family:var(--font-sans);font-size:0.9rem;color:var(--color-text-on-dark-muted);line-height:1.45;">{e.data.tagline}</p>
                  )}
                  {svcs.length > 0 && (
                    <p class="mt-2" style="font-family:var(--font-sans);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-on-dark-muted);">{svcs.join(" · ")}</p>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {programmeSlugs.length > 0 && (
    <section class="mx-auto max-w-[1100px] px-6 md:px-12 py-12 md:py-16">
      <p style="font-family:var(--font-sans);font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-mint);">Enterprise Ireland funded</p>
      <h2
        class="mt-2"
        style="font-family:var(--font-display);font-size:clamp(1.75rem, 3vw, 2.5rem);color:var(--color-text-on-dark);line-height:1.15;letter-spacing:-0.01em;"
      >
        Funded programmes for {name.toLowerCase()}
      </h2>
      <ul class="mt-6 flex flex-wrap gap-3 list-none p-0 m-0">
        {programmeSlugs.map((p) => (
          <li>
            <a
              href={`/programmes/${p}/`}
              class="inline-flex items-center px-5 py-3"
              style="background:var(--color-mint);color:var(--color-navy-900);border-radius:9999px;font-family:var(--font-sans);font-weight:600;font-size:0.95rem;text-decoration:none;"
            >
              {titleCase(p)}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {faq.length > 0 && <FAQBlock faqs={faq} heading={`${name} questions`} eyebrow="FAQ" />}

  <PageCTA variant="sector" sector={slug} />
</Layout>
