---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../reskin/PageHero.astro";
import WCtaBand from "../reskin/WCtaBand.astro";
import Picture from "../Picture.astro";
import BreadcrumbSchema from "../seo/BreadcrumbSchema.astro";

type FAQ = { question: string; answer: string };

interface Props {
  name: string;
  slug: string;
  summary: string;
  metaDescription: string;
  heroEyebrow?: string;
  heroHeading: string;
  heroBody: string;
  challenges: string[];
  pointOfView?: string;
  serviceSlugs: string[];
  programmeSlugs: string[];
  caseStudySlugs: string[];
  aggregateMetrics: { value: string; label: string }[];
  faq: FAQ[];
}

const {
  name, slug, metaDescription, heroEyebrow, heroHeading, heroBody,
  challenges, pointOfView, serviceSlugs, programmeSlugs, caseStudySlugs,
  aggregateMetrics, faq,
} = Astro.props;

const pageUrl = `/sectors/${slug}/`;
const title = `${name} | Rooftop Twenty Two`;
const lower = name.toLowerCase();
const titleCase = (s: string) => s.replace(/-/g, " ").replace(/\b\w/g, (m) => m.toUpperCase());

const portfolio = await getCollection("portfolio", ({ data }) => !data.needs_review);
const caseStudies = caseStudySlugs
  .map((s) => portfolio.find((e) => e.id.replace(/\.mdx?$/, "") === s))
  .filter((e): e is NonNullable<typeof e> => Boolean(e && e.data.heroImage))
  .slice(0, 6);
---

<Layout title={title} description={metaDescription}>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Sectors", url: "/sectors/" }, { name, url: pageUrl }]} />

  <PageHero
    kicker={heroEyebrow ?? "Sectors"}
    title={heroHeading}
    intro={heroBody}
    primary={{ label: `Talk to us about ${lower}`, href: `/contact/?sector=${slug}#contact` }}
    secondary={{ label: "See selected work", href: "/work/" }}
  />

  {aggregateMetrics.length > 0 && (
    <section class="se-stats">
      <div class="se-stats__inner">
        <ul class="se-stats__grid">
          {aggregateMetrics.map((m) => (
            <li>
              <span class="se-stats__v">{m.value}</span>
              <span class="se-stats__l">{m.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {challenges.length > 0 && (
    <section class="se-block">
      <div class="se-block__inner">
        <div class="se-block__head reveal">
          <p class="kicker kicker--script">Common challenges</p>
          <h2 class="se-h2">What we see in {lower}.</h2>
        </div>
        <ul class="se-chal">
          {challenges.map((c) => <li class="reveal">{c}</li>)}
        </ul>
      </div>
    </section>
  )}

  {pointOfView && (
    <section class="se-block se-block--alt">
      <div class="se-block__inner">
        <div class="se-block__head reveal">
          <p class="kicker kicker--script">Our point of view</p>
          <h2 class="se-h2">How we approach {lower}.</h2>
        </div>
        <p class="se-pov reveal">{pointOfView}</p>
      </div>
    </section>
  )}

  {serviceSlugs.length > 0 && (
    <section class="se-svc">
      <div class="se-svc__inner">
        <p class="kicker kicker--script">Services that fit</p>
        <h2 class="se-h2 se-mb">How we typically work with {lower}.</h2>
        <ul class="se-svc__grid">
          {serviceSlugs.map((s) => (
            <li class="reveal">
              <a class="se-svc__card" href={`/services/${s}/`}>
                <span class="se-svc__name">{titleCase(s)}</span>
                <span class="se-svc__cta r22-arrow">Explore <span class="r22-arrow__i" aria-hidden="true">&rarr;</span></span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {caseStudies.length > 0 && (
    <section class="se-work">
      <div class="se-work__inner">
        <div class="se-work__top">
          <div>
            <p class="kicker kicker--script">Selected work</p>
            <h2 class="se-h2">What we&rsquo;ve shipped in {lower}.</h2>
          </div>
          <a href="/work/" class="wbtn wbtn--primary se-work__all">View all projects</a>
        </div>
        <ul class="se-work__grid">
          {caseStudies.map((e) => {
            const cslug = e.id.replace(/\.mdx?$/, "");
            const svcs = (e.data.services ?? []).slice(0, 2);
            return (
              <li class="reveal">
                <a href={`/work/${cslug}/`}>
                  <figure class="se-work__img r22-media"><Picture src={e.data.heroImage!} alt={e.data.name} loading="lazy" decoding="async" /></figure>
                  <span class="se-work__name">{e.data.name}</span>
                  {e.data.tagline && <span class="se-work__tag">{e.data.tagline}</span>}
                  {svcs.length > 0 && <span class="se-work__svcs">{svcs.join(" · ")}</span>}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  {programmeSlugs.length > 0 && (
    <section class="se-prog">
      <div class="se-prog__inner">
        <p class="kicker kicker--on-dark kicker--script">Enterprise Ireland funded</p>
        <h2 class="se-h2 se-prog__h">Funded programmes for {lower}.</h2>
        <ul class="se-prog__pills">
          {programmeSlugs.map((p) => (
            <li><a href={`/programmes/${p}/`}>{titleCase(p)}</a></li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {faq.length > 0 && (
    <section class="se-faq">
      <div class="se-faq__inner">
        <div class="se-faq__main">
          <p class="kicker kicker--script">FAQ</p>
          <h2 class="se-h2 se-mb">{name} questions.</h2>
          <ul class="se-faq__list">
            {faq.map((f) => (
              <li class="reveal">
                <h3 class="se-faq__q">{f.question}</h3>
                <p class="se-faq__a">{f.answer}</p>
              </li>
            ))}
          </ul>
        </div>
        <aside class="se-faq__aside reveal">
          <div class="se-faq__card">
            <p class="kicker kicker--on-dark">Still have questions?</p>
            <p class="se-faq__card-h">Talk to the team that does the work.</p>
            <p class="se-faq__card-b">No notes passed between account managers. You speak to the people running your {lower} marketing.</p>
            <a href={`/contact/?sector=${slug}#contact`} class="wbtn wbtn--accent">Talk to us about {lower}</a>
          </div>
        </aside>
      </div>
    </section>
  )}

  <WCtaBand />
</Layout>

<style>
  .se-h2 { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h2); line-height: var(--lh-heading); letter-spacing: var(--tracking-display); color: var(--c-ink); margin: 0.4rem 0 0; }
  .se-h2 em { font-style: italic; color: var(--c-accent); }
  .se-mb { margin-bottom: 2.5rem; }

  /* Stats band */
  .se-stats { background: var(--c-dark); color: var(--c-on-dark); padding-block: clamp(2.5rem, 5vw, 4rem); }
  .se-stats__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .se-stats__grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  @media (min-width: 760px) { .se-stats__grid { grid-template-columns: repeat(4, 1fr); } }
  .se-stats__v { display: block; font-family: var(--w-font-display); font-weight: 700; font-size: clamp(2.2rem, 4vw, 3.25rem); line-height: 1; color: var(--c-accent-2-bright); }
  .se-stats__l { display: block; font-family: var(--w-font-body); font-size: 0.85rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--c-on-dark-soft); margin-top: 0.6rem; }

  /* Text blocks (challenges / POV) */
  .se-block { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); }
  .se-block--alt { background: var(--c-bg-alt); }
  .se-block__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) { .se-block__inner { grid-template-columns: 0.8fr 1.2fr; gap: 4rem; } }
  .se-chal { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 600px) { .se-chal { grid-template-columns: 1fr 1fr; gap: 1rem 2.5rem; } }
  .se-chal li { position: relative; padding-left: 1.6rem; font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); line-height: 1.5; }
  .se-chal li::before { content: ""; position: absolute; left: 0; top: 0.5em; width: 0.6rem; height: 0.6rem; border-radius: 0 100% 0 0; background: var(--c-accent); }
  .se-pov { font-family: var(--w-font-body); font-size: 1.15rem; line-height: 1.7; color: var(--c-ink-soft); margin: 0; max-width: 60ch; }

  /* Services that fit */
  .se-svc { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); }
  .se-svc__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .se-svc__grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 600px) { .se-svc__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 920px) { .se-svc__grid { grid-template-columns: repeat(3, 1fr); } }
  .se-svc__card { display: flex; flex-direction: column; gap: 0.75rem; height: 100%; background: var(--c-bg-alt); border: 1px solid var(--c-line); border-radius: var(--w-radius); padding: 1.5rem; text-decoration: none; transition: transform var(--w-dur) var(--w-ease); }
  .se-svc__card:hover { transform: translateY(-3px); }
  .se-svc__name { font-family: var(--w-font-display); font-weight: 600; font-size: 1.2rem; color: var(--c-ink); }
  .se-svc__cta { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--w-font-body); font-weight: 600; font-size: 0.9rem; color: var(--c-accent); margin-top: auto; }

  /* Case studies */
  .se-work { background: var(--c-bg-alt); color: var(--c-ink); padding-block: var(--w-section-y); }
  .se-work__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .se-work__top { display: flex; flex-wrap: wrap; align-items: end; justify-content: space-between; gap: 1.25rem; margin-bottom: 2.5rem; }
  .se-work__all { white-space: nowrap; }
  .se-work__grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 2.5rem 1.75rem; }
  @media (min-width: 640px) { .se-work__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .se-work__grid { grid-template-columns: repeat(3, 1fr); } }
  .se-work__grid a { text-decoration: none; color: inherit; display: block; }
  .se-work__img { margin: 0; border: 1px solid var(--c-line); border-radius: var(--w-radius); overflow: hidden; aspect-ratio: 4 / 3; box-shadow: var(--w-shadow-soft); }
  .se-work__img :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .se-work__name { display: block; font-family: var(--w-font-display); font-weight: 600; font-size: 1.25rem; margin-top: 1rem; }
  .se-work__tag { display: block; font-family: var(--w-font-body); font-size: 0.95rem; color: var(--c-ink-soft); margin-top: 0.3rem; line-height: 1.4; }
  .se-work__svcs { display: block; font-family: var(--w-font-body); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--c-ink-soft); margin-top: 0.5rem; }

  /* Programmes */
  .se-prog { background: var(--c-dark); color: var(--c-on-dark); padding-block: var(--w-section-y); }
  .se-prog__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .se-prog__h { color: var(--c-on-dark); }
  .se-prog__pills { list-style: none; margin: 1.75rem 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .se-prog__pills a { display: inline-flex; align-items: center; padding: 0.6rem 1.25rem; border-radius: var(--radius-pill); background: var(--c-accent-2); color: var(--c-ink); font-family: var(--w-font-body); font-weight: 600; font-size: 0.95rem; text-decoration: none; transition: transform var(--w-dur-fast) var(--w-ease); }
  .se-prog__pills a:hover { transform: translateY(-2px); }

  /* FAQ */
  .se-faq { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); }
  .se-faq__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 940px) { .se-faq__inner { grid-template-columns: 1.5fr 1fr; gap: 4rem; align-items: start; } }
  .se-faq__list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--c-line); }
  .se-faq__list li { padding: 1.5rem 0; border-bottom: 1px solid var(--c-line); }
  .se-faq__q { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h3); color: var(--c-ink); margin: 0; }
  .se-faq__a { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); line-height: 1.65; margin: 0.6rem 0 0; }
  @media (min-width: 940px) { .se-faq__aside { position: sticky; top: 6rem; } }
  .se-faq__card { background: var(--c-dark); color: var(--c-on-dark); border-radius: var(--w-radius); padding: clamp(1.75rem, 3vw, 2.5rem); }
  .se-faq__card-h { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h3); color: var(--c-on-dark); margin: 0.75rem 0 0; }
  .se-faq__card-b { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-on-dark-soft); line-height: 1.6; margin: 0.75rem 0 1.5rem; }
</style>
