---
// Source-faithful "Our Work" preview. Full-width 4-column grid of vertical
// scrolling brand-element imagery flows behind a centred, sticky-positioned
// heading + View Projects pill (with a subtle glass backdrop for legibility).
//
// Heading sits in the centre of the section; columns at the very edges bleed
// off-screen. No more 2-col layout pushing imagery to the right "sidebar".

import Signature from "./Signature.astro";
import BtnFiller from "./BtnFiller.astro";

type Tile = { src: string; alt: string };

const col1: Tile[] = [
  { src: "/images/work-preview/Nostra_Elements_2.png", alt: "Nostra brand work" },
  { src: "/images/work-preview/Nostra_Elements_3.png", alt: "Nostra brand work" },
  { src: "/images/work-preview/GFP_Elements_2.png", alt: "Gourmet Food Parlour elements" },
  { src: "/images/work-preview/GFP_Header.png", alt: "Gourmet Food Parlour" },
  { src: "/images/work-preview/TCMatthews_2.png", alt: "TC Matthews brand work" },
  { src: "/images/work-preview/TCMatthews_3.png", alt: "TC Matthews brand work" },
];

const col2: Tile[] = [
  { src: "/images/work-preview/ILT_Element_3.png", alt: "Irish Landmark Trust" },
  { src: "/images/work-preview/ILT_Element_2.png", alt: "Irish Landmark Trust" },
  { src: "/images/work-preview/Image-for-featured-Heritage-project-1.jpg", alt: "Joseph May heritage project" },
  { src: "/images/work-preview/1933_Element-34-1-1.png", alt: "The 1933 Furniture Company" },
];

const col3: Tile[] = [
  { src: "/images/work-preview/1933_Element-18-1.png", alt: "The 1933 Furniture Company" },
  { src: "/images/work-preview/ILT_Element-8.png", alt: "Irish Landmark Trust" },
  { src: "/images/work-preview/ILT_Header.png", alt: "Irish Landmark Trust" },
  { src: "/images/work-preview/GFP_Header.png", alt: "Gourmet Food Parlour" },
  { src: "/images/work-preview/1933_Element_3.png", alt: "The 1933 Furniture Company" },
];

const col4: Tile[] = [
  { src: "/images/work-preview/Dolphin-scaled-1.jpg", alt: "Dolphin project" },
  { src: "/images/work-preview/JM_Element_7-1.png", alt: "Joseph May" },
  { src: "/images/work-preview/ILT_Element_1.png", alt: "Irish Landmark Trust" },
  { src: "/images/work-preview/ILT_Element_5.png", alt: "Irish Landmark Trust" },
];

const allCols = [col1, col2, col3, col4];
const durations = ["62s", "48s", "82s", "54s"];
---

<section class="work-preview">
  <!-- Curved top divider: filled page-bg navy, sits above the imagery so the
       columns appear masked by a wavy top edge. Matches source's
       curve-asymmetrical shape_divider_top behaviour. -->
  <svg
    class="work-preview__divider-top"
    viewBox="0 0 1000 100"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path d="M615.2,96.7C240.2,97.8,0,18.9,0,0v100h1000V0C1000,19.2,989.8,96,615.2,96.7z" />
  </svg>

  <!-- Subtle dark overlay over the imagery for legibility of the centered
       heading. Sits above the columns (z:0) but below the heading (z:4). -->
  <div class="work-preview__overlay" aria-hidden="true"></div>

  <div class="work-preview__columns" aria-hidden="true">
    {allCols.map((col, i) => (
      <div class:list={["vmarquee", i === 3 ? "hidden lg:block" : ""]}>
        <div
          class:list={["vmarquee-track", i % 2 === 1 ? "vmarquee-track--reverse" : ""]}
          style={`--duration:${durations[i]};`}
        >
          {[...col, ...col].map((t) => (
            <figure>
              <img src={t.src} alt={t.alt} loading="lazy" decoding="async" />
            </figure>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="work-preview__heading">
    <div class="work-preview__heading-inner">
      <Signature
        text="A selection of"
        tone="mint"
        rotate={-3}
        size="clamp(2rem, 4vw, 3.25rem)"
      />
      <h2
        style="font-family:var(--font-display);font-size:clamp(4.5rem, 10vw, 8.5rem);color:var(--color-text-on-dark);line-height:1;letter-spacing:-0.02em;margin-top:-0.75rem;"
      >
        Our Work
      </h2>
      <div class="mt-6">
        <BtnFiller href="/work/" variant="solid-white" class="work-preview__cta">View Projects</BtnFiller>
      </div>
    </div>
  </div>

  <!-- Full-width navy fade. Imagery diffuses into solid navy at the bottom
       of the section across the whole width (not just the middle). The arc
       divider on ServicesPanel below creates the actual curved boundary. -->
  <div class="work-preview__bottom-fade" aria-hidden="true"></div>
</section>

<style>
  .work-preview {
    position: relative;
    overflow: hidden;
    background: var(--color-page-bg);
    height: clamp(640px, 95vh, 920px);
    margin: 0;
    /* clip-path defines the section's actual SHAPE. Top edge has a subtle
     * concave curve (dips down at center), matching the source's curve-
     * asymmetrical divider. Bottom edge does the same, mirrored, so the
     * imagery section has true curved top and bottom edges with no filled
     * divider band between sections. */
    clip-path: path('M0,0 C300,40 700,40 1000,0 L1000,1000 C700,960 300,960 0,1000 Z');
  }
  /* Fluid clip-path needs to scale to the actual section width. We hijack
   * a CSS variable + clip-path with a percentage-based path via objectBoundingBox
   * is fragile, so we use a JS-free trick: a larger viewBox + percentages won't
   * work either. Instead, we use polygon() approximating the curves. */
  .work-preview {
    /* Top: wavy curve flipped, peaks UP at center, dips at corners. */
    clip-path: polygon(
      0% 4%,
      10% 2.4%, 25% 1%, 40% 0.2%, 50% 0%, 60% 0.2%, 75% 1%, 90% 2.4%,
      100% 4%,
      100% 100%,
      0% 100%
    );
  }
  .work-preview__divider-top {
    /* unused now, clip-path handles the curve */
    display: none;
  }
  .work-preview__bottom-fade {
    /* 80px overlay at the bottom of the imagery section. Transparent at the
     * top → opaque navy at the bottom. Imagery dissolves into navy in this
     * region. The arc divider on ServicesPanel below handles the curved
     * boundary at the section edge. */
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 120px;
    z-index: 8;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(13, 32, 48, 0) 0%,
      rgba(13, 32, 48, 1) 100%
    );
  }

  .work-preview__columns {
    position: absolute;
    inset: -4rem -2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    transform: rotate(2deg);
    transform-origin: center;
  }
  @media (min-width: 1024px) {
    .work-preview__columns {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
      inset: -5rem -3rem;
    }
  }
  @media (max-width: 640px) {
    .work-preview__columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .work-preview__heading {
    /* Sticky: stays at top:30vh as the section scrolls past. The bottom
     * gradient (z-index 8) sits ABOVE the heading (z-index 4), so as the
     * section scrolls up and the gradient drifts up with it, the gradient
     * naturally overlaps and fades the heading from view. */
    position: sticky;
    top: 30vh;
    z-index: 4;
    width: min(95%, 40rem);
    margin: 28vh auto 0;
    text-align: center;
    pointer-events: none;
  }
  @media (max-width: 767px) {
    .work-preview__heading { margin-top: 22vh; }
  }
  .work-preview__heading-inner {
    pointer-events: auto;
  }
  /* Dark overlay over imagery for legibility of the centred heading. */
  .work-preview__overlay {
    position: absolute;
    inset: 0;
    background: rgba(13, 32, 48, 0.4);
    z-index: 2;
    pointer-events: none;
  }
  /* Bigger View Projects CTA inside the heading. */
  .work-preview__heading .work-preview__cta {
    padding: 18px 56px;
    font-size: 1.1rem;
  }
  @media (min-width: 1024px) {
    .work-preview__heading .work-preview__cta {
      padding: 22px 68px;
      font-size: 1.2rem;
    }
  }
</style>
