---
// Source-faithful "At Rooftop Twenty Two..." intro paragraph.
//
// Replaces the previous single-gradient sweep with a line-by-line reveal:
// each word starts low-opacity, and as the user scrolls the section into the
// viewport, lines reveal sequentially with words inside each line lighting up
// left-to-right (natural reading order). Lines are detected at runtime from
// word offsetTop so they always match the actual visual wrapping at the
// current viewport width.
const copy =
  "At Rooftop Twenty Two, we're an independent digital creative agency helping Irish businesses navigate the evolving landscape of strategy, branding, websites, digital marketing, and social media. We're here to make the digital world work for you, with tailored strategies that deliver real results.";
const words = copy.split(/(\s+)/).filter(Boolean);
---

<section class="mx-auto max-w-[1100px] px-6 md:px-12 py-20 md:py-32">
  <h2
    class="reveal-paragraph leading-snug"
    data-reveal-lines
    style="font-family:var(--font-display);font-size:clamp(1.5rem, 2.6vw, 2.5rem);letter-spacing:-0.005em;"
  >
    {words.map((w) => /\s/.test(w) ? <span class="reveal-word reveal-word--space">{w}</span> : <span class="reveal-word">{w}</span>)}
  </h2>
</section>

<style>
  .reveal-paragraph .reveal-word {
    display: inline-block;
    color: rgba(255, 255, 255, 0.18);
    transition: color 380ms ease-out;
    white-space: pre;
  }
  .reveal-paragraph .reveal-word.is-revealed {
    color: #ffffff;
  }
  /* Spaces stay revealed colour-wise but they're invisible anyway. */
  .reveal-paragraph .reveal-word--space {
    color: transparent;
  }
</style>

<script>
  type WordEl = HTMLElement & { _line?: number };
  const containers = Array.from(document.querySelectorAll<HTMLElement>("[data-reveal-lines]"));

  const state = new WeakMap<HTMLElement, { lines: WordEl[][] }>();

  function detectLines(container: HTMLElement) {
    const words = Array.from(container.querySelectorAll<WordEl>(".reveal-word"));
    const lines: WordEl[][] = [];
    let current: WordEl[] = [];
    let lastTop = Number.NaN;
    for (const w of words) {
      const top = w.offsetTop;
      if (!Number.isNaN(lastTop) && Math.abs(top - lastTop) > 4) {
        if (current.length) lines.push(current);
        current = [];
      }
      current.push(w);
      lastTop = top;
    }
    if (current.length) lines.push(current);
    state.set(container, { lines });
  }

  function update() {
    for (const container of containers) {
      const s = state.get(container);
      if (!s) continue;
      const rect = container.getBoundingClientRect();
      const vh = window.innerHeight;
      // Overall progress: 0 when bottom of paragraph at 85% of viewport,
      // 1 when top of paragraph reaches 25% of viewport.
      const startY = vh * 0.85;
      const endY = vh * 0.25;
      let p = (startY - rect.top) / (startY - endY);
      if (p < 0) p = 0;
      if (p > 1) p = 1;

      const lines = s.lines;
      const lineCount = lines.length;
      if (lineCount === 0) continue;
      // Scale overall progress so it spans lineCount units, then step each
      // line down by 0.85 (controls stagger / overlap). The last line reaches
      // lineProgress ≥ 1 when p = 1, so trailing words ("results") actually
      // get the is-revealed class at full scroll.
      const linesScaled = p * lineCount;
      const step = 0.85;
      for (let li = 0; li < lineCount; li++) {
        let lineProgress = linesScaled - li * step;
        if (lineProgress < 0) lineProgress = 0;
        if (lineProgress > 1) lineProgress = 1;

        const line = lines[li];
        for (let wi = 0; wi < line.length; wi++) {
          const wordThreshold = wi / line.length;
          line[wi].classList.toggle("is-revealed", lineProgress > wordThreshold);
        }
      }
      // Safety: at full scroll, force every word revealed regardless of
      // floating-point edges.
      if (p >= 0.999) {
        for (const line of lines) {
          for (const w of line) w.classList.add("is-revealed");
        }
      }
    }
  }

  function ready() {
    for (const c of containers) detectLines(c);
    update();
  }

  // Initial pass after layout settles + fonts load.
  if (document.readyState === "complete") {
    requestAnimationFrame(ready);
  } else {
    window.addEventListener("load", ready, { once: true });
  }

  let raf = 0;
  window.addEventListener("scroll", () => {
    if (raf) return;
    raf = requestAnimationFrame(() => {
      raf = 0;
      update();
    });
  }, { passive: true });

  let resizeTimer = 0;
  window.addEventListener("resize", () => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      for (const c of containers) detectLines(c);
      update();
    }, 120);
  }, { passive: true });
</script>
