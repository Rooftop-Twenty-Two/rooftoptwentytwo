---
// Serves a WebP sibling (generated by scripts/gen-webp.mjs) with the original
// raster as fallback. Falls back to a plain <img> when no WebP exists (e.g. SVGs
// or un-generated assets). The WebP presence is checked at build time.
import { existsSync } from "node:fs";
import path from "node:path";

interface Props {
  src: string;
  alt?: string;
  class?: string;
  [key: string]: unknown;
}

const { src, alt = "", ...rest } = Astro.props as Props;

const ext = path.extname(src).toLowerCase();
const isRaster = ext === ".png" || ext === ".jpg" || ext === ".jpeg";
const webpSrc = isRaster ? src.slice(0, -ext.length) + ".webp" : null;
// public/<...> on disk for the absolute web path.
const onDisk = webpSrc ? path.join(process.cwd(), "public", webpSrc) : null;
const hasWebp = !!onDisk && existsSync(onDisk);
---

{hasWebp ? (
  <picture>
    <source srcset={webpSrc} type="image/webp" />
    <img src={src} alt={alt} {...rest} />
  </picture>
) : (
  <img src={src} alt={alt} {...rest} />
)}
