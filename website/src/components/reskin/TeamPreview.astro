---
// Homepage "Meet the team" section. Pulls the team collection (Cathal, Roisin,
// Padraic first via their order) and presents the portraits as a single
// continuous marquee (pauses on hover), mirroring the Selected Work bar. Links
// to the About page.
import { getCollection } from "astro:content";
import Picture from "../Picture.astro";
import { existsSync } from "node:fs";
import path from "node:path";

// Only show members whose portrait is in the repo, so a newly-added member
// without an uploaded photo doesn't leave a broken tile.
const team = (await getCollection("team"))
  .filter((m) => existsSync(path.join(process.cwd(), "public", m.data.portrait)))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
// Two identical halves so the -50% → 0 marquee loops seamlessly.
const track = [...team, ...team];
---

<section class="tm">
  <div class="tm__head reveal">
    <p class="kicker kicker--script">Meet the team</p>
    <h2 class="tm__title">The people <em>behind the work</em>.</h2>
    <p class="tm__lead">A senior, in-house team that treats your growth like our own, the people who strategise are the people who ship.</p>
  </div>

  <div class="tm__viewport" data-marquee="60">
    <ul class="tm__rail" role="list">
      {track.map((m, i) => {
        const dup = i >= team.length;
        return (
          <li class:list={["tm__member", m.data.name === "Justin" && "tm__member--static"]} aria-hidden={dup ? "true" : "false"}>
            <div class="tm__img"><Picture src={m.data.portrait} alt={dup ? "" : m.data.name} loading="lazy" decoding="async" /></div>
            <p class="tm__name">{m.data.name}</p>
            <p class="tm__role">{m.data.role}</p>
          </li>
        );
      })}
    </ul>
  </div>

  <div class="tm__cta reveal">
    <a href="/about/#team" class="wbtn wbtn--primary">More about us</a>
  </div>
</section>

<style>
  .tm { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); overflow: hidden; }
  .tm__head { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .tm__title { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h2); line-height: var(--lh-heading); letter-spacing: var(--tracking-display); margin: 0.4rem 0 0; }
  .tm__title em { font-style: italic; color: var(--c-accent); }
  .tm__lead { font-family: var(--w-font-body); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--c-ink-soft); margin: 1.25rem 0 0; max-width: 60ch; }

  /* Continuous marquee — native-scroll driven (see Layout), pauses on hover. */
  .tm__viewport { margin-top: 3rem; overflow: hidden; }
  .tm__rail { list-style: none; margin: 0; padding: 0.5rem 0; display: flex; width: max-content; }
  .tm__member { flex: 0 0 clamp(150px, 40vw, 200px); margin: 0 1.5rem 0 0; }
  .tm__img { border-radius: var(--w-radius); overflow: hidden; aspect-ratio: 5 / 6; background: var(--c-bg-alt); }
  .tm__img :global(img) { width: 100%; height: 100%; object-fit: cover; object-position: center 18%; filter: grayscale(1); transition: filter var(--w-dur) var(--w-ease), transform var(--w-dur) var(--w-ease); }
  .tm__member:hover .tm__img :global(img) { filter: grayscale(0); transform: scale(1.03); }
  .tm__member--static:hover .tm__img :global(img) { filter: grayscale(1); transform: none; }
  .tm__name { font-family: var(--w-font-display); font-weight: 600; font-size: 1.05rem; color: var(--c-ink); margin: 0.85rem 0 0; }
  .tm__role { font-family: var(--w-font-body); font-size: var(--fs-small); color: var(--c-ink-soft); margin: 0.15rem 0 0; }

  .tm__cta { max-width: var(--w-container); margin: 3rem auto 0; padding-inline: var(--w-gutter); }

  @media (prefers-reduced-motion: reduce) {
    .tm__viewport { overflow-x: auto; scrollbar-width: none; }
    .tm__viewport::-webkit-scrollbar { display: none; }
  }
</style>
