---
// S4, Logo wall / trust bar. Monochrome (white) client logos on a dark band,
// scrolling as a seamless left-to-right marquee.
const logos = [
  { src: "/images/logos/GFP_Rev.svg", alt: "Gourmet Food Parlour" },
  { src: "/images/logos/ILT_Rev.svg", alt: "Irish Landmark Trust" },
  { src: "/images/logos/TC-Matthews_Rev.svg", alt: "TC Matthews" },
  { src: "/images/logos/MIG_Rev.svg", alt: "McCarthy Insurance Group" },
  { src: "/images/logos/1934_Rev.svg", alt: "The 1933 Furniture Company" },
  { src: "/images/logos/Josesph-May_Rev.svg", alt: "Joseph May" },
  { src: "/images/logos/Shomera_Rev.svg", alt: "Shomera" },
  { src: "/images/logos/GCJ_Rev.png", alt: "Guinness Cork Jazz" },
];
// Repeat into a long track so a single half fills wide viewports; the track is
// then two identical halves, which lets the -50% → 0 animation loop seamlessly.
const half = [...logos, ...logos];
const track = [...half, ...half];
---

<section class="lw">
  <div class="lw__inner">
    <p class="kicker kicker--on-dark">Trusted by ambitious Irish brands</p>
  </div>
  <div class="lw__marquee" aria-hidden="false">
    <ul class="lw__track" role="list">
      {track.map((l, i) => (
        <li aria-hidden={i >= half.length ? "true" : "false"}>
          <img src={l.src} alt={i >= half.length ? "" : l.alt} loading="lazy" decoding="async" />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .lw { background: var(--c-dark); color: var(--c-on-dark); padding-block: clamp(3rem, 6vw, 5rem); overflow: hidden; }
  .lw__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .lw__marquee {
    margin-top: 2.25rem; overflow: hidden;
    transform: translateZ(0);  /* own layer — fixes Safari mask + transform blank-render */
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
            mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .lw__track {
    list-style: none; margin: 0; padding: 0;
    display: flex; align-items: center; gap: clamp(2.5rem, 5vw, 5rem); width: max-content;
    will-change: transform; animation: lw-scroll 45s linear infinite;
  }
  .lw__track li { flex: 0 0 auto; display: flex; align-items: center; justify-content: center; }
  .lw__track img {
    max-height: 38px; width: auto; height: auto;
    /* Normalise mixed-source logos (white SVGs + a colour PNG) to one white tone. */
    filter: brightness(0) invert(1);
    opacity: 0.65; transition: opacity var(--w-dur-fast) var(--w-ease);
  }
  .lw__track li:hover img { opacity: 1; }
  /* Only pause on pointer devices — :hover sticks after a tap on touchscreens. */
  @media (hover: hover) { .lw:hover .lw__track { animation-play-state: paused; } }

  /* Two identical halves → translate left-to-right by one half and loop seamlessly. */
  @keyframes lw-scroll {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lw__track { animation: none; transform: none; justify-content: center; flex-wrap: wrap; gap: 2.5rem 3rem; }
  }
</style>
