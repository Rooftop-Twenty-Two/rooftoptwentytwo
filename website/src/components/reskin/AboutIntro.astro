---
// S3, About / intro split. Kicker + H2 (with emphasised phrase) + body + CTAs
// on one side; image on the other. White section.
const image = "/images/office/office-portrait-01.jpg";
---

<section class="ai">
  <div class="ai__inner">
    <div class="ai__copy reveal">
      <p class="kicker kicker--script">Your outsourced marketing growth team</p>
      <h2 class="ai__title">
        One Strategy. Every Channel. <em>Clear Results</em>.
      </h2>
      <p class="ai__body">
        Rooftop Twenty Two is an independent studio that plugs into your business
        like an in-house team, bringing strategy, brand, web, and performance
        together in one place. One joined-up team, accountable to the numbers that matter.
      </p>
      <div class="ai__cta">
        <a href="/about/" class="wbtn wbtn--primary">About us</a>
        <a href="/contact/" class="wbtn wbtn--ghost ai__ghost">Get in touch</a>
      </div>
    </div>
    <figure class="ai__media reveal">
      <img src={image} alt="A Rooftop Twenty Two designer at work in the Dublin studio" loading="lazy" decoding="async" />
    </figure>
  </div>
</section>

<style>
  .ai { background: var(--c-bg); color: var(--c-ink); padding-block: var(--w-section-y); }
  .ai__inner {
    max-width: var(--w-container);
    margin: 0 auto;
    padding-inline: var(--w-gutter);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 920px) {
    .ai__inner { grid-template-columns: 1.05fr 0.95fr; gap: 5rem; }
  }
  .ai__title {
    font-family: var(--w-font-display);
    font-weight: 600;
    font-size: var(--fs-h2);
    line-height: var(--lh-heading);
    letter-spacing: var(--tracking-display);
    margin: 1rem 0 0;
  }
  .ai__title em { font-style: normal; color: var(--c-accent); }
  .ai__body {
    font-family: var(--w-font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--c-ink-soft);
    margin-top: 1.5rem;
    max-width: 46ch;
  }
  .ai__cta { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }
  .ai__ghost { color: var(--c-ink); }
  .ai__media { margin: 0; border-radius: var(--w-radius); overflow: hidden; aspect-ratio: 4 / 3; }
  .ai__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
