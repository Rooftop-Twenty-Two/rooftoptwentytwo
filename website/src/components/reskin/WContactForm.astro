---
// Reusable inline contact form band (navy). Uses the site's own markup/styling
// but posts straight to JotForm (EU) — the exact same form as the /contact
// page (ID + field names taken verbatim from the JotForm source) — so
// case-study enquiries land in the same JotForm inbox and work reliably.
// formID + simple_spc are JotForm's required hidden fields; `website` is its
// honeypot and must stay empty.
interface Props {
  heading?: string;
  lead?: string;
  routing?: string;        // accepted for back-compat; folded into the subject
  prefillSubject?: string;
  prefillMessage?: string;
}
const {
  heading = "Like what you see? Let's talk.",
  lead = "Tell us what you're scaling, launching, or rebuilding. We'll come back with a thoughtful reply and a time to talk it through.",
  prefillSubject = "",
  prefillMessage = "",
} = Astro.props;

const JOTFORM_ID = "261524373945058";
const jotformAction = `https://eu-submit.jotform.com/submit/${JOTFORM_ID}`;
const simpleSpc = `${JOTFORM_ID}-${JOTFORM_ID}`;
---

<section class="wcf" id="contact">
  <div class="wcf__inner">
    <div class="wcf__aside">
      <p class="kicker kicker--on-dark kicker--script">Get in touch</p>
      <h2 class="wcf__title" set:html={heading} />
      <p class="wcf__lead">{lead}</p>
      <div class="wcf__details">
        <a href="mailto:hey@rooftoptwentytwo.ie">hey@rooftoptwentytwo.ie</a>
        <a href="tel:+35316991422">+353 1 699 1422</a>
        <address>Rooftop Twenty Two, Claremont Avenue,<br />Glasnevin, Dublin 11, D11 YNR2</address>
      </div>
    </div>

    <form class="wcf__form" action={jotformAction} method="post" accept-charset="utf-8" data-jotform-redirect="/thank-you/">
      <input type="hidden" name="formID" value={JOTFORM_ID} />
      <input type="hidden" name="simple_spc" value={simpleSpc} />
      <!-- JotForm honeypot: must stay empty -->
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
      <label class="wcf__field">
        <span>First name</span>
        <input type="text" name="q2_q2_fullname0[first]" required placeholder="Your first name" />
      </label>
      <label class="wcf__field">
        <span>Last name</span>
        <input type="text" name="q2_q2_fullname0[last]" required placeholder="Your last name" />
      </label>
      <label class="wcf__field">
        <span>Email</span>
        <input type="email" name="q3_q3_email1" required placeholder="you@company.com" />
      </label>
      <label class="wcf__field">
        <span>Company</span>
        <input type="text" name="q7_company" placeholder="Company (optional)" />
      </label>
      <label class="wcf__field wcf__field--full">
        <span>Subject</span>
        <input type="text" name="q4_q4_textbox2" required placeholder="What's this about?" value={prefillSubject} />
      </label>
      <label class="wcf__field wcf__field--full">
        <span>Message</span>
        <textarea name="q5_q5_textarea3" required rows="5" placeholder="Tell us a little about your project">{prefillMessage}</textarea>
      </label>
      <button type="submit" class="wbtn wbtn--accent wcf__submit">Send message</button>
    </form>
  </div>
</section>

<script>
  // Submit the enquiry to JotForm in the background, then send the visitor to
  // our own /thank-you/ page. Without JS the form still posts to JotForm
  // normally (showing JotForm's thank-you). Mirrors the /contact handler.
  const form = document.querySelector<HTMLFormElement>("form.wcf__form[data-jotform-redirect]");
  if (form) {
    const dest = form.dataset.jotformRedirect || "/";
    form.addEventListener("submit", (e) => {
      if (!form.checkValidity()) return;
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.textContent = "Sending…"; }
      fetch(form.action, { method: "POST", body: new FormData(form), mode: "no-cors", keepalive: true })
        .catch(() => {})
        .finally(() => { window.location.href = dest; });
    });
  }
</script>

<style>
  .wcf { background: var(--c-dark); color: var(--c-on-dark); padding-block: var(--w-section-y); }
  .wcf__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 920px) { .wcf__inner { grid-template-columns: 1fr 1.05fr; gap: 5rem; align-items: start; } }
  .wcf__title { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h2); line-height: var(--lh-heading); letter-spacing: var(--tracking-display); margin: 1rem 0 0; }
  .wcf__title :global(em) { font-style: normal; color: var(--c-accent-2); }
  .wcf__lead { font-family: var(--w-font-body); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--c-on-dark-soft); margin: 1.25rem 0 0; max-width: 44ch; }
  .wcf__details { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 2rem; font-family: var(--w-font-body); }
  .wcf__details a { color: var(--c-on-dark); text-decoration: none; font-weight: 600; }
  .wcf__details a:hover { color: var(--c-accent); }
  .wcf__details address { color: var(--c-on-dark-soft); font-style: normal; line-height: 1.6; margin-top: 0.5rem; }

  .wcf__form { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .wcf__field { display: flex; flex-direction: column; gap: 0.4rem; }
  .wcf__field--full { grid-column: 1 / -1; }
  .wcf__field span { font-family: var(--w-font-body); font-size: var(--fs-small); color: var(--c-on-dark-soft); }
  .wcf__field input, .wcf__field textarea {
    width: 100%; padding: 0.9rem 1.1rem; border-radius: 14px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.16);
    color: var(--c-on-dark); font-family: var(--w-font-body); font-size: 1rem; resize: vertical;
  }
  .wcf__field input::placeholder, .wcf__field textarea::placeholder { color: rgba(255,255,255,0.4); }
  .wcf__field input:focus-visible, .wcf__field textarea:focus-visible { outline: 2px solid var(--c-accent); outline-offset: 2px; border-color: transparent; }
  .wcf__submit { grid-column: 1 / -1; justify-self: start; margin-top: 0.5rem; }
</style>
