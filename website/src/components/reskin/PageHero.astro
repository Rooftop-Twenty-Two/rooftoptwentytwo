---
// S2 — Compact page hero (re-skin). Kicker + big H1 + intro + optional CTAs,
// on a near-black band with an optional faded background image.
interface Props {
  kicker?: string;
  title: string;
  intro?: string;
  bg?: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
}
const { kicker, title, intro, bg, primary, secondary } = Astro.props;
---

<section class="ph" style={bg ? `--ph-bg:url('${bg}')` : undefined} data-has-bg={bg ? "true" : undefined}>
  <div class="ph__inner">
    {kicker && <p class="kicker kicker--on-dark">{kicker}</p>}
    <h1 class="ph__title" set:html={title} />
    {intro && <p class="ph__intro">{intro}</p>}
    {(primary || secondary) && (
      <div class="ph__cta">
        {primary && <a href={primary.href} class="wbtn wbtn--accent">{primary.label}</a>}
        {secondary && <a href={secondary.href} class="wbtn wbtn--ghost ph__ghost">{secondary.label}</a>}
      </div>
    )}
  </div>
</section>

<style>
  .ph {
    position: relative; isolation: isolate;
    background: var(--c-dark); color: var(--c-on-dark);
    padding-block: clamp(7rem, 14vw, 11rem) var(--w-section-y);
  }
  .ph[data-has-bg] {
    background-image:
      linear-gradient(rgba(13,32,48,0.82), rgba(13,32,48,0.9)), var(--ph-bg);
    background-size: cover; background-position: center;
  }
  .ph__inner { max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter); }
  .ph__title {
    font-family: var(--w-font-display); font-weight: 600;
    font-size: var(--fs-display); line-height: var(--lh-display);
    letter-spacing: var(--tracking-display); color: var(--c-on-dark);
    margin: 1.25rem 0 0; max-width: 18ch;
  }
  .ph__title :global(em) { font-style: normal; color: var(--c-accent-2); }
  .ph__intro {
    font-family: var(--w-font-body); font-size: var(--fs-body); line-height: var(--lh-body);
    color: var(--c-on-dark-soft); margin: 1.5rem 0 0; max-width: 52ch;
  }
  .ph__cta { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2.25rem; }
  .ph__ghost { color: var(--c-on-dark); }
</style>
