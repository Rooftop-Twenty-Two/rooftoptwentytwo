---
// S5, Selected work. Case-study cards pulled from the portfolio collection,
// presented as a single continuous left-to-right marquee (pauses on hover),
// mirroring the client logo bar. Off-white section. No fabricated metrics.
import { getCollection } from "astro:content";
import Picture from "../Picture.astro";

const all = (await getCollection("portfolio")).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100)
);
// Kept off the homepage marquee (still live on /work/ and elsewhere).
const HOMEPAGE_EXCLUDE = new Set(["best4travel", "antaris-consulting"]);
const withHero = all.filter((p) => p.data.heroImage && !HOMEPAGE_EXCLUDE.has(p.data.slug));
// Lead with the featured work, then fill by order.
const cards = [
  ...withHero.filter((p) => p.data.featured),
  ...withHero.filter((p) => !p.data.featured),
].slice(0, 10);
// Two identical halves so the -50% → 0 animation loops seamlessly.
const track = [...cards, ...cards];
---

<section class="sw">
  <div class="sw__head">
    <div class="sw__intro reveal">
      <p class="kicker kicker--script">Selected work</p>
      <h2 class="sw__title">Work we&rsquo;re <em>proud of</em>.</h2>
    </div>
    <a href="/work/" class="wbtn wbtn--primary sw__all">View all work</a>
  </div>

  <div class="sw__viewport" data-marquee="55">
    <ul class="sw__rail" role="list">
      {track.map((c, i) => {
        const dup = i >= cards.length;
        return (
          <li class="sw__card" aria-hidden={dup ? "true" : "false"}>
            <a class="r22-card" href={`/work/${c.data.slug}/`} tabindex={dup ? -1 : undefined}>
              <figure class="sw__img r22-media">
                <Picture src={c.data.heroImage} alt={dup ? "" : c.data.name} loading="lazy" decoding="async" />
              </figure>
              <div class="sw__meta">
                <span class="sw__client">{c.data.name}</span>
                <span class="sw__tag">{c.data.tagline}</span>
                <span class="sw__cta r22-arrow">View case study <span class="r22-arrow__i" aria-hidden="true">&rarr;</span></span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .sw { background: var(--c-bg-alt); color: var(--c-ink); padding-block: var(--w-section-y); overflow: hidden; }
  .sw__head {
    max-width: var(--w-container); margin: 0 auto; padding-inline: var(--w-gutter);
    display: grid; gap: 1.25rem; align-items: end;
  }
  @media (min-width: 820px) { .sw__head { grid-template-columns: 1fr auto; } }
  .sw__title {
    font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h2);
    line-height: var(--lh-heading); letter-spacing: var(--tracking-display); margin: 0.25rem 0 0;
  }
  .sw__title em { font-style: italic; color: var(--c-accent); }

  /* Continuous marquee — native-scroll driven (see Layout), pauses on hover. */
  .sw__viewport { margin-top: 2.5rem; overflow: hidden; }
  .sw__rail {
    list-style: none; margin: 0; padding: 0.5rem 0 1rem;
    display: flex; width: max-content;
  }
  .sw__card { flex: 0 0 min(80vw, 400px); margin-right: 1.5rem; }
  .sw__card a { text-decoration: none; color: inherit; display: block; }
  .sw__img {
    margin: 0; border: 1px solid var(--c-line); border-radius: var(--w-radius); overflow: hidden; aspect-ratio: 4 / 3;
    background: #fff; box-shadow: var(--w-shadow-soft);
  }
  .sw__img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform var(--w-dur) var(--w-ease); }
  .sw__card a:hover .sw__img img { transform: scale(1.04); }
  .sw__meta { display: flex; flex-direction: column; gap: 0.3rem; margin-top: 1.1rem; }
  .sw__client { font-family: var(--w-font-display); font-weight: 600; font-size: var(--fs-h3); line-height: 1.1; }
  .sw__tag { font-family: var(--w-font-body); font-size: var(--fs-body); color: var(--c-ink-soft); }
  .sw__cta { font-family: var(--w-font-body); font-weight: 600; font-size: 0.9rem; color: var(--c-accent); margin-top: 0.35rem; }

  @media (prefers-reduced-motion: reduce) {
    .sw__viewport { overflow-x: auto; scrollbar-width: none; }
    .sw__viewport::-webkit-scrollbar { display: none; }
  }
</style>
