---
// Subtle full-bleed brand ticker — large outlined "Rooftop Twenty Two" scrolling
// left to right. Two identical halves so the -50% → 0 loop is seamless. Decorative.
interface Props {
  variant?: "dark" | "light";
}
const { variant = "dark" } = Astro.props;
const word = "Rooftop Twenty Two";
const reps = Array.from({ length: 8 });
---

<div class:list={["bticker", `bticker--${variant}`]} aria-hidden="true">
  <div class="bticker__track">
    {reps.map(() => (
      <span class="bticker__word">{word}<span class="bticker__sep">&middot;</span></span>
    ))}
  </div>
</div>

<style>
  .bticker { overflow: hidden; padding-block: clamp(0.75rem, 2vw, 1.5rem); }
  .bticker--dark { background: var(--c-dark); }
  .bticker--light { background: var(--c-bg-alt); }
  .bticker__track { display: flex; width: max-content; animation: bticker-scroll 48s linear infinite; }
  .bticker__word {
    display: inline-flex; align-items: center; white-space: nowrap;
    font-family: var(--w-font-display); font-weight: 700;
    font-size: clamp(2.75rem, 7vw, 6.5rem); line-height: 1.1; letter-spacing: -0.01em;
    color: transparent;
  }
  .bticker--dark .bticker__word { -webkit-text-stroke: 1px rgba(255, 255, 255, 0.16); }
  .bticker--light .bticker__word { -webkit-text-stroke: 1px rgba(20, 58, 79, 0.14); }
  .bticker__sep {
    -webkit-text-stroke: 0; padding: 0 1.5rem; transform: translateY(-0.08em);
  }
  .bticker--dark .bticker__sep { color: var(--c-accent); }
  .bticker--light .bticker__sep { color: var(--c-accent); }

  /* Left to right: two identical halves, translate from -50% back to 0. */
  @keyframes bticker-scroll {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .bticker__track { animation: none; transform: none; }
  }
</style>
