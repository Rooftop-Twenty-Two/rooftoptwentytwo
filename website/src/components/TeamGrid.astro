---
import { getCollection } from "astro:content";

const team = (await getCollection("team")).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100)
);
---

<ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6 md:gap-8 list-none p-0 m-0">
  {team.map((member) => (
    <li>
      <figure class="m-0">
        <div
          class="overflow-hidden"
          style="border-radius:var(--radius-card-md);aspect-ratio:5/6;background-color:var(--color-navy-700);"
        >
          <img
            src={member.data.portrait}
            alt={member.data.name}
            class="w-full h-full object-cover grayscale"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption class="mt-3">
          <p
            style="font-family:var(--font-sans);font-weight:600;color:var(--color-text-on-dark);font-size:var(--text-body);"
          >
            {member.data.name}
          </p>
          <p
            class="mt-0.5"
            style="font-family:var(--font-sans);font-size:var(--text-body-sm);color:var(--color-text-on-dark-muted);"
          >
            {member.data.role}
          </p>
        </figcaption>
      </figure>
    </li>
  ))}
</ul>
