---
// Source-style detail hero: full-width brand-coloured banner driven by the
// case study's hero image. Pills + tagline sit BELOW the banner on the
// stone body background — many case study hero images already contain
// brand text or strong typographic elements, so overlaying our pills
// on the image creates clash.

interface Props {
  name: string;
  tagline?: string;
  heroImage?: string;
  wordmark?: string;
  services?: string[];
}
const { name, tagline, heroImage, services = [] } = Astro.props;
---

<section class="detail-hero">
  <div
    class="detail-hero__banner"
    style={heroImage
      ? `background-image:url('${heroImage}');`
      : `background-color: var(--color-navy-700);`}
  >
    <svg class="detail-hero__arc" viewBox="0 0 1000 100" preserveAspectRatio="none" aria-hidden="true">
      <path d="M 0 78 C 220 -5, 780 -5, 1000 78 L 1000 100 L 0 100 Z" />
    </svg>
  </div>

  <div class="detail-hero__meta mx-auto max-w-[1440px] px-6 md:px-12">
    {services.length > 0 && (
      <ul class="detail-hero__pills" aria-label="Services delivered">
        {services.map((s) => (
          <li>{s}</li>
        ))}
      </ul>
    )}
    {tagline && (
      <h1 class="detail-hero__tagline">{tagline}</h1>
    )}
  </div>
</section>

<style>
  .detail-hero {
    position: relative;
    /* Pull the brand banner up under the transparent sticky header. The
       header's content is the PressToTalkRing (56px) + py-5/6 padding —
       104px total on desktop, 96px on mobile. We overshoot by ~16px so
       there's never a gap above the banner. */
    margin-top: -112px;
  }
  @media (min-width: 768px) {
    .detail-hero { margin-top: -120px; }
  }
  .detail-hero__banner {
    position: relative;
    min-height: clamp(550px, 77vh, 800px);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }
  .detail-hero__arc {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 80px;
    fill: var(--color-stone-100, #F9F9F9);
    pointer-events: none;
    z-index: 3;
    display: block;
  }
  @media (min-width: 768px) {
    .detail-hero__arc { height: 100px; }
  }

  .detail-hero__meta {
    padding-top: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  .detail-hero__pills {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .detail-hero__pills li {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.05rem;
    border-radius: 9999px;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    background: var(--color-navy-900, #0D2030);
    border: 1px solid var(--color-navy-900, #0D2030);
  }
  .detail-hero__tagline {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--color-text-on-light, #143A4F);
    max-width: 24ch;
    margin: 0;
  }
</style>
