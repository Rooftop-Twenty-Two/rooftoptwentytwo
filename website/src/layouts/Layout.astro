---
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
import OrganizationSchema from "../components/seo/OrganizationSchema.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hidePreFooterCTA?: boolean;
  hideStickyMobileCTA?: boolean;
  theme?: "dark" | "light";
}

const {
  title = "Rooftop Twenty Two, Independent branding and digital design studio, Dublin",
  description = "Rooftop Twenty Two is an independent branding and digital design studio that develops brands, strategies, and experiences for exceptional companies.",
  ogImage = "/og-default.jpg",
  hideStickyMobileCTA = false,
  theme = "dark",
} = Astro.props;

const path = Astro.url.pathname;
const isContact = path === "/contact/" || path === "/contact";

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://rooftoptwentytwo.ie").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Genuine R22 brand faces, self-hosted: Butler (display), Mulish (body),
         Starlit Drive (script signatures). Preloaded, font-display: swap. -->
    <link rel="preload" href="/fonts/butler-bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/mulish-variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/starlit-drive.woff2" as="font" type="font/woff2" crossorigin />
    <OrganizationSchema />
  </head>
  <body class:list={[theme === "light" ? "theme-light" : "theme-dark"]}>
    <div class="cursor-glow" aria-hidden="true" data-cursor-glow></div>

    <Header />
    <main id="main" style="position:relative;z-index:2;"><slot /></main>
    {!hideStickyMobileCTA && !isContact && <StickyMobileCTA />}
    <SiteFooter />
    <MenuOverlay />

    <script>
      // ---------- Progressive-enhancement marker ----------
      document.documentElement.classList.add("js-ready");

      // ---------- .reveal IntersectionObserver ----------
      const targets = document.querySelectorAll<HTMLElement>(".reveal");
      if (targets.length) {
        if (!("IntersectionObserver" in window)) {
          targets.forEach((el) => el.classList.add("is-visible"));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add("is-visible");
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.1, rootMargin: "0px 0px -5% 0px" }
          );
          targets.forEach((el) => io.observe(el));
        }
      }

      // ---------- Marquees (native-scroll driven, no CSS transform) ----------
      // Auto-scrolls a [data-marquee] container left→right by writing scrollLeft
      // each frame. Avoids transform/mask (which blank-render on iOS Safari).
      // The track holds two identical halves so resetting at the boundary is seamless.
      const marquees = document.querySelectorAll<HTMLElement>("[data-marquee]");
      const reduceMo = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const canHover = window.matchMedia("(hover: hover)").matches;
      marquees.forEach((vp) => {
        const track = vp.firstElementChild as HTMLElement | null;
        if (!track) return;
        const durSec = parseFloat(vp.dataset.marquee || "60") || 60;
        let half = track.scrollWidth / 2;
        let paused = false;
        let last = 0;
        const start = () => { half = track.scrollWidth / 2; vp.scrollLeft = half; };
        start();
        window.addEventListener("resize", () => { half = track.scrollWidth / 2; }, { passive: true });
        if (canHover) {
          vp.addEventListener("mouseenter", () => { paused = true; });
          vp.addEventListener("mouseleave", () => { paused = false; });
        }
        if (reduceMo) return; // leave static
        const tick = (ts: number) => {
          if (!last) last = ts;
          const dt = ts - last; last = ts;
          if (!paused && half > 0) {
            vp.scrollLeft -= (half / (durSec * 1000)) * dt;
            if (vp.scrollLeft <= 0) vp.scrollLeft += half;
          }
          requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });

      // ---------- textRevealOnScroll: drives --reveal-progress 0..100 ----------
      const revealNodes = document.querySelectorAll<HTMLElement>("[data-reveal-scroll]");
      if (revealNodes.length) {
        function updateReveal() {
          const vh = window.innerHeight;
          for (const node of revealNodes) {
            const r = node.getBoundingClientRect();
            // Fully revealed once the top has scrolled to ~30% of viewport;
            // begins revealing as the bottom crosses 80%.
            const start = vh * 0.85;
            const end = vh * 0.25;
            let p = ((start - r.top) / (start - end)) * 100;
            if (p < 0) p = 0;
            if (p > 100) p = 100;
            node.style.setProperty("--reveal-progress", String(p));
          }
        }
        updateReveal();
        let raf = 0;
        window.addEventListener(
          "scroll",
          () => {
            if (raf) return;
            raf = requestAnimationFrame(() => {
              raf = 0;
              updateReveal();
            });
          },
          { passive: true }
        );
        window.addEventListener("resize", updateReveal, { passive: true });
      }

      // ---------- btn-filler radial hover (positions inner span at cursor entry) ----------
      const fillers = document.querySelectorAll<HTMLElement>(".btn-filler");
      for (const f of fillers) {
        const span = f.querySelector<HTMLElement>("span");
        if (!span) continue;
        const place = (e: MouseEvent) => {
          const rect = f.getBoundingClientRect();
          span.style.left = `${e.clientX - rect.left}px`;
          span.style.top = `${e.clientY - rect.top}px`;
        };
        f.addEventListener("mouseenter", place);
        f.addEventListener("mouseleave", place);
      }

      // ---------- Theme-switch observer ----------
      // When a [data-theme-switch] section enters the viewport, add
      // body.alternate-theme so the header (and other dark-on-dark elements)
      // can swap to a light-on-light treatment. CSS variables in globals.css
      // handle the actual colour swaps.
      // ---------- Cursor glow (radial blob, transform-only for smoothness) ----------
      const glow = document.querySelector<HTMLElement>("[data-cursor-glow]");
      if (glow && window.matchMedia("(hover: hover)").matches && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        let cx = 0, cy = 0, raf = 0;
        // Always a teal/mint halo. We only adapt the *opacity* to the surface
        // under the cursor (a touch stronger on light sections) so the same
        // brand colour reads on dark *and* light backgrounds.
        const adapt = () => {
          raf = 0;
          const el = document.elementFromPoint(cx, cy); // glow is pointer-events:none
          let node: HTMLElement | null = el as HTMLElement | null;
          while (node && node !== document.documentElement) {
            const bg = getComputedStyle(node).backgroundColor;
            const m = bg.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/);
            if (m && (m[4] === undefined || parseFloat(m[4]) > 0.5)) {
              const lum = (0.2126 * +m[1] + 0.7152 * +m[2] + 0.0722 * +m[3]) / 255;
              glow.style.setProperty("--glow-a", lum < 0.5 ? "0.22" : "0.3");
              return;
            }
            node = node.parentElement;
          }
          glow.style.setProperty("--glow-a", "0.22");
        };
        window.addEventListener(
          "mousemove",
          (e) => {
            glow.classList.add("is-active");
            cx = e.clientX; cy = e.clientY;
            glow.style.transform = `translate3d(${cx}px, ${cy}px, 0)`;
            if (!raf) raf = requestAnimationFrame(adapt);
          },
          { passive: true }
        );
        window.addEventListener("mouseleave", () => glow.classList.remove("is-active"));
      }

      const themeSections = document.querySelectorAll<HTMLElement>("[data-theme-switch]");
      if (themeSections.length) {
        // Count of currently-intersecting theme sections. Header inverts only
        // while at least one is on-screen; reverts in both directions
        // (scrolling down past the section AND scrolling back up to the hero).
        let inViewCount = 0;
        const themeIO = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              inViewCount += e.isIntersecting ? 1 : -1;
            }
            if (inViewCount < 0) inViewCount = 0;
            document.body.classList.toggle("alternate-theme", inViewCount > 0);
          },
          { rootMargin: "-15% 0px -55% 0px" }
        );
        themeSections.forEach((s) => themeIO.observe(s));
      }
    </script>
  </body>
</html>
