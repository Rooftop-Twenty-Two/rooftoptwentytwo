---
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
import OrganizationSchema from "../components/seo/OrganizationSchema.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hidePreFooterCTA?: boolean;
  hideStickyMobileCTA?: boolean;
  theme?: "dark" | "light";
}

const {
  title = "Rooftop Twenty Two, Independent branding and digital design studio, Dublin",
  description = "Rooftop Twenty Two is an independent branding and digital design studio that develops brands, strategies, and experiences for exceptional companies.",
  ogImage = "/og-default.jpg",
  hideStickyMobileCTA = false,
  theme = "dark",
} = Astro.props;

const path = Astro.url.pathname;
const isContact = path === "/contact/" || path === "/contact";

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://rooftoptwentytwo.ie").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preload" href="/fonts/butler-bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/mulish-variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/starlit-drive.woff2" as="font" type="font/woff2" crossorigin />
    <OrganizationSchema />
  </head>
  <body class:list={[theme === "light" ? "theme-light" : "theme-dark"]}>
    <div class="cursor-glow" aria-hidden="true" data-cursor-glow></div>

    <Header />
    <main id="main" style="position:relative;z-index:2;"><slot /></main>
    {!hideStickyMobileCTA && !isContact && <StickyMobileCTA />}
    <SiteFooter />
    <MenuOverlay />

    <script>
      // ---------- Progressive-enhancement marker ----------
      document.documentElement.classList.add("js-ready");

      // ---------- .reveal IntersectionObserver ----------
      const targets = document.querySelectorAll<HTMLElement>(".reveal");
      if (targets.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.15 }
        );
        targets.forEach((el) => io.observe(el));
      }

      // ---------- textRevealOnScroll: drives --reveal-progress 0..100 ----------
      const revealNodes = document.querySelectorAll<HTMLElement>("[data-reveal-scroll]");
      if (revealNodes.length) {
        function updateReveal() {
          const vh = window.innerHeight;
          for (const node of revealNodes) {
            const r = node.getBoundingClientRect();
            // Fully revealed once the top has scrolled to ~30% of viewport;
            // begins revealing as the bottom crosses 80%.
            const start = vh * 0.85;
            const end = vh * 0.25;
            let p = ((start - r.top) / (start - end)) * 100;
            if (p < 0) p = 0;
            if (p > 100) p = 100;
            node.style.setProperty("--reveal-progress", String(p));
          }
        }
        updateReveal();
        let raf = 0;
        window.addEventListener(
          "scroll",
          () => {
            if (raf) return;
            raf = requestAnimationFrame(() => {
              raf = 0;
              updateReveal();
            });
          },
          { passive: true }
        );
        window.addEventListener("resize", updateReveal, { passive: true });
      }

      // ---------- btn-filler radial hover (positions inner span at cursor entry) ----------
      const fillers = document.querySelectorAll<HTMLElement>(".btn-filler");
      for (const f of fillers) {
        const span = f.querySelector<HTMLElement>("span");
        if (!span) continue;
        const place = (e: MouseEvent) => {
          const rect = f.getBoundingClientRect();
          span.style.left = `${e.clientX - rect.left}px`;
          span.style.top = `${e.clientY - rect.top}px`;
        };
        f.addEventListener("mouseenter", place);
        f.addEventListener("mouseleave", place);
      }

      // ---------- Theme-switch observer ----------
      // When a [data-theme-switch] section enters the viewport, add
      // body.alternate-theme so the header (and other dark-on-dark elements)
      // can swap to a light-on-light treatment. CSS variables in globals.css
      // handle the actual colour swaps.
      // ---------- Cursor glow (radial blob, transform-only for smoothness) ----------
      const glow = document.querySelector<HTMLElement>("[data-cursor-glow]");
      if (glow && window.matchMedia("(hover: hover)").matches && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        window.addEventListener(
          "mousemove",
          (e) => {
            glow.classList.add("is-active");
            glow.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0)`;
          },
          { passive: true }
        );
        window.addEventListener("mouseleave", () => glow.classList.remove("is-active"));
      }

      const themeSections = document.querySelectorAll<HTMLElement>("[data-theme-switch]");
      if (themeSections.length) {
        // Count of currently-intersecting theme sections. Header inverts only
        // while at least one is on-screen; reverts in both directions
        // (scrolling down past the section AND scrolling back up to the hero).
        let inViewCount = 0;
        const themeIO = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              inViewCount += e.isIntersecting ? 1 : -1;
            }
            if (inViewCount < 0) inViewCount = 0;
            document.body.classList.toggle("alternate-theme", inViewCount > 0);
          },
          { rootMargin: "-15% 0px -55% 0px" }
        );
        themeSections.forEach((s) => themeIO.observe(s));
      }
    </script>
  </body>
</html>
